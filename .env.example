# Copy to .env (gitignored) and fill in. Loaded automatically by main.py.

# --- BitGN platform -------------------------------------------------------
# Required for official leaderboard runs. Get it at https://bitgn.com/me
BITGN_API_KEY=

# --- Model selection ------------------------------------------------------
# Routing lives in llm.py. Pick ONE and set its credential below.
#   tests      -> claude:opus  (or sonnet)  : Claude OAuth via the claude CLI, no key
#   challenge  -> gemini/gemini-3.5-flash    : fast; or gemini/gemini-3.5-pro
#   default    -> gpt-5.5 (bare OpenAI-family names route to Codex CLI)
#   OpenAI API -> openai/gpt-5.5 (requires OPENAI_API_KEY)
MODEL_ID=gpt-5.5

# Provider credential for the chosen MODEL_ID (set the one you need):
OPENAI_API_KEY=
GEMINI_API_KEY=
# ANTHROPIC_API_KEY=        # only for anthropic/claude-* (metered API, not the OAuth CLI)

# --- Optional overrides ---------------------------------------------------
# BENCHMARK_ID=bitgn/ecom1-dev
# MAX_STEPS=40
# MAX_TOKENS=16384
# CLAUDE_CLI_TIMEOUT=300
# HINT=
# BITGN_HOST=https://api.bitgn.com
