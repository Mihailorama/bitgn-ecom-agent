SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind, pp.key, pp.value_text, pp.value_number
FROM products p
LEFT JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand) = 'husqvarna'
  AND (
    lower(p.series) LIKE '%aspire%'
    OR lower(p.model) LIKE '%k7q-v7z%'
    OR lower(p.name) LIKE '%k7q-v7z%'
    OR lower(p.name) LIKE '%trimmer and blower%'
  )
ORDER BY p.sku, pp.key;
