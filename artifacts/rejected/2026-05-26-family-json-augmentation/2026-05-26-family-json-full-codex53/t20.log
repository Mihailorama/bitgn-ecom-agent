SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       pk.name AS kind, pp.key, pp.value_text
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand = 'Legrand'
  AND (
    p.name LIKE '%Extension Cable%'
    OR pk.name LIKE '%Extension Cable%'
    OR p.series LIKE '%Compact LG 1VZ-UDC%'
    OR p.model LIKE '%Compact LG 1VZ-UDC%'
    OR p.name LIKE '%Compact LG 1VZ-UDC%'
  )
ORDER BY p.sku, pp.key;
