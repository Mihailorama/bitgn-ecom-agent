SELECT p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind, pp.key, pp.value_text
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand) = 'fiskars'
  AND lower(pk.name) = 'chainsaw'
  AND (
    lower(p.series) LIKE '%battery x 1cd-a3x%'
    OR lower(p.model) LIKE '%battery x 1cd-a3x%'
    OR lower(p.name) LIKE '%battery x 1cd-a3x%'
  )
  AND lower(pp.key) IN ('power_source','power source')
  AND lower(pp.value_text) = 'battery'
ORDER BY p.sku, pp.key;
