[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.name
FROM products p
JOIN product_properties pp1 ON pp1.sku = p.sku AND pp1.key = 'storage_type'
JOIN product_properties pp2 ON pp2.sku = p.sku AND pp2.key = 'color_family'
WHERE p.brand = 'Stanley'
  AND p.series = 'Professional'
  AND p.model = 'FM 1LT-4QA'
  AND LOWER(pp1.value_text) = 'storage bin'
  AND LOWER(pp2.value_text) = 'gray'
ORDER BY p.sku;
