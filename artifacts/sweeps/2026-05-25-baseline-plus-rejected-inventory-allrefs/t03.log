SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       pk.name AS kind, f.name AS family_name,
       pp.key, COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) AS prop_value
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
JOIN families f ON f.id = p.family_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand = 'Bosch'
  AND (
    p.series LIKE '%LS3-D02%'
    OR p.model LIKE '%LS3-D02%'
    OR p.name LIKE '%LS3-D02%'
    OR f.series LIKE '%LS3-D02%'
    OR f.model LIKE '%LS3-D02%'
    OR f.name LIKE '%LS3-D02%'
  )
ORDER BY p.sku, pp.key;
