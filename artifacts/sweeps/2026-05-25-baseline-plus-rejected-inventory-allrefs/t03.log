  [[32msafe[0m] tool='exec' path='/bin/sql' args=[] stdin="SELECT p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind,\n       MAX(CASE WHEN pp.key='machine_type' THEN pp.value_text END) AS machine_type,\n       MAX(CASE WHEN pp.key='voltage_v' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS voltage_v,\n       MAX(CASE WHEN pp.key='power_w' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS power_w,\n       MAX(CASE WHEN pp.key='working_width_mm' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS working_width_mm\nFROM products p\nJOIN product_kinds pk ON pk.id = p.kind_id\nLEFT JOIN product_properties pp ON pp.sku = p.sku\nWHERE p.brand = 'Bosch'\n  AND p.series = 'Bosch Universal BBS LS3-D02'\n  AND (p.name LIKE '%Workshop Drill Grinder and Sander%' OR p.model LIKE '%Workshop Drill Grinder and Sander%')\nGROUP BY p.sku, p.path, p.brand, p.series, p.model, pk.name\nORDER BY p.sku;"
[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind,
       MAX(CASE WHEN pp.key='machine_type' THEN pp.value_text END) AS machine_type,
       MAX(CASE WHEN pp.key='voltage_v' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS voltage_v,
       MAX(CASE WHEN pp.key='power_w' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS power_w,
       MAX(CASE WHEN pp.key='working_width_mm' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS working_width_mm
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand = 'Bosch'
  AND p.series = 'Bosch Universal BBS LS3-D02'
  AND (p.name LIKE '%Workshop Drill Grinder and Sander%' OR p.model LIKE '%Workshop Drill Grinder and Sander%')
GROUP BY p.sku, p.path, p.brand, p.series, p.model, pk.name
ORDER BY p.sku;
