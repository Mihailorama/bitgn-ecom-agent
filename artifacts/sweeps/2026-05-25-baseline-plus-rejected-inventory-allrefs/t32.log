SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
WHERE p.brand = 'Osram'
  AND (p.model = '3QE-SVE' OR p.series = 'Classic Night' OR p.name LIKE '%Automotive Charger and Bulb%')
ORDER BY p.series, p.model, p.name, p.sku;

SELECT p.sku, p.path, pp.key, pp.value_text, pp.value_number
FROM products p
JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand = 'Osram'
  AND (p.model = '3QE-SVE' OR p.series = 'Classic Night' OR p.name LIKE '%Automotive Charger and Bulb%')
ORDER BY p.sku, pp.key;
