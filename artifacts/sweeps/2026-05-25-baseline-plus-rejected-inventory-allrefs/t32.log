SELECT p.sku,
       p.path,
       p.brand,
       p.series,
       p.model,
       p.name,
       pk.name AS kind,
       MAX(CASE WHEN pp.key='product_type' THEN pp.value_text END) AS product_type,
       MAX(CASE WHEN pp.key='voltage_v' THEN COALESCE(pp.value_number, CAST(pp.value_text AS REAL)) END) AS voltage_v,
       MAX(CASE WHEN pp.key='current_a' THEN COALESCE(pp.value_number, CAST(pp.value_text AS REAL)) END) AS current_a,
       MAX(CASE WHEN pp.key IN ('wifi_enabled','wifi','wireless','connectivity') THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS wifi_signal
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand='Osram'
  AND p.series='Classic Night'
  AND p.model='3QE-SVE'
  AND p.name='Automotive Charger and Bulb'
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name
ORDER BY p.sku;
