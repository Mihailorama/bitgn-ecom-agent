WITH vienna_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Vienna'
)
SELECT vs.path AS store_path,
       COALESCE(i.available_today, 0) AS available_today
FROM vienna_stores vs
LEFT JOIN inventory i
  ON i.store_id = vs.id
 AND i.sku = 'CLN-GEF2EYP9'
ORDER BY vs.path;

SELECT COALESCE(SUM(COALESCE(i.available_today,0)),0) AS total_available_today
FROM stores s
LEFT JOIN inventory i
  ON i.store_id = s.id
 AND i.sku = 'CLN-GEF2EYP9'
WHERE s.city = 'Vienna';
