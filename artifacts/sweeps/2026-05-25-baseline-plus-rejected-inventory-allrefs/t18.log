WITH candidates AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, k.name AS kind_name
  FROM products p
  JOIN product_kinds k ON k.id = p.kind_id
  WHERE p.brand = 'Bahco'
    AND k.name = 'Pliers and Wrenches'
    AND (
      p.series LIKE '%Comfort Grip%'
      OR p.model LIKE '%1ZR-PGS%'
      OR p.name LIKE '%Comfort Grip%'
      OR p.name LIKE '%1ZR-PGS%'
    )
)
SELECT c.sku, c.path, c.brand, c.series, c.model, c.name, pp.key, pp.value_text, pp.value_number
FROM candidates c
LEFT JOIN product_properties pp ON pp.sku = c.sku
ORDER BY c.sku, pp.key;
