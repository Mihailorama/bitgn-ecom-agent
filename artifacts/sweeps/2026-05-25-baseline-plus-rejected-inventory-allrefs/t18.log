WITH vienna_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Vienna'
), per_store AS (
  SELECT
    vs.id AS store_id,
    vs.path AS store_path,
    COALESCE(i.available_today, 0) AS available_today
  FROM vienna_stores vs
  LEFT JOIN inventory i
    ON i.store_id = vs.id
   AND i.sku = 'HND-3ZVNDDW0'
)
SELECT 'STORE' AS row_type, store_id, store_path, available_today, NULL AS total_available_today
FROM per_store
UNION ALL
SELECT 'TOTAL' AS row_type, NULL, NULL, NULL, SUM(available_today)
FROM per_store
ORDER BY row_type, store_id;
