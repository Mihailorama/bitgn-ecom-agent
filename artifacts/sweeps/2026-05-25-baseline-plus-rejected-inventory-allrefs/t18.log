[32mOUT[0m: /bin/sql <<'SQL'
WITH target_products AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_kinds k ON k.id = p.kind_id
  JOIN families f ON f.id = p.family_id
  JOIN product_properties pp_tool ON pp_tool.sku = p.sku
  JOIN product_properties pp_len ON pp_len.sku = p.sku
  WHERE p.brand = 'Bahco'
    AND p.series = 'Comfort Grip BE'
    AND p.model = '1ZR-PGS'
    AND k.name = 'Pliers and Wrenches'
    AND pp_tool.key IN ('tool_type','tool type')
    AND lower(pp_tool.value_text) = 'side cutter'
    AND (
      (pp_len.key IN ('length_mm','length') AND (pp_len.value_number = 300 OR pp_len.value_text = '300' OR pp_len.value_text = '300 mm'))
    )
),
vienna_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Vienna'
)
SELECT
  tp.sku,
  tp.path AS product_path,
  vs.id AS store_id,
  vs.path AS store_path,
  COALESCE(i.available_today, 0) AS available_today
FROM vienna_stores vs
CROSS JOIN target_products tp
LEFT JOIN inventory i ON i.store_id = vs.id AND i.sku = tp.sku
ORDER BY tp.sku, vs.id;
SQL
sku,product_path,store_id,store_path,available_today
