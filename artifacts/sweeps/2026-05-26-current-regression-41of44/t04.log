SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       MAX(CASE WHEN pp.key='cleaner_type' THEN pp.value_text END) AS cleaner_type,
       MAX(CASE WHEN pp.key='vehicle_type' THEN pp.value_text END) AS vehicle_type,
       MAX(CASE WHEN pp.key='volume_ml' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS volume_ml
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand = 'Sonax'
  AND (p.series = 'Premium Gloss' OR p.model = 'Premium Gloss' OR p.name LIKE '%Premium Gloss%')
  AND (p.series = '1OV-9WZ' OR p.model = '1OV-9WZ' OR p.name LIKE '%1OV-9WZ%')
  AND p.name LIKE '%Automotive Cleaner%'
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
HAVING cleaner_type = 'interior cleaner'
   AND vehicle_type = 'van'
   AND CAST(volume_ml AS REAL) = 5000;
