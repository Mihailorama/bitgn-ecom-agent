[32mOUT[0m: /bin/sql <<'SQL'
WITH base AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, k.name AS kind_name
  FROM products p
  LEFT JOIN product_kinds k ON k.id = p.kind_id
  WHERE p.brand = 'Dresselhaus'
    AND (
      p.series LIKE '%Outdoor Pro%'
      OR p.model LIKE '%1VG-P5G%'
      OR p.name LIKE '%Wood and Drywall Screw%'
      OR k.name LIKE '%Wood and Drywall Screw%'
    )
)
SELECT b.sku, b.path, b.brand, b.series, b.model, b.name, b.kind_name,
       pp.key, pp.value_text, pp.value_number
FROM base b
LEFT JOIN product_properties pp ON pp.sku = b.sku
ORDER BY b.sku, pp.key;
