Next step_4... Run a strict SQL query for Sikkens + Quick Dry + SIK 1H0-QNN in metal_concrete_paint with required properties. (16069 ms)
  [[32msafe[0m] tool='exec' path='/bin/sql' args=[] stdin="SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,\n       MAX(CASE WHEN pp.key='product_type' THEN LOWER(pp.value_text) END) AS product_type,\n       MAX(CASE WHEN pp.key='color_family' THEN LOWER(pp.value_text) END) AS color_family\nFROM products p\nJOIN product_properties pp ON pp.sku = p.sku\nWHERE p.path LIKE '/proc/catalog/paints_finishes/metal_concrete_paint/%'\n  AND LOWER(p.brand) = 'sikkens'\n  AND LOWER(p.series) = 'quick dry'\n  AND p.model = 'SIK 1H0-QNN'\nGROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name\nHAVING product_type = 'concrete sealer' AND color_family = 'brown';"
[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       MAX(CASE WHEN pp.key='product_type' THEN LOWER(pp.value_text) END) AS product_type,
       MAX(CASE WHEN pp.key='color_family' THEN LOWER(pp.value_text) END) AS color_family
FROM products p
JOIN product_properties pp ON pp.sku = p.sku
WHERE p.path LIKE '/proc/catalog/paints_finishes/metal_concrete_paint/%'
  AND LOWER(p.brand) = 'sikkens'
  AND LOWER(p.series) = 'quick dry'
  AND p.model = 'SIK 1H0-QNN'
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
HAVING product_type = 'concrete sealer' AND color_family = 'brown';
SQL
sku,path,brand,series,model,name,product_type,color_family
