  [[32msafe[0m] tool='exec' path='/bin/sql' args=[] stdin="SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,\n       MAX(CASE WHEN pp.key='product_type' THEN pp.value_text END) AS product_type,\n       MAX(CASE WHEN pp.key='color_family' THEN pp.value_text END) AS color_family\nFROM products p\nLEFT JOIN product_properties pp ON pp.sku = p.sku\nWHERE p.brand LIKE '%Sikkens%'\n   OR p.series LIKE '%Quick Dry%'\n   OR p.model LIKE '%SIK 1H0-QNN%'\n   OR p.name LIKE '%Sikkens Quick Dry SIK 1H0-QNN%'\nGROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name\nORDER BY p.brand, p.series, p.model, p.sku;"
[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       MAX(CASE WHEN pp.key='product_type' THEN pp.value_text END) AS product_type,
       MAX(CASE WHEN pp.key='color_family' THEN pp.value_text END) AS color_family
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand LIKE '%Sikkens%'
   OR p.series LIKE '%Quick Dry%'
   OR p.model LIKE '%SIK 1H0-QNN%'
   OR p.name LIKE '%Sikkens Quick Dry SIK 1H0-QNN%'
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
ORDER BY p.brand, p.series, p.model, p.sku;
