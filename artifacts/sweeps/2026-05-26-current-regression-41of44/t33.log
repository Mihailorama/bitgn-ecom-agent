[32mOUT[0m: /bin/sql <<'SQL'
WITH target AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_kinds k ON k.id = p.kind_id
  LEFT JOIN product_properties pp_mt ON pp_mt.sku = p.sku AND pp_mt.key = 'machine_type'
  LEFT JOIN product_properties pp_v ON pp_v.sku = p.sku AND pp_v.key IN ('voltage_v','voltage')
  LEFT JOIN product_properties pp_pw ON pp_pw.sku = p.sku AND pp_pw.key IN ('power_w','power')
  WHERE p.brand = 'Metabo'
    AND p.series = 'Metabo Bench BS 1H0-06I'
    AND k.name = 'Workshop Drill Grinder and Sander'
    AND pp_mt.value_text = 'planer thicknesser'
    AND (
      pp_v.value_text IN ('230 V','230V')
      OR pp_v.value_number = 230
    )
    AND (
      pp_pw.value_text IN ('750 W','750W')
      OR pp_pw.value_number = 750
    )
)
SELECT t.sku, t.path AS product_path
FROM target t;
