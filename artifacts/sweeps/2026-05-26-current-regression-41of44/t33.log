[32mOUT[0m: /bin/sql <<'SQL'
WITH graz_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Graz' AND is_open = 1
), per_store AS (
  SELECT gs.path AS store_path,
         COALESCE(i.available_today, 0) AS available_today
  FROM graz_stores gs
  LEFT JOIN inventory i
    ON i.store_id = gs.id
   AND i.sku = 'MAC-37VRH7VP'
)
SELECT store_path,
       available_today,
       SUM(available_today) OVER () AS total_available_today
FROM per_store
ORDER BY store_path;
