[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       pp.key, pp.value_text, pp.value_number
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand) = 'sonax'
  AND (
    lower(p.name) LIKE '%cleaner%'
    OR lower(p.series) LIKE '%xtreme%'
    OR lower(p.model) LIKE '%3m7%'
    OR lower(pp.value_text) LIKE '%screen wash%'
    OR pp.key IN ('cleaner_type','volume_ml')
  )
ORDER BY p.series, p.model, p.sku, pp.key;
