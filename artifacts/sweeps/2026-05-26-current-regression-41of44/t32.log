WITH candidates AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name
  FROM products p
  WHERE lower(p.brand) = 'sonax'
    AND lower(p.series) = 'professional xtreme'
    AND lower(p.model) = '3m7-ccf'
    AND lower(p.name) LIKE '%automotive cleaner%'
)
SELECT c.sku, c.path, c.brand, c.series, c.model, c.name,
       pp.key, pp.value_text, pp.value_number
FROM candidates c
LEFT JOIN product_properties pp ON pp.sku = c.sku
WHERE pp.key IN ('cleaner_type','volume_ml','gps_tracking','built_in_gps_tracking')
   OR pp.key LIKE '%gps%'
   OR pp.key LIKE '%tracking%'
ORDER BY c.sku, pp.key;
