WITH target_product AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_properties pp ON pp.sku = p.sku
  WHERE p.brand = 'Heco'
    AND p.series = 'Heco Zinc Plated TopFix'
    AND p.model = 'GTU-YPJ'
    AND p.name = 'Wood and Drywall Screw'
    AND pp.key = 'screw_type'
    AND pp.value_text = 'drywall screw'
), vienna_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Vienna'
)
SELECT
  vs.path AS store_path,
  tp.path AS product_path,
  COALESCE(i.available_today, 0) AS available_today
FROM vienna_stores vs
CROSS JOIN target_product tp
LEFT JOIN inventory i
  ON i.store_id = vs.id
 AND i.sku = tp.sku
ORDER BY vs.path;
