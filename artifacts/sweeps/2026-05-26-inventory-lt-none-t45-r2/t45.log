WITH x AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind,
         MAX(CASE WHEN pp.key='product_type' THEN pp.value_text END) AS product_type,
         MAX(CASE WHEN pp.key='storage_type' THEN pp.value_text END) AS storage_type,
         MAX(CASE WHEN pp.key='color_family' THEN pp.value_text END) AS color_family,
         MAX(CASE WHEN pp.key='volume_l' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS volume_l,
         MAX(CASE WHEN pp.key='volume_ml' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS volume_ml,
         MAX(CASE WHEN pp.key='viscosity' THEN pp.value_text END) AS viscosity,
         MAX(CASE WHEN pp.key='vehicle_type' THEN pp.value_text END) AS vehicle_type
  FROM products p
  JOIN product_kinds pk ON pk.id = p.kind_id
  LEFT JOIN product_properties pp ON pp.sku = p.sku
  WHERE (p.brand='Sikkens' AND p.series='Cetol Rubbol' AND p.model='1KE-GBP')
     OR (p.brand='Keter' AND p.series='Workshop' AND p.model='Connect 3K5-2SL')
     OR (p.brand='Shell' AND p.series='Helix Advance' AND p.model='2CC-Q5M')
  GROUP BY p.sku, p.path, p.brand, p.series, p.model, pk.name
)
SELECT *
FROM x
WHERE (brand='Sikkens' AND kind='Wood Stain and Deck Oil' AND product_type='deck oil')
   OR (brand='Keter' AND kind='Shelving and Cabinet' AND storage_type='shelving unit' AND lower(color_family)='yellow' AND volume_l IN ('80','80.0'))
   OR (brand='Shell' AND kind='Engine Oil' AND volume_ml IN ('5000','5000.0') AND viscosity='5W-40' AND vehicle_type='universal')
ORDER BY brand, sku;
