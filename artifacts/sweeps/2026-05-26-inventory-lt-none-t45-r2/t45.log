  [[32msafe[0m] tool='exec' path='/bin/sql' args=[] stdin="WITH p AS (\n  SELECT pr.sku, pr.path, pr.brand, pr.series, pr.model, pk.name AS kind,\n         MAX(CASE WHEN pp.key='product_type' THEN lower(pp.value_text) END) AS product_type,\n         MAX(CASE WHEN pp.key='volume_ml' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS volume_ml,\n         MAX(CASE WHEN pp.key='viscosity' THEN pp.value_text END) AS viscosity,\n         MAX(CASE WHEN pp.key='vehicle_type' THEN lower(pp.value_text) END) AS vehicle_type\n  FROM products pr\n  JOIN product_kinds pk ON pk.id = pr.kind_id\n  LEFT JOIN product_properties pp ON pp.sku = pr.sku\n  WHERE pr.brand IN ('Sikkens','Shell')\n  GROUP BY pr.sku, pr.path, pr.brand, pr.series, pr.model, pk.name\n)\nSELECT *\nFROM p\nWHERE (brand='Sikkens' AND kind='Wood Stain and Deck Oil' AND product_type='deck oil')\n   OR (brand='Shell' AND kind='Engine Oil' AND volume_ml IN ('5000','5000.0') AND viscosity='5W-40' AND vehicle_type='universal')\nORDER BY brand, series, model, sku;"
[32mOUT[0m: /bin/sql <<'SQL'
WITH p AS (
  SELECT pr.sku, pr.path, pr.brand, pr.series, pr.model, pk.name AS kind,
         MAX(CASE WHEN pp.key='product_type' THEN lower(pp.value_text) END) AS product_type,
         MAX(CASE WHEN pp.key='volume_ml' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS volume_ml,
         MAX(CASE WHEN pp.key='viscosity' THEN pp.value_text END) AS viscosity,
         MAX(CASE WHEN pp.key='vehicle_type' THEN lower(pp.value_text) END) AS vehicle_type
  FROM products pr
  JOIN product_kinds pk ON pk.id = pr.kind_id
  LEFT JOIN product_properties pp ON pp.sku = pr.sku
  WHERE pr.brand IN ('Sikkens','Shell')
  GROUP BY pr.sku, pr.path, pr.brand, pr.series, pr.model, pk.name
)
SELECT *
FROM p
WHERE (brand='Sikkens' AND kind='Wood Stain and Deck Oil' AND product_type='deck oil')
   OR (brand='Shell' AND kind='Engine Oil' AND volume_ml IN ('5000','5000.0') AND viscosity='5W-40' AND vehicle_type='universal')
ORDER BY brand, series, model, sku;
