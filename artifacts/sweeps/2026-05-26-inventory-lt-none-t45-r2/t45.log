WITH base AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind
  FROM products p
  JOIN product_kinds pk ON pk.id = p.kind_id
), props AS (
  SELECT sku,
         MAX(CASE WHEN key='product_type' THEN value_text END) AS product_type,
         MAX(CASE WHEN key='tool_type' THEN value_text END) AS tool_type,
         MAX(CASE WHEN key='length_mm' THEN COALESCE(CAST(value_number AS TEXT), value_text) END) AS length_mm,
         MAX(CASE WHEN key='storage_type' THEN value_text END) AS storage_type,
         MAX(CASE WHEN key='color_family' THEN value_text END) AS color_family,
         MAX(CASE WHEN key='volume_l' THEN COALESCE(CAST(value_number AS TEXT), value_text) END) AS volume_l,
         MAX(CASE WHEN key='volume_ml' THEN COALESCE(CAST(value_number AS TEXT), value_text) END) AS volume_ml,
         MAX(CASE WHEN key='viscosity' THEN value_text END) AS viscosity,
         MAX(CASE WHEN key='vehicle_type' THEN value_text END) AS vehicle_type,
         MAX(CASE WHEN key='size' THEN value_text END) AS size
  FROM product_properties
  GROUP BY sku
)
SELECT b.sku, b.path, b.brand, b.series, b.model, b.kind,
       p.product_type, p.tool_type, p.length_mm, p.storage_type, p.color_family,
       p.volume_l, p.volume_ml, p.viscosity, p.vehicle_type, p.size
FROM base b
JOIN props p ON p.sku = b.sku
WHERE (
    b.brand='Sikkens' AND b.series='Cetol Rubbol' AND b.model='1KE-GBP' AND b.kind='Wood Stain and Deck Oil' AND p.product_type='deck oil'
) OR (
    b.brand='Knipex' AND b.series='Professional' AND b.model='KP 2H0-CV1' AND b.kind='Pliers and Wrenches' AND p.tool_type='adjustable wrench' AND p.length_mm IN ('250','250.0')
) OR (
    b.brand='Keter' AND b.series='Workshop Connect' AND b.model='3K5-2SL' AND b.kind='Shelving and Cabinet' AND p.storage_type='shelving unit' AND p.color_family='Yellow' AND p.volume_l IN ('80','80.0')
) OR (
    b.brand='Knipex' AND b.series='Professional' AND b.model='KP 2H0-CV1' AND b.kind='Pliers and Wrenches' AND p.tool_type='adjustable wrench' AND p.length_mm IN ('150','150.0')
) OR (
    b.brand='Shell' AND b.series='Helix Advance' AND b.model='2CC-Q5M' AND b.kind='Engine Oil' AND p.volume_ml IN ('5000','5000.0') AND p.viscosity='5W-40' AND p.vehicle_type='universal'
) OR (
    b.brand='Helly Hansen' AND b.series='Chelsea Evolution Kensington' AND b.model='V83-TOZ' AND b.kind='Work Jacket' AND p.color_family='Blue' AND p.size='M'
)
ORDER BY b.brand, b.series, b.model, b.sku;
