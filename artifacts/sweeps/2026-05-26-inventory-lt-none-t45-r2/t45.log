  [[32msafe[0m] tool='exec' path='/bin/sql' args=[] stdin="SELECT p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind, pp.key, pp.value_text, pp.value_number\nFROM products p\nJOIN product_kinds pk ON pk.id = p.kind_id\nLEFT JOIN product_properties pp ON pp.sku = p.sku\nWHERE p.brand IN ('Sikkens','Keter','Shell','Helly Hansen')\nORDER BY p.brand, pk.name, p.series, p.model, p.sku, pp.key;"
[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind, pp.key, pp.value_text, pp.value_number
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand IN ('Sikkens','Keter','Shell','Helly Hansen')
ORDER BY p.brand, pk.name, p.series, p.model, p.sku, pp.key;
