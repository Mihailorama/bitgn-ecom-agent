SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind,
       pp1.value_text AS power_source, pp2.value_number AS cutting_width_cm
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
JOIN product_properties pp1 ON pp1.sku = p.sku AND pp1.key = 'power_source'
JOIN product_properties pp2 ON pp2.sku = p.sku AND pp2.key = 'cutting_width_cm'
WHERE p.brand = 'Wolf-Garten'
  AND p.series = 'Silent WG 2IA-DMB'
  AND pk.name = 'Lawn Mower'
  AND pp1.value_text = 'manual'
  AND pp2.value_number = 38;
