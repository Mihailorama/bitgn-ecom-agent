SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       MAX(CASE WHEN pp.key='wattage_w' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS wattage_w,
       MAX(CASE WHEN pp.key='luminous_flux_lm' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS luminous_flux_lm
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE (p.brand = 'Osram' OR p.brand LIKE '%Osram%')
  AND (p.series = 'Eco Classic' OR p.series LIKE '%Eco Classic%')
  AND (p.model = '3PW-R88' OR p.model LIKE '%3PW-R88%')
  AND (p.name LIKE '%LED Bulb%')
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
ORDER BY p.sku;
