SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       pp.key, COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) AS value
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand LIKE '%Osram%'
   OR p.name LIKE '%Osram%'
   OR p.name LIKE '%LED Bulb%'
ORDER BY p.brand, p.series, p.model, p.sku, pp.key;
