SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, c.name AS category_name, k.name AS kind_name, pp.key, pp.value_text
FROM products p
JOIN categories c ON c.id = p.category_id
JOIN product_kinds k ON k.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand) = 'soudal'
  AND (lower(p.series) LIKE '%silirub%' OR lower(p.model) LIKE '%silirub%' OR lower(p.name) LIKE '%silirub%')
  AND (lower(c.name) = 'adhesive and glue' OR lower(k.name) = 'adhesive and glue')
ORDER BY p.sku, pp.key;
