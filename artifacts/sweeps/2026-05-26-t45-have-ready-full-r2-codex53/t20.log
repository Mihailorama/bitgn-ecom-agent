[32mOUT[0m: /bin/sql <<'SQL'
WITH target_product AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_properties pp_color
    ON pp_color.sku = p.sku
   AND pp_color.key = 'color_family'
   AND pp_color.value_text = 'Black'
  JOIN product_properties pp_size
    ON pp_size.sku = p.sku
   AND pp_size.key = 'size'
   AND pp_size.value_text = 'L'
  WHERE p.brand = 'Carhartt'
    AND p.series = 'Carhartt Force Duck 2AZ-W0B'
    AND p.kind_id IN (
      SELECT id FROM product_kinds WHERE name = 'Work Trousers'
    )
)
SELECT s.path AS store_path,
       tp.path AS product_path,
       COALESCE(i.available_today, 0) AS available_today
FROM stores s
CROSS JOIN target_product tp
LEFT JOIN inventory i
  ON i.store_id = s.id
 AND i.sku = tp.sku
WHERE s.city = 'Vienna'
ORDER BY s.path;
