[32mOUT[0m: /bin/sql <<'SQL'
WITH city_candidates AS (
  SELECT DISTINCT city
  FROM stores
  WHERE LOWER(city) LIKE '%vien%'
     OR LOWER(city) LIKE '%wien%'
),
vienna_stores AS (
  SELECT s.id, s.path, s.city
  FROM stores s
  WHERE s.city IN (SELECT city FROM city_candidates)
),
target_product AS (
  SELECT sku, path
  FROM products
  WHERE sku = 'WRK-47YZMMZ7'
)
SELECT vs.path AS store_path,
       vs.city AS store_city,
       tp.path AS product_path,
       COALESCE(i.available_today, 0) AS available_today,
       (SELECT SUM(COALESCE(i2.available_today,0))
          FROM vienna_stores vs2
          LEFT JOIN inventory i2
            ON i2.store_id = vs2.id
           AND i2.sku = tp.sku) AS total_available_today
FROM vienna_stores vs
CROSS JOIN target_product tp
LEFT JOIN inventory i
  ON i.store_id = vs.id
 AND i.sku = tp.sku
ORDER BY vs.path;
