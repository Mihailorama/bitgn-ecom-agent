WITH actor_store AS (
  SELECT e.store_id
  FROM employees e
  WHERE e.id = 'emp_021'
),
req(row_id, brand, series, model, name, qty, p1k, p1t, p1n, p2k, p2t, p2n) AS (
  VALUES
    ('TCM8r','Mellerud','Bio','MEL 233-MOB','Cleaning Liquid',10,'cleaner_type','interior cleaner',NULL,NULL,NULL,NULL),
    ('W4cUt','Sonax','Workshop','XTREME 218-FC5','Automotive Cleaner',4,'cleaner_type','polish',NULL,NULL,NULL,NULL),
    ('aE5K6','Mascot','Advanced','ACC 35W-IIS','Work Jacket',2,'color_family','Blue',NULL,'color_family','purple',NULL),
    ('6wHVg','Mobil','All Season','Super 1ZE-TCR','Engine Oil',3,'volume_ml',NULL,5000,'viscosity','15W-40',NULL),
    ('h1wZK','Sonax','Premium','Gloss 304-ZK0','Wiper Blade',3,'length_mm',NULL,500,NULL,NULL,NULL)
),
base AS (
  SELECT r.*, p.sku, p.path
  FROM req r
  LEFT JOIN products p
    ON p.brand = r.brand
   AND p.series = r.series
   AND p.model = r.model
   AND p.name = r.name
),
prop_ok AS (
  SELECT b.row_id, b.sku,
         CASE
           WHEN b.sku IS NULL THEN 0
           WHEN b.p1k IS NULL THEN 1
           WHEN b.p1t IS NOT NULL THEN EXISTS (
             SELECT 1 FROM product_properties pp
             WHERE pp.sku=b.sku AND pp.key=b.p1k AND lower(pp.value_text)=lower(b.p1t)
           )
           ELSE EXISTS (
             SELECT 1 FROM product_properties pp
             WHERE pp.sku=b.sku AND pp.key=b.p1k AND pp.value_number=b.p1n
           )
         END AS p1_ok,
         CASE
           WHEN b.p2k IS NULL THEN 1
           WHEN b.p2t IS NOT NULL THEN EXISTS (
             SELECT 1 FROM product_properties pp
             WHERE pp.sku=b.sku AND pp.key=b.p2k AND lower(pp.value_text)=lower(b.p2t)
           )
           ELSE EXISTS (
             SELECT 1 FROM product_properties pp
             WHERE pp.sku=b.sku AND pp.key=b.p2k AND pp.value_number=b.p2n
           )
         END AS p2_ok
  FROM base b
),
qualified AS (
  SELECT b.row_id, b.qty, b.sku, b.path
  FROM base b
  JOIN prop_ok po ON po.row_id=b.row_id AND po.sku=b.sku
  WHERE po.p1_ok=1 AND po.p2_ok=1
),
unique_match AS (
  SELECT q.row_id,
         CASE WHEN COUNT(*)=1 THEN MAX(q.sku) END AS sku
  FROM qualified q
  GROUP BY q.row_id
)
SELECT r.row_id,
       um.sku,
       CASE WHEN um.sku IS NOT NULL THEN COALESCE(i.available_today,0) END AS in_stock,
       CASE WHEN um.sku IS NOT NULL AND COALESCE(i.available_today,0) >= r.qty THEN 1 ELSE 0 END AS match
FROM req r
LEFT JOIN unique_match um ON um.row_id=r.row_id
LEFT JOIN actor_store s ON 1=1
LEFT JOIN inventory i ON i.store_id=s.store_id AND i.sku=um.sku
ORDER BY CASE r.row_id
  WHEN 'TCM8r' THEN 1
  WHEN 'W4cUt' THEN 2
  WHEN 'aE5K6' THEN 3
  WHEN '6wHVg' THEN 4
  WHEN 'h1wZK' THEN 5
  ELSE 999 END;
