SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       pp.key, pp.value_text, pp.value_number
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand) = 'wurth'
  AND (
    lower(p.series) LIKE '%pro pack zebra lnp-sm1%'
    OR lower(p.model) LIKE '%pro pack zebra lnp-sm1%'
    OR lower(p.name) LIKE '%pro pack zebra lnp-sm1%'
  )
ORDER BY p.sku, pp.key;
