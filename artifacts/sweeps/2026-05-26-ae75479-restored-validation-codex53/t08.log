[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       MAX(CASE WHEN pp.key='device_type' THEN pp.value_text END) AS device_type,
       MAX(CASE WHEN pp.key='color_family' THEN pp.value_text END) AS color_family,
       MAX(CASE WHEN pp.key='ip_rating' THEN pp.value_text END) AS ip_rating,
       MAX(CASE WHEN pp.key='current_a' THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS current_a
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE (p.brand='Wago' OR p.name LIKE '%Wago%')
  AND (p.series LIKE '%221%' OR p.model LIKE '%221%' OR p.name LIKE '%221%')
  AND (p.series LIKE '%222%' OR p.model LIKE '%222%' OR p.name LIKE '%222%')
  AND (p.series LIKE '%DLX-KMG%' OR p.model LIKE '%DLX-KMG%' OR p.name LIKE '%DLX-KMG%')
  AND (p.kind_id IN (SELECT id FROM product_kinds WHERE name='Wiring Device') OR p.name LIKE '%Wiring Device%')
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
ORDER BY p.sku;
