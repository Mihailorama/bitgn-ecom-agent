SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, k.name AS kind_name, pp.key, COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) AS value
FROM products p
JOIN product_kinds k ON k.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand = 'Fischer'
  AND (k.name LIKE '%Screw%' OR p.name LIKE '%Screw%' OR p.series LIKE '%SX%' OR p.model LIKE '%SX%')
ORDER BY p.series, p.model, p.sku, pp.key;
