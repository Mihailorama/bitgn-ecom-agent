  [[32msafe[0m] tool='exec' path='/bin/sql' args=[] stdin="WITH target_product AS (\n  SELECT p.sku, p.path\n  FROM products p\n  JOIN product_kinds k ON k.id = p.kind_id\n  JOIN product_properties ps ON ps.sku = p.sku AND ps.key = 'screw_type'\n  JOIN product_properties pd ON pd.sku = p.sku AND pd.key = 'diameter_mm'\n  JOIN product_properties pl ON pl.sku = p.sku AND pl.key = 'length_mm'\n  WHERE p.brand = 'Fischer'\n    AND p.series = 'Universal'\n    AND p.model = 'SX 1PF-JY8'\n    AND k.name = 'Wood and Drywall Screw'\n    AND ps.value_text = 'wood screw'\n    AND pd.value_number = 4\n    AND pl.value_number = 20\n), vienna_stores AS (\n  SELECT id, path\n  FROM stores\n  WHERE city = 'Vienna'\n)\nSELECT 'product' AS row_type, tp.sku, tp.path AS ref_path, NULL AS store_id, NULL AS available_today\nFROM target_product tp\nUNION ALL\nSELECT 'store' AS row_type, NULL AS sku, vs.path AS ref_path, vs.id AS store_id,\n       COALESCE(i.available_today, 0) AS available_today\nFROM vienna_stores vs\nCROSS JOIN target_product tp\nLEFT JOIN inventory i ON i.store_id = vs.id AND i.sku = tp.sku\nUNION ALL\nSELECT 'total' AS row_type, NULL AS sku, NULL AS ref_path, NULL AS store_id,\n       COALESCE(SUM(COALESCE(i.available_today,0)),0) AS available_today\nFROM vienna_stores vs\nCROSS JOIN target_product tp\nLEFT JOIN inventory i ON i.store_id = vs.id AND i.sku = tp.sku;"
[32mOUT[0m: /bin/sql <<'SQL'
WITH target_product AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_kinds k ON k.id = p.kind_id
  JOIN product_properties ps ON ps.sku = p.sku AND ps.key = 'screw_type'
  JOIN product_properties pd ON pd.sku = p.sku AND pd.key = 'diameter_mm'
  JOIN product_properties pl ON pl.sku = p.sku AND pl.key = 'length_mm'
  WHERE p.brand = 'Fischer'
    AND p.series = 'Universal'
    AND p.model = 'SX 1PF-JY8'
    AND k.name = 'Wood and Drywall Screw'
    AND ps.value_text = 'wood screw'
    AND pd.value_number = 4
    AND pl.value_number = 20
), vienna_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Vienna'
)
SELECT 'product' AS row_type, tp.sku, tp.path AS ref_path, NULL AS store_id, NULL AS available_today
FROM target_product tp
UNION ALL
SELECT 'store' AS row_type, NULL AS sku, vs.path AS ref_path, vs.id AS store_id,
       COALESCE(i.available_today, 0) AS available_today
FROM vienna_stores vs
CROSS JOIN target_product tp
LEFT JOIN inventory i ON i.store_id = vs.id AND i.sku = tp.sku
UNION ALL
SELECT 'total' AS row_type, NULL AS sku, NULL AS ref_path, NULL AS store_id,
       COALESCE(SUM(COALESCE(i.available_today,0)),0) AS available_today
FROM vienna_stores vs
CROSS JOIN target_product tp
LEFT JOIN inventory i ON i.store_id = vs.id AND i.sku = tp.sku;
