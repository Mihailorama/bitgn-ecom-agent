  [[32msafe[0m] tool='exec' path='/bin/sql' args=[] stdin="SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,\n       MAX(CASE WHEN pp.key='screw_type' THEN pp.value_text END) AS screw_type,\n       MAX(CASE WHEN pp.key='diameter_mm' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS diameter_mm,\n       MAX(CASE WHEN pp.key='length_mm' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS length_mm\nFROM products p\nJOIN product_properties pp ON pp.sku = p.sku\nJOIN product_kinds k ON k.id = p.kind_id\nWHERE p.brand = 'Fischer'\n  AND p.series = 'Fischer Universal SX 1PF-JY8'\n  AND (k.name = 'Wood and Drywall Screw' OR p.name LIKE '%Wood and Drywall Screw%')\nGROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name\nHAVING MAX(CASE WHEN pp.key='screw_type' THEN pp.value_text END) = 'wood screw'\n   AND CAST(MAX(CASE WHEN pp.key='diameter_mm' THEN pp.value_number END) AS REAL) = 4\n   AND CAST(MAX(CASE WHEN pp.key='length_mm' THEN pp.value_number END) AS REAL) = 20;"
[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       MAX(CASE WHEN pp.key='screw_type' THEN pp.value_text END) AS screw_type,
       MAX(CASE WHEN pp.key='diameter_mm' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS diameter_mm,
       MAX(CASE WHEN pp.key='length_mm' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS length_mm
FROM products p
JOIN product_properties pp ON pp.sku = p.sku
JOIN product_kinds k ON k.id = p.kind_id
WHERE p.brand = 'Fischer'
  AND p.series = 'Fischer Universal SX 1PF-JY8'
  AND (k.name = 'Wood and Drywall Screw' OR p.name LIKE '%Wood and Drywall Screw%')
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
HAVING MAX(CASE WHEN pp.key='screw_type' THEN pp.value_text END) = 'wood screw'
   AND CAST(MAX(CASE WHEN pp.key='diameter_mm' THEN pp.value_number END) AS REAL) = 4
   AND CAST(MAX(CASE WHEN pp.key='length_mm' THEN pp.value_number END) AS REAL) = 20;
