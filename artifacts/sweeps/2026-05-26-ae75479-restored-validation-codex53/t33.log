[32mOUT[0m: /bin/sql <<'SQL'
WITH target_products AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_properties pp_color
    ON pp_color.sku = p.sku
   AND pp_color.key = 'color_family'
   AND pp_color.value_text = 'White'
  JOIN product_properties pp_length
    ON pp_length.sku = p.sku
   AND pp_length.key IN ('length_m','length')
   AND (
     pp_length.value_number = 5
     OR pp_length.value_text IN ('5','5 m','5m')
   )
  WHERE p.brand = 'Schneider Electric'
    AND p.series = 'Schneider Electric Heavy Duty Merten 214-ZHY Extension Cable'
    AND p.kind_id IN (SELECT id FROM product_kinds WHERE name = 'Extension Cable')
)
SELECT s.path AS store_path,
       tp.path AS product_path,
       SUM(i.available_today) AS available_today_sum
FROM stores s
JOIN inventory i ON i.store_id = s.id
JOIN target_products tp ON tp.sku = i.sku
WHERE s.city = 'Vienna'
GROUP BY s.path, tp.path
ORDER BY s.path;
