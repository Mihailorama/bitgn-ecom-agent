WITH candidates AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind_name
  FROM products p
  JOIN product_kinds pk ON pk.id = p.kind_id
  WHERE p.brand = 'Schneider Electric'
    AND (
      pk.name LIKE '%Extension Cable%'
      OR p.name LIKE '%Extension Cable%'
      OR p.series LIKE '%214-ZHY%'
      OR p.model LIKE '%214-ZHY%'
    )
)
SELECT c.sku,
       c.path,
       c.kind_name,
       c.series,
       c.model,
       c.name,
       pp.key,
       pp.value_text,
       pp.value_number
FROM candidates c
LEFT JOIN product_properties pp ON pp.sku = c.sku
ORDER BY c.series, c.model, c.sku, pp.key;
