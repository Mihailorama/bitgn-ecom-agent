SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind, pp.key, pp.value_text
FROM products p
LEFT JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand) = 'ajax'
  AND (
    lower(p.series) LIKE '%eco classic%'
    OR lower(p.model) LIKE '%25c-dxe%'
    OR lower(p.name) LIKE '%eco classic%'
    OR lower(p.name) LIKE '%25c-dxe%'
  )
  AND (
    lower(p.name) LIKE '%cleaning liquid%'
    OR lower(pk.name) LIKE '%cleaning liquid%'
  )
ORDER BY p.sku, pp.key;
