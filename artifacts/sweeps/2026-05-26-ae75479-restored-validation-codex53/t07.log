SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pp.key, pp.value_text, pp.value_number
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE (
  lower(p.brand) LIKE '%black%decker%'
  OR lower(p.brand) LIKE '%black+decker%'
)
AND (
  lower(p.series) LIKE '%home gtc%'
  OR lower(p.model) LIKE '%3pt-1y9%'
  OR lower(p.name) LIKE '%cordless drill driver%'
)
ORDER BY p.sku, pp.key;
