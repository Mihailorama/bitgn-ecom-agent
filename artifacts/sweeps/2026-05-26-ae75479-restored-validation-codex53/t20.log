[32mOUT[0m: /bin/sql <<'SQL'
WITH graz_stores AS (
  SELECT id, path
  FROM stores
  WHERE lower(city)=lower('Graz')
), candidates AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind_name
  FROM products p
  LEFT JOIN product_kinds pk ON pk.id = p.kind_id
  WHERE lower(p.brand) = lower('Bondex')
    AND (
      lower(p.series) LIKE '%eco%classic%'
      OR lower(p.model) LIKE '%28s-4ut%'
      OR lower(p.name)  LIKE '%eco%classic%'
      OR lower(p.name)  LIKE '%28s-4ut%'
    )
)
SELECT 'CANDIDATE' AS row_type,
       c.sku AS sku,
       c.path AS path,
       c.brand AS a,
       c.series AS b,
       c.model || ' | ' || c.kind_name || ' | ' || c.name AS c
FROM candidates c
UNION ALL
SELECT 'PROP' AS row_type,
       pp.sku AS sku,
       c.path AS path,
       pp.key AS a,
       pp.value_text AS b,
       CAST(pp.value_number AS TEXT) AS c
FROM candidates c
JOIN product_properties pp ON pp.sku = c.sku
WHERE lower(pp.key) LIKE '%type%'
   OR lower(pp.key) LIKE '%product%'
   OR lower(pp.value_text) LIKE '%deck oil%'
ORDER BY row_type, path, a, b;
