WITH graz_stores AS (
  SELECT id, path
  FROM stores
  WHERE lower(city)=lower('Graz')
)
SELECT SUM(COALESCE(i.available_today,0)) AS qty
FROM graz_stores gs
LEFT JOIN inventory i
  ON i.store_id = gs.id
 AND i.sku = 'PNT-2EZWHFOA';
