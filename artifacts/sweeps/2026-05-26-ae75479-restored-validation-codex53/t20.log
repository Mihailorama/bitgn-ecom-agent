WITH target_product AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_properties pp ON pp.sku = p.sku
  WHERE p.brand = 'Bondex'
    AND p.series = 'Eco Classic'
    AND p.model = '28S-4UT'
    AND (
      (pp.key = 'product_type' AND lower(pp.value_text) = 'deck oil')
      OR (pp.key = 'type' AND lower(pp.value_text) = 'deck oil')
    )
), graz_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Graz'
)
SELECT tp.sku,
       tp.path AS product_path,
       gs.path AS store_path,
       COALESCE(i.available_today, 0) AS store_available_today,
       SUM(COALESCE(i.available_today, 0)) OVER () AS total_available_today
FROM graz_stores gs
CROSS JOIN target_product tp
LEFT JOIN inventory i
  ON i.store_id = gs.id
 AND i.sku = tp.sku
ORDER BY gs.path;
