WITH actor_store AS (
  SELECT store_id FROM employees WHERE id='emp_036'
), req AS (
  SELECT 'L9UbC' AS row_id, 7 AS qty, 'Giacomini' AS brand, 'R Series' AS series, 'R 1PA-6JD' AS model, 'Valve and Connector' AS kind_name UNION ALL
  SELECT 'gfxN8',4,'Raaco','Modular CarryLite','1QB-902','Tool Box and Bag' UNION ALL
  SELECT '2qiVy',2,'Keter','Compact Stack','99Z-RIS','Storage Bin and Organizer' UNION ALL
  SELECT '5UwF3',2,'AlcaPlast','Universal Basic','1CT-04J','Valve and Connector' UNION ALL
  SELECT 'Vf42c',5,'Stanley','Classic','STA CEQ-WUX','Tool Box and Bag' UNION ALL
  SELECT 'UfKe2',6,'Black+Decker','Home GTC','3PT-1Y9','Cordless Drill Driver' UNION ALL
  SELECT 'W5KcM',1,'Wurth','Universal WU','30Y-BPU','Nut Bolt and Washer'
), base AS (
  SELECT r.row_id, r.qty, p.sku, p.path,
