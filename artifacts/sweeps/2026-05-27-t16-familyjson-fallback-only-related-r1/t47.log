  [[32msafe[0m] tool='exec' path='/bin/sql' args=[] stdin="WITH actor_store AS (\n  SELECT store_id FROM employees WHERE id='emp_036'\n), req AS (\n  SELECT 'L9UbC' AS row_id, 7 AS qty, 'Giacomini' AS brand, 'R Series' AS series, 'R 1PA-6JD' AS model, 'Valve and Connector' AS kind_name UNION ALL\n  SELECT 'gfxN8',4,'Raaco','Modular CarryLite','1QB-902','Tool Box and Bag' UNION ALL\n  SELECT '2qiVy',2,'Keter','Compact Stack','99Z-RIS','Storage Bin and Organizer' UNION ALL\n  SELECT '5UwF3',2,'AlcaPlast','Universal Basic','1CT-04J','Valve and Connector' UNION ALL\n  SELECT 'Vf42c',5,'Stanley','Classic','STA CEQ-WUX','Tool Box and Bag' UNION ALL\n  SELECT 'UfKe2',6,'Black+Decker','Home GTC','3PT-1Y9','Cordless Drill Driver' UNION ALL\n  SELECT 'W5KcM',1,'Wurth','Universal WU','30Y-BPU','Nut Bolt and Washer'\n), base AS (\n  SELECT r.row_id, r.qty, p.sku, p.path,\n         COALESCE(i.available_today,0) AS available_today\n  FROM req r\n  JOIN products p ON p.brand=r.brand AND p.series=r.series AND p.model=r.model\n  JOIN product_kinds k ON k.id=p.kind_id AND k.name=r.kind_name\n  LEFT JOIN actor_store s ON 1=1\n  LEFT JOIN inventory i ON i.store_id=s.store_id AND i.sku=p.sku\n), matched AS (\n  SELECT b.* FROM base b\n  WHERE (\n    b.row_id='L9UbC' AND\n    EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=b.sku AND pp.key='connector_type' AND pp.value_text='ball valve') AND\n    EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=b.sku AND pp.key='diameter_mm' AND pp.value_number=25)\n  ) OR (\n    b.row_id='gfxN8' AND\n    EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=b.sku AND pp.key='storage_type' AND pp.value_text='tool bag') AND\n    EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=b.sku AND pp.key='color_family' AND lower(pp.value_text)='black') AND\n    EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=b.sku AND pp.key='volume_l' AND pp.value_number=12)\n  ) OR (\n    b.row_id='2qiVy' AND\n    EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=b.sku AND pp.key='storage_type' AND pp.value_text='organizer') AND\n    EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=b.sku AND pp.key='color_family' AND lower(pp.value_text)='gray')\n  ) OR (\n    b.row_id='5UwF3' AND\n    EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=b.sku AND pp.key='connector_type' AND pp.value_text='ball valve') AND\n    EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=b.sku AND pp.key='diameter_mm' AND pp.value_number=25) AND\n    EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=b.sku AND pp.key='thread_type' AND pp.value_text='3/4 inch')\n  ) OR (\n    b.row_id='Vf42c' AND\n    EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=b.sku AND pp.key='storage_type' AND pp.value_text='tool box') AND\n    EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=b.sku AND pp.key='color_family' AND lower(pp.value_text)='orange')\n  ) OR (\n    b.row_id='UfKe2' AND\n    EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=b.sku AND pp.key='voltage_v' AND pp.value_number=12)\n  ) OR (\n    b.row_id='W5KcM' AND\n    EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=b.sku AND pp.key='fastener_type' AND pp.value_text='washer') AND\n    EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=b.sku AND pp.key='diameter_mm' AND pp.value_number=6) AND\n    EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=b.sku AND pp.key='length_mm' AND pp.value_number=12) AND\n    EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=b.sku AND pp.key='pack_count_pcs' AND pp.value_number=50) AND\n    EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=b.sku AND pp.key='fastener_type' AND pp.value_text='threaded rod')\n  )\n)\nSELECT row_id, qty, sku, path, available_today\nFROM matched\nORDER BY row_id, sku;"
