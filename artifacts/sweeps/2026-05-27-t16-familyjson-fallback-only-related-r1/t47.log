WITH actor_store AS (
  SELECT store_id FROM employees WHERE id='emp_036'
), req(row_id, qty, brand, series, model) AS (
  VALUES
    ('L9UbC',7,'Giacomini','R Series','R 1PA-6JD'),
    ('gfxN8',4,'Raaco','Modular CarryLite','1QB-902'),
    ('2qiVy',2,'Keter','Compact Stack','99Z-RIS'),
    ('5UwF3',2,'AlcaPlast','Universal Basic','1CT-04J'),
    ('Vf42c',5,'Stanley','Classic','STA CEQ-WUX'),
    ('UfKe2',6,'Black+Decker','Home GTC','3PT-1Y9'),
    ('W5KcM',1,'Wurth','Universal WU','30Y-BPU')
)
SELECT
  r.row_id,
  r.qty,
  p.sku,
  p.path,
  c.name AS category_name,
  k.name AS kind_name,
  p.brand,
  p.series,
  p.model,
  COALESCE(i.available_today,0) AS available_today,
  pp.key,
  pp.value_text,
  pp.value_number
FROM req r
JOIN products p
  ON p.brand=r.brand AND p.series=r.series AND p.model=r.model
JOIN categories c ON c.id=p.category_id
JOIN product_kinds k ON k.id=p.kind_id
LEFT JOIN product_properties pp ON pp.sku=p.sku
LEFT JOIN actor_store s ON 1=1
LEFT JOIN inventory i ON i.store_id=s.store_id AND i.sku=p.sku
ORDER BY r.row_id, p.sku, pp.key;
