WITH req(label, brand, series, model, kind_name) AS (
  VALUES
    ('r1','Wavin','Compact','Tigris 2HC-AJD','Pipe Fitting'),
    ('r2','Uponor','Press Fit','Aqua 35M-6XO','Pipe Fitting'),
    ('r3','Leifheit','Fresh','Profi NBC-KFA','Cloth Mop and Wipe'),
    ('r4','Makita','Precision','DDF 26V-AVZ','Cordless Saw and Sander'),
    ('r5','Spax','Outdoor','T-Star 1GS-NEI','Wood and Drywall Screw'),
    ('r6','Milwaukee','Professional','M18 5AB-LER','Corded Angle Grinder')
)
SELECT r.label, p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind_name,
       pp.key, COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) AS value
FROM req r
JOIN products p
  ON p.brand = r.brand AND p.series = r.series AND p.model = r.model
JOIN product_kinds pk
  ON pk.id = p.kind_id AND pk.name = r.kind_name
LEFT JOIN product_properties pp
  ON pp.sku = p.sku
WHERE (
    r.label='r1' AND p.sku IN (
      SELECT sku FROM product_properties WHERE key='fitting_type' AND value_text='compression coupler'
    )
  ) OR (
    r.label='r2' AND p.sku IN (
      SELECT sku FROM product_properties WHERE key='fitting_type' AND value_text='thread adapter'
      INTERSECT
      SELECT sku FROM product_properties WHERE key='diameter_mm' AND value_number=15
    )
  ) OR (
    r.label='r3' AND p.sku IN (
      SELECT sku FROM product_properties WHERE key='cleaning_type' AND value_text='sponge'
    )
  ) OR (
    r.label='r4' AND p.sku IN (
      SELECT sku FROM product_properties WHERE key='tool_type' AND value_text='jigsaw'
      INTERSECT
      SELECT sku FROM product_properties WHERE key='voltage_v' AND value_number=12
    )
  ) OR (
    r.label='r5' AND p.sku IN (
      SELECT sku FROM product_properties WHERE key='screw_type' AND value_text='deck screw'
      INTERSECT
      SELECT sku FROM product_properties WHERE key='diameter_mm' AND value_number=8
    )
  ) OR (
    r.label='r6' AND p.sku IN (
      SELECT sku FROM product_properties WHERE key='disc_diameter_mm' AND value_number=230
      INTERSECT
      SELECT sku FROM product_properties WHERE key='power_w' AND value_number=650
    )
  )
ORDER BY r.label, p.sku, pp.key;
