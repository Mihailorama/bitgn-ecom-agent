[32mOUT[0m: /bin/sql <<'SQL'
WITH vienna_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Vienna'
),
candidate_products AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name
  FROM products p
  WHERE p.brand = 'Einhell'
    AND p.series = 'Einhell Expert GC RPD-J21'
    AND p.name = 'Cordless Drill Driver'
),
required_props AS (
  SELECT 'voltage' AS key, '18 V' AS value_text
  UNION ALL SELECT 'battery_platform', '18v-system'
  UNION ALL SELECT 'kit_contents', 'starter kit'
),
matching_products AS (
  SELECT cp.sku, cp.path
  FROM candidate_products cp
  JOIN required_props rp
    ON EXISTS (
      SELECT 1
      FROM product_properties pp
      WHERE pp.sku = cp.sku
        AND pp.key = rp.key
        AND pp.value_text = rp.value_text
    )
  GROUP BY cp.sku, cp.path
  HAVING COUNT(*) = (SELECT COUNT(*) FROM required_props)
)
SELECT 'STORE' AS row_type, vs.id AS id, vs.path AS path, NULL AS sku, NULL AS available_today
FROM vienna_stores vs
UNION ALL
SELECT 'PRODUCT' AS row_type, NULL AS id, mp.path AS path, mp.sku AS sku, NULL AS available_today
FROM matching_products mp
UNION ALL
SELECT 'TOTAL' AS row_type, NULL AS id, NULL AS path, mp.sku AS sku, COALESCE(SUM(COALESCE(i.available_today,0)),0) AS available_today
FROM matching_products mp
CROSS JOIN vienna_stores vs
LEFT JOIN inventory i
  ON i.store_id = vs.id AND i.sku = mp.sku
GROUP BY mp.sku;
