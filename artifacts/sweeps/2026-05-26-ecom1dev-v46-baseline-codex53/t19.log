WITH einhell_candidates AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name
  FROM products p
  WHERE p.brand = 'Einhell'
    AND (
      LOWER(p.name) LIKE '%cordless%drill%driver%'
      OR LOWER(p.model) LIKE '%gc rpd-j21%'
      OR LOWER(p.series) LIKE '%expert%'
    )
)
SELECT ec.sku, ec.path, ec.brand, ec.series, ec.model, ec.name, pp.key, pp.value_text
FROM einhell_candidates ec
LEFT JOIN product_properties pp ON pp.sku = ec.sku
ORDER BY ec.sku, pp.key;
