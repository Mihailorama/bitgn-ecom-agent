SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       pk.name AS kind
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
WHERE p.brand = 'Geberit'
  AND (
    p.series LIKE '%Brass%'
    OR p.series LIKE '%Silent%'
    OR p.model LIKE '%1J6-HIW%'
    OR p.name LIKE '%1J6-HIW%'
    OR p.name LIKE '%Valve and Connector%'
  )
ORDER BY p.series, p.model, p.sku;
