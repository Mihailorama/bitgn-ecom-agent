[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       pp1.value_text AS fitting_type,
       COALESCE(pp2.value_number, CAST(pp2.value_text AS REAL)) AS diameter_mm
FROM products p
LEFT JOIN product_properties pp1
  ON pp1.sku = p.sku AND pp1.key IN ('fitting_type','fitting type')
LEFT JOIN product_properties pp2
  ON pp2.sku = p.sku AND pp2.key IN ('diameter_mm','diameter mm','diameter')
WHERE p.brand = 'Uponor'
  AND (p.series = 'Uponor Press Fit Aqua 35M-6XO' OR p.model = 'Uponor Press Fit Aqua 35M-6XO' OR p.name LIKE '%Uponor Press Fit Aqua 35M-6XO%')
ORDER BY p.sku;
