SELECT p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind, c.name AS category,
       pp.key, pp.value_text, pp.value_number
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
JOIN categories c ON c.id = p.category_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand = '3M'
  AND (p.series = 'Comfort Aura' OR p.name LIKE '%Comfort Aura%')
  AND (p.model = 'K2Y-9TP' OR p.name LIKE '%K2Y-9TP%')
  AND (pk.name = 'Head and Hearing Protection' OR c.name = 'Head and Hearing Protection')
ORDER BY p.sku, pp.key;
