WITH target_store AS (
  SELECT id, path FROM stores
  WHERE id='store_bratislava_praterstern' OR lower(name) LIKE '%praterstern%' OR (lower(city)='bratislava' AND lower(name) LIKE '%central%')
), wanted AS (
  SELECT 'Loctite' AS brand, 'Loctite Universal' AS series, '401' AS model, 'Adhesive and Glue' AS kind,
         'adhesive_type' AS k1, 'wood glue' AS v1, 'color_family' AS k2, 'Brown' AS v2
  UNION ALL SELECT 'Snickers Workwear','Snickers Workwear Classic','SW','Work Trousers','color_family','Black','size','L'
  UNION ALL SELECT 'Really Useful Box','Really Useful Box Compact','RUB','Storage Bin and Organizer','storage_type','parts case','color_family','Clear'
  UNION ALL SELECT 'Wera','Wera Professional','Kraftform','Pliers and Wrenches','tool_type','adjustable wrench','length_mm','125'
  UNION ALL SELECT 'Metabo','Metabo Professional','W','Corded Angle Grinder','disc_diameter_mm','115','power_w','2600'
  UNION ALL SELECT 'Stanley','Stanley Professional','SX','Pliers and Wrenches','tool_type','water pump pliers','length_mm','125'
), base AS (
  SELECT w.brand,w.series,w.model,w.kind,w.k1,w.v1,w.k2,w.v2,p.sku,p.path,ts.path AS store_path,i.available_today,pk.name AS kind_name
  FROM wanted w
  JOIN product_kinds pk ON pk.name = w.kind
  JOIN products p ON p.kind_id = pk.id
    AND p.brand = w.brand
    AND p.series LIKE w.series || '%'
    AND p.model LIKE w.model || '%'
  JOIN product_properties pp1 ON pp1.sku=p.sku AND pp1.key=w.k1
  JOIN product_properties pp2 ON pp2.sku=p.sku AND pp2.key=w.k2
  JOIN target_store ts
  JOIN inventory i ON i.store_id=ts.id AND i.sku=p.sku
  WHERE (lower(pp1.value_text)=lower(w.v1) OR CAST(pp1.value_number AS TEXT)=w.v1)
    AND (lower(pp2.value_text)=lower(w.v2) OR CAST(pp2.value_number AS TEXT)=w.v2)
)
SELECT * FROM base ORDER BY brand, series, model, sku;
