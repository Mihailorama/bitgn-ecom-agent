[32mOUT[0m: /bin/sql <<'SQL'
WITH bratislava AS (
  SELECT id, path, name, city
  FROM stores
  WHERE lower(city)='bratislava'
), target_store AS (
  SELECT id, path, name
  FROM bratislava
  WHERE id='store_bratislava_praterstern'
     OR lower(name) LIKE '%praterstern%'
     OR lower(name) LIKE '%central%'
), wanted(item,brand,series,model,kind,k1,v1,k2,v2,k3,v3) AS (
  VALUES
  ('loctite','Loctite','Loctite Universal','401 4VI-0XS','Adhesive and Glue','adhesive_type','wood glue','color_family','Brown',NULL,NULL),
  ('snickers','Snickers Workwear','Snickers Workwear Classic','SW 27F-FGX','Work Trousers','color_family','Black','size','L','fit','women'),
  ('rub','Really Useful Box','Really Useful Box Compact','RUB 10R-QVB','Storage Bin and Organizer','storage_type','parts case','color_family','Clear',NULL,NULL),
  ('wera','Wera','Wera Professional','Kraftform VNH-TAQ','Pliers and Wrenches','tool_type','adjustable wrench','length_mm','125',NULL,NULL),
  ('metabo','Metabo','Metabo Professional','W 27T-T2L','Corded Angle Grinder','disc_diameter_mm','115','power_w','2600',NULL,NULL),
  ('stanley','Stanley','Stanley Professional','SX ECU-AKL','Pliers and Wrenches','tool_type','water pump pliers','length_mm','125',NULL,NULL)
), matched AS (
  SELECT
    w.item,
    w.brand,
    p.sku,
    p.path AS product_path,
    ts.path AS store_path,
    i.available_today
  FROM wanted w
  JOIN product_kinds pk ON pk.name=w.kind
  JOIN products p ON p.kind_id=pk.id
   AND p.brand=w.brand
   AND p.series=w.series
   AND p.model=w.model
  JOIN target_store ts
  JOIN inventory i ON i.store_id=ts.id AND i.sku=p.sku
  JOIN product_properties a ON a.sku=p.sku AND a.key=w.k1
  JOIN product_properties b ON b.sku=p.sku AND b.key=w.k2
  LEFT JOIN product_properties c ON c.sku=p.sku AND w.k3 IS NOT NULL AND c.key=w.k3
  WHERE (lower(a.value_text)=lower(w.v1) OR CAST(a.value_number AS TEXT)=w.v1)
    AND (lower(b.value_text)=lower(w.v2) OR CAST(b.value_number AS TEXT)=w.v2)
    AND (w.k3 IS NULL OR lower(c.value_text)=lower(w.v3) OR CAST(c.value_number AS TEXT)=w.v3)
)
SELECT
  (SELECT group_concat(id,'|') FROM bratislava) AS bratislava_store_ids,
  (SELECT group_concat(id,'|') FROM target_store) AS resolved_target_store_ids,
  COUNT(DISTINCT CASE WHEN available_today>=4 THEN item END) AS qualifying_count
FROM matched;
