WITH store_scan AS (
  SELECT id, path, name, city
  FROM stores
  WHERE lower(city) LIKE '%bratislava%' OR lower(name) LIKE '%bratislava%' OR lower(name) LIKE '%stare mesto%' OR lower(name) LIKE '%praterstern%'
), wanted AS (
  SELECT 'Loctite' AS brand, 'Adhesive and Glue' AS kind
  UNION ALL SELECT 'Snickers Workwear','Work Trousers'
  UNION ALL SELECT 'Really Useful Box','Storage Bin and Organizer'
  UNION ALL SELECT 'Wera','Pliers and Wrenches'
  UNION ALL SELECT 'Metabo','Corded Angle Grinder'
  UNION ALL SELECT 'Stanley','Pliers and Wrenches'
)
SELECT
  ss.id AS store_id,
  ss.path AS store_path,
  ss.name AS store_name,
  ss.city,
  p.sku,
  p.path AS product_path,
  p.brand,
  p.series,
  p.model,
  pk.name AS kind,
  i.available_today,
  pp.key,
  COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) AS value
FROM store_scan ss
JOIN inventory i ON i.store_id = ss.id
JOIN products p ON p.sku = i.sku
JOIN product_kinds pk ON pk.id = p.kind_id
JOIN wanted w ON w.brand = p.brand AND w.kind = pk.name
LEFT JOIN product_properties pp ON pp.sku = p.sku
ORDER BY ss.id, p.brand, pk.name, p.series, p.model, p.sku, pp.key;
