WITH bratislava_stores AS (
  SELECT id, path, name, city FROM stores WHERE lower(city)='bratislava'
), wanted AS (
  SELECT 'Loctite' AS brand, 'Loctite Universal' AS series, '401 4VI-0XS' AS model_hint, 'Adhesive and Glue' AS kind
  UNION ALL SELECT 'Snickers Workwear','Snickers Workwear Classic','SW 27F-FGX','Work Trousers'
  UNION ALL SELECT 'Really Useful Box','Really Useful Box Compact','RUB 10R-QVB','Storage Bin and Organizer'
  UNION ALL SELECT 'Wera','Wera Professional','Kraftform VNH-TAQ','Pliers and Wrenches'
  UNION ALL SELECT 'Metabo','Metabo Professional','W 27T-T2L','Corded Angle Grinder'
  UNION ALL SELECT 'Stanley','Stanley Professional','SX ECU-AKL','Pliers and Wrenches'
)
SELECT
  bs.id AS store_id,
  bs.path AS store_path,
  bs.name AS store_name,
  w.brand,
  w.series,
  w.model_hint,
  w.kind,
  p.sku,
  p.path AS product_path,
  p.model,
  p.name,
  i.available_today,
  pp.key,
  COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) AS value
FROM bratislava_stores bs
JOIN inventory i ON i.store_id = bs.id
JOIN products p ON p.sku = i.sku
JOIN product_kinds pk ON pk.id = p.kind_id
JOIN wanted w ON w.brand = p.brand AND pk.name = w.kind
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.series LIKE w.series || '%'
  AND (p.model LIKE '%' || w.model_hint || '%' OR p.name LIKE '%' || w.model_hint || '%')
ORDER BY bs.id, w.brand, p.sku, pp.key;
