SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       pp.key, pp.value_text, pp.value_number
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE LOWER(p.brand) = 'rawlplug'
  AND (
    LOWER(p.series) LIKE '%rapid raw 2yz-i6t%'
    OR LOWER(p.model) LIKE '%rapid raw 2yz-i6t%'
    OR LOWER(p.name) LIKE '%rapid raw 2yz-i6t%'
  )
ORDER BY p.sku, pp.key;
