[32mOUT[0m: /bin/sql <<'SQL'
WITH props AS (
  SELECT p.sku, p.path,
         MAX(CASE WHEN pp.key='anchor_type' THEN pp.value_text END) AS anchor_type,
         MAX(CASE WHEN pp.key='diameter_mm' THEN COALESCE(pp.value_number, CAST(pp.value_text AS REAL)) END) AS diameter_mm,
         MAX(CASE WHEN pp.key='length_mm' THEN COALESCE(pp.value_number, CAST(pp.value_text AS REAL)) END) AS length_mm
  FROM products p
  JOIN product_properties pp ON pp.sku = p.sku
  WHERE LOWER(p.brand)='rawlplug'
    AND LOWER(p.series)='rapid'
    AND LOWER(p.model)='raw 2yz-i6t'
  GROUP BY p.sku, p.path
)
SELECT sku, path, anchor_type, diameter_mm, length_mm,
       CASE WHEN anchor_type='concrete anchor' AND diameter_mm=8 AND length_mm=50 THEN 1 ELSE 0 END AS matches_concrete_8x50,
       CASE WHEN anchor_type='frame fixing' AND diameter_mm=8 AND length_mm=50 THEN 1 ELSE 0 END AS matches_framefix_8x50
FROM props
WHERE diameter_mm=8 AND (length_mm=50 OR anchor_type IN ('concrete anchor','frame fixing'))
ORDER BY sku;
