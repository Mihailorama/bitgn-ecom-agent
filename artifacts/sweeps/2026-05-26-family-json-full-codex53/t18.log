WITH target_products AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_properties pp ON pp.sku = p.sku
  WHERE p.brand = 'Bahco'
    AND p.series = 'Bahco Workshop BAH 3VZ-SPH'
    AND p.name = 'Hammer Measuring and Cutting Tool'
    AND pp.key = 'tool_type'
    AND pp.value_text = 'measuring tape'
)
SELECT 'product' AS kind, tp.sku AS id, tp.path AS path, NULL AS city, NULL AS available_today
FROM target_products tp
UNION ALL
SELECT 'store' AS kind, s.id AS id, s.path AS path, s.city AS city,
       COALESCE(i.available_today, 0) AS available_today
FROM stores s
LEFT JOIN inventory i
  ON i.store_id = s.id
 AND i.sku IN (SELECT sku FROM target_products)
WHERE s.city = 'Graz'
ORDER BY kind, id;
