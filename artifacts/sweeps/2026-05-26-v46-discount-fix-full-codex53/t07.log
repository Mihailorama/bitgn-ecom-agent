SELECT p.sku, p.path,
       MAX(CASE WHEN pp.key='length_mm' AND pp.value_number=250 THEN 1 ELSE 0 END) AS has_len_250,
       MAX(CASE WHEN pp.key='tool_type' AND lower(pp.value_text)='water pump pliers' THEN 1 ELSE 0 END) AS has_water_pump,
       MAX(CASE WHEN pp.key='tool_type' AND lower(pp.value_text)='socket wrench' THEN 1 ELSE 0 END) AS has_socket_wrench
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand='Bahco'
  AND p.series='Heavy Duty'
  AND p.model='S ETS-3CM'
  AND pk.name='Pliers and Wrenches'
GROUP BY p.sku, p.path
ORDER BY p.sku;
