[32mOUT[0m: /bin/sql <<'SQL'
WITH target_product AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_properties pp_type
    ON pp_type.sku = p.sku AND pp_type.key = 'product_type' AND lower(pp_type.value_text) = 'primer'
  JOIN product_properties pp_color
    ON pp_color.sku = p.sku AND pp_color.key = 'color_family' AND lower(pp_color.value_text) = 'red'
  JOIN product_properties pp_finish
    ON pp_finish.sku = p.sku AND pp_finish.key = 'finish' AND lower(pp_finish.value_text) = 'transparent'
  WHERE lower(p.brand) = 'caparol'
    AND lower(p.series) = 'caparol premium capa 32d-5x8 metal and concrete paint'
    AND lower(p.name) = 'metal and concrete paint'
), graz_stores AS (
  SELECT id, path
  FROM stores
  WHERE lower(city) = 'graz'
)
SELECT
  tp.sku,
  tp.path AS product_path,
  gs.path AS store_path,
  COALESCE(i.available_today, 0) AS available_today,
  SUM(COALESCE(i.available_today, 0)) OVER () AS total_available_today
FROM graz_stores gs
CROSS JOIN target_product tp
LEFT JOIN inventory i
  ON i.store_id = gs.id AND i.sku = tp.sku
ORDER BY gs.path;
