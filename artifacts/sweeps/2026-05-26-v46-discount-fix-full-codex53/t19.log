[32mOUT[0m: /bin/sql <<'SQL'
WITH candidates AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind_name
  FROM products p
  LEFT JOIN product_kinds pk ON pk.id = p.kind_id
  WHERE lower(p.brand) = 'caparol'
    AND (
      lower(p.name) LIKE '%metal%concrete%paint%'
      OR lower(p.series) LIKE '%32d-5x8%'
      OR lower(p.series) LIKE '%caparol premium capa%'
    )
)
SELECT c.sku, c.path, c.brand, c.series, c.model, c.name, c.kind_name,
       pp.key, pp.value_text, pp.value_number
FROM candidates c
LEFT JOIN product_properties pp ON pp.sku = c.sku
ORDER BY c.path, pp.key;
