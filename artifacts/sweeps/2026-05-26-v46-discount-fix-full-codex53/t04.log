[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       GROUP_CONCAT(pp.key || '=' || COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)), '; ') AS props
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE LOWER(p.brand) = 'metabo'
  AND (
    LOWER(p.name) LIKE '%grinder%'
    OR EXISTS (
      SELECT 1 FROM product_properties pp2
      WHERE pp2.sku = p.sku
        AND (
          LOWER(pp2.value_text) LIKE '%grinder%'
          OR LOWER(pp2.value_text) LIKE '%angle%'
        )
    )
  )
  AND (
    LOWER(p.name) LIKE '%cordless%'
    OR EXISTS (
      SELECT 1 FROM product_properties pp3
      WHERE pp3.sku = p.sku AND LOWER(pp3.value_text) LIKE '%cordless%'
    )
  )
  AND (
    LOWER(p.name) LIKE '%125%'
    OR EXISTS (
      SELECT 1 FROM product_properties pp4
      WHERE pp4.sku = p.sku
        AND (LOWER(pp4.value_text) LIKE '%125%' OR pp4.value_number = 125)
    )
  )
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
ORDER BY p.sku;
