[32mOUT[0m: /bin/sql <<'SQL'
WITH c AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, k.name AS kind_name,
         MAX(CASE WHEN pp.key='fastener_type' AND lower(pp.value_text)='bolt' THEN 1 ELSE 0 END) AS ok_fastener_type,
         MAX(CASE WHEN pp.key='diameter_mm' AND pp.value_number=12 THEN 1 ELSE 0 END) AS ok_diameter,
         MAX(CASE WHEN pp.key='length_mm' AND pp.value_number=40 THEN 1 ELSE 0 END) AS ok_length,
         MAX(CASE WHEN pp.key='pack_count' AND pp.value_number=100 THEN 1 ELSE 0 END) AS ok_pack_count,
         MAX(CASE WHEN pp.key='machine_type' AND lower(pp.value_text)='drill press' THEN 1 ELSE 0 END) AS ok_machine_type,
         MAX(CASE WHEN pp.key='voltage_v' AND pp.value_number=400 THEN 1 ELSE 0 END) AS ok_voltage
  FROM products p
  JOIN product_kinds k ON k.id=p.kind_id
  JOIN product_properties pp ON pp.sku=p.sku
  WHERE (p.brand='Heco' AND p.series='Unix' AND p.model='HECO 2VD-VNA' AND k.name='Nut Bolt and Washer')
     OR (p.brand='Makita' AND p.series='Workshop' AND p.model='DDF OIE-YYP' AND k.name='Workshop Drill Grinder and Sander')
  GROUP BY p.sku, p.path, p.brand, p.series, p.model, k.name
)
SELECT *
FROM c
WHERE (brand='Heco' AND ok_fastener_type=1 AND ok_diameter=1 AND ok_length=1 AND ok_pack_count=1)
   OR (brand='Makita' AND ok_machine_type=1 AND ok_voltage=1)
ORDER BY brand, sku;
