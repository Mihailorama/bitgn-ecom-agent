WITH req(label,brand,series,model,kind_name) AS (
  VALUES
  ('mascot_black','Mascot','Advanced','ACC 35W-IIS','Work Jacket'),
  ('mascot_blue','Mascot','Advanced','ACC 35W-IIS','Work Jacket'),
  ('heco_bolt_12_40_100','Heco','Unix','HECO 2VD-VNA','Nut Bolt and Washer'),
  ('makita_drillpress_400','Makita','Workshop','DDF OIE-YYP','Workshop Drill Grinder and Sander'),
  ('gardena_pruningsaw','Gardena','Smart','PowerMax 280-5FI','Manual Garden Tool'),
  ('ryobi_multitool','Ryobi','Precision','RLM 2KQ-R4C','Cordless Saw and Sander')
), base AS (
  SELECT r.label, p.sku, p.path, p.brand, p.series, p.model, k.name AS kind_name
  FROM req r
  JOIN products p
    ON p.brand=r.brand AND p.series=r.series AND p.model=r.model
  JOIN product_kinds k
    ON k.id=p.kind_id AND k.name=r.kind_name
)
SELECT b.label, b.sku, b.path, pp.key, pp.value_text, pp.value_number
FROM base b
JOIN product_properties pp ON pp.sku=b.sku
WHERE
  (b.label='mascot_black' AND pp.key='color_family' AND lower(pp.value_text)='black') OR
  (b.label='mascot_blue' AND pp.key='color_family' AND lower(pp.value_text)='blue') OR
  (b.label='heco_bolt_12_40_100' AND (
      (pp.key='fastener_type' AND lower(pp.value_text)='bolt') OR
      (pp.key='diameter_mm' AND pp.value_number=12) OR
      (pp.key='length_mm' AND pp.value_number=40) OR
      (pp.key='pack_count' AND pp.value_number=100)
