      (pp.key='machine_type' AND lower(pp.value_text)='drill press') OR
      (pp.key='voltage_v' AND pp.value_number=400)
  )) OR
  (b.label='gardena_pruningsaw' AND pp.key='tool_type' AND lower(pp.value_text)='pruning saw') OR
  (b.label='ryobi_multitool' AND pp.key='tool_type' AND lower(pp.value_text)='multi tool')
ORDER BY b.label, b.sku, pp.key;
