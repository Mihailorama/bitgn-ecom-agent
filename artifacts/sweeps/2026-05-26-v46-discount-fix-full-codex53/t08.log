[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       MAX(CASE WHEN pp.key='power_source' THEN pp.value_text END) AS power_source,
       MAX(CASE WHEN pp.key='cutting_width_cm' THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS cutting_width_cm,
       MAX(CASE WHEN pp.key='battery_platform' THEN pp.value_text END) AS battery_platform
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE (p.brand='Wolf-Garten' OR p.name LIKE '%Wolf-Garten%')
  AND (p.series='Battery Lycos' OR p.name LIKE '%Battery Lycos%')
  AND (p.model='2WV-8JX' OR p.name LIKE '%2WV-8JX%')
  AND (p.name LIKE '%Lawn Mower%' OR p.model LIKE '%Lawn Mower%')
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
ORDER BY p.sku;
