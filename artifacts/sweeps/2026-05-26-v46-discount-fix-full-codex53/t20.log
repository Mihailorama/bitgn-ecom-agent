WITH candidate_products AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name
  FROM products p
  JOIN product_properties pp_len ON pp_len.sku = p.sku
  JOIN product_properties pp_adapter ON pp_adapter.sku = p.sku
  WHERE p.brand = 'Valeo'
    AND (p.series = 'Valeo Winter VF' OR p.series LIKE '%Winter VF%')
    AND (p.model = '1JR-UBR' OR p.model LIKE '%1JR-UBR%')
    AND p.name LIKE '%Wiper Blade%'
    AND pp_len.key IN ('length_mm','length')
    AND (pp_len.value_number = 450 OR pp_len.value_text IN ('450','450 mm'))
    AND pp_adapter.key IN ('adapter_type','adapter')
    AND lower(pp_adapter.value_text) = 'side lock'
)
SELECT * FROM candidate_products;
