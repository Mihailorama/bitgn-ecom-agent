WITH target_product AS (
  SELECT sku, path
  FROM products
  WHERE sku = 'AUT-CYMPKOQD'
), vienna_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Vienna'
)
SELECT
  tp.path AS product_path,
  vs.path AS store_path,
  COALESCE(i.available_today, 0) AS available_today,
  SUM(COALESCE(i.available_today, 0)) OVER () AS total_available_today
FROM vienna_stores vs
CROSS JOIN target_product tp
LEFT JOIN inventory i
  ON i.store_id = vs.id
 AND i.sku = tp.sku
ORDER BY vs.path;
SQL
product_path,store_path,available_today,total_available_today
