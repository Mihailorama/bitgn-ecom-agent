[32mOUT[0m: /bin/sql <<'SQL'
WITH base AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name
  FROM products p
  WHERE p.brand = 'Valeo'
    AND lower(p.name) LIKE '%wiper%blade%'
    AND (
      p.series LIKE '%Winter VF%'
      OR p.model LIKE '%1JR-UBR%'
      OR p.name LIKE '%1JR-UBR%'
    )
)
SELECT b.sku, b.path, b.brand, b.series, b.model, b.name,
       pp.key, pp.value_text, pp.value_number
FROM base b
LEFT JOIN product_properties pp ON pp.sku = b.sku
ORDER BY b.sku, pp.key;
