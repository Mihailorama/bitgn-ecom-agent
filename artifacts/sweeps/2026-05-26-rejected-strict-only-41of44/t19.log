SELECT s.path AS store_path,
       COALESCE(i.available_today, 0) AS available_today,
       (
         SELECT SUM(COALESCE(i2.available_today,0))
         FROM stores s2
         LEFT JOIN inventory i2
           ON i2.store_id = s2.id AND i2.sku = 'PNT-36S2OR3P'
         WHERE s2.city = 'Vienna'
       ) AS city_total
FROM stores s
LEFT JOIN inventory i
  ON i.store_id = s.id AND i.sku = 'PNT-36S2OR3P'
WHERE s.city = 'Vienna'
ORDER BY s.path;
