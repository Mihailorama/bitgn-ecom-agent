WITH target_store AS (
  SELECT id, path, name, city
  FROM stores
  WHERE city='Graz' AND name LIKE '%Lend%'
), requested AS (
  SELECT 'frosch_cleaning_liquid' AS req_key, 'Frosch' AS brand, 'Eco Citrus' AS series, '335-M1E' AS model, 'Cleaning Liquid' AS kind_name, 'cleaner type' AS p1k, 'glass cleaner' AS p1v, 'volume ml' AS p2k, '500' AS p2v
  UNION ALL SELECT 'scheppach_workshop_saw_cutter','Scheppach','Precision','HC 18L-GVQ','Workshop Saw and Cutter','machine type','mitre saw',NULL,NULL
  UNION ALL SELECT 'sparco_work_top','Sparco','Urban Allroad','1UH-ALM','Work Top','garment type','polo shirt','color family','Blue'
  UNION ALL SELECT 'hazet_pliers_wrenches','Hazet','Professional 600','2X8-KJZ','Pliers and Wrenches','tool type','water pump pliers','length mm','200'
  UNION ALL SELECT 'wolf_manual_garden_tool','Wolf-Garten','Compact Multi-Star','KVU-5RJ','Manual Garden Tool','tool type','soil cultivator',NULL,NULL
  UNION ALL SELECT '3m_safety_eyewear','3M','SecureFit SF','6OX-K48','Safety Eyewear','lens color','Clear','size','S'
), norm_props AS (
  SELECT sku,
         lower(replace(key,'_',' ')) AS k,
         COALESCE(value_text, CAST(value_number AS TEXT)) AS v
  FROM product_properties
), candidates AS (
  SELECT r.req_key, p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind_name
  FROM requested r
  JOIN products p ON p.brand=r.brand AND p.series=r.series AND p.model=r.model
  JOIN product_kinds pk ON pk.id=p.kind_id
  WHERE pk.name=r.kind_name
)
SELECT c.req_key, c.sku, c.path, c.brand, c.series, c.model, c.kind_name,
       ts.id AS store_id, ts.path AS store_path,
       i.available_today,
       MAX(CASE WHEN np.k=lower(r.p1k) THEN np.v END) AS prop1_value,
       MAX(CASE WHEN r.p2k IS NOT NULL AND np.k=lower(r.p2k) THEN np.v END) AS prop2_value
FROM candidates c
JOIN requested r ON r.req_key=c.req_key
JOIN target_store ts
LEFT JOIN norm_props np ON np.sku=c.sku
LEFT JOIN inventory i ON i.sku=c.sku AND i.store_id=ts.id
GROUP BY c.req_key, c.sku, c.path, c.brand, c.series, c.model, c.kind_name, ts.id, ts.path, i.available_today
ORDER BY c.req_key, c.sku;
