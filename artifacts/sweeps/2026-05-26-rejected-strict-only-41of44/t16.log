WITH req(req_key,brand,series,model,kind_name,p1k,p1v,p2k,p2v,p3k,p3v) AS (
  VALUES
  ('frosch_cleaning_liquid','Frosch','Eco Citrus','335-M1E','Cleaning Liquid','cleaner type','glass cleaner','volume ml','500',NULL,NULL),
  ('scheppach_workshop_saw_cutter','Scheppach','Precision','HC 18L-GVQ','Workshop Saw and Cutter','machine type','mitre saw',NULL,NULL,NULL,NULL),
  ('sparco_work_top','Sparco','Urban Allroad','1UH-ALM','Work Top','garment type','polo shirt','color family','Blue','size','L'),
  ('hazet_pliers_wrenches','Hazet','Professional 600','2X8-KJZ','Pliers and Wrenches','tool type','water pump pliers','length mm','200',NULL,NULL),
  ('wolf_manual_garden_tool','Wolf-Garten','Compact Multi-Star','KVU-5RJ','Manual Garden Tool','tool type','soil cultivator',NULL,NULL,NULL,NULL),
  ('3m_safety_eyewear','3M','SecureFit SF','6OX-K48','Safety Eyewear','lens color','Clear','size','S',NULL,NULL)
), s AS (
  SELECT id, path FROM stores WHERE id='store_graz_lend'
), base AS (
  SELECT r.req_key, p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind_name
  FROM req r
  JOIN products p
    ON lower(p.brand)=lower(r.brand)
   AND lower(p.series)=lower(r.series)
   AND lower(p.model)=lower(r.model)
  JOIN product_kinds pk
    ON pk.id=p.kind_id
   AND lower(pk.name)=lower(r.kind_name)
), norm_props AS (
  SELECT sku,
         lower(replace(key,'_',' ')) AS k,
         lower(COALESCE(value_text, CAST(value_number AS TEXT))) AS v
  FROM product_properties
), matched AS (
  SELECT b.req_key, b.sku, b.path, b.brand, b.series, b.model, b.kind_name,
         i.available_today, s.path AS store_path
  FROM base b
  JOIN req r ON r.req_key=b.req_key
  LEFT JOIN s
  LEFT JOIN inventory i ON i.store_id=s.id AND i.sku=b.sku
  WHERE EXISTS (
          SELECT 1 FROM norm_props np
          WHERE np.sku=b.sku
            AND np.k=lower(r.p1k)
            AND np.v=lower(r.p1v)
        )
    AND (r.p2k IS NULL OR EXISTS (
          SELECT 1 FROM norm_props np
          WHERE np.sku=b.sku
            AND np.k=lower(r.p2k)
            AND np.v=lower(r.p2v)
        ))
    AND (r.p3k IS NULL OR EXISTS (
          SELECT 1 FROM norm_props np
          WHERE np.sku=b.sku
            AND np.k=lower(r.p3k)
            AND np.v=lower(r.p3v)
        ))
)
SELECT req_key, sku, path, brand, series, model, kind_name, available_today, store_path
FROM matched
ORDER BY req_key, sku;
