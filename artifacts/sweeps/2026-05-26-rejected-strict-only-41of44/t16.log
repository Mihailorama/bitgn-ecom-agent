WITH req(req_key,brand,series,model,kind_name) AS (
  VALUES
  ('frosch_cleaning_liquid','Frosch','Eco Citrus','335-M1E','Cleaning Liquid'),
  ('scheppach_workshop_saw_cutter','Scheppach','Precision','HC 18L-GVQ','Workshop Saw and Cutter'),
  ('sparco_work_top','Sparco','Urban Allroad','1UH-ALM','Work Top'),
  ('hazet_pliers_wrenches','Hazet','Professional 600','2X8-KJZ','Pliers and Wrenches'),
  ('wolf_manual_garden_tool','Wolf-Garten','Compact Multi-Star','KVU-5RJ','Manual Garden Tool'),
  ('3m_safety_eyewear','3M','SecureFit SF','6OX-K48','Safety Eyewear')
), s AS (
  SELECT id, path FROM stores WHERE id='store_graz_lend'
)
SELECT r.req_key,
       p.sku,
       p.path,
       p.brand,
       p.series,
       p.model,
       pk.name AS kind_name,
       pp.key,
       pp.value_text,
       pp.value_number,
       i.available_today,
       s.path AS store_path
FROM req r
JOIN products p
  ON p.brand=r.brand AND p.series=r.series AND p.model=r.model
JOIN product_kinds pk
  ON pk.id=p.kind_id AND pk.name=r.kind_name
LEFT JOIN product_properties pp
  ON pp.sku=p.sku
LEFT JOIN s
LEFT JOIN inventory i
  ON i.store_id=s.id AND i.sku=p.sku
ORDER BY r.req_key, p.sku, pp.key;
