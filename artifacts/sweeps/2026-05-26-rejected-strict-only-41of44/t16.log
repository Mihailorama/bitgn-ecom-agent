Next step_3... Run a diagnostic SQL lookup by brand with loose matching to enumerate real product kind/series/model/property keys for the missing brands. (21885 ms)
  [[32msafe[0m] tool='exec' path='/bin/sql' args=[] stdin="WITH s AS (\n  SELECT id, path FROM stores WHERE id='store_graz_lend'\n), brands AS (\n  VALUES ('Frosch'),('Sparco'),('Hazet'),('Wolf-Garten'),('3M')\n)\nSELECT p.brand,\n       pk.name AS kind_name,\n       p.series,\n       p.model,\n       p.sku,\n       p.path,\n       pp.key,\n       pp.value_text,\n       pp.value_number,\n       i.available_today,\n       s.path AS store_path\nFROM products p\nJOIN brands b ON p.brand=b.column1\nJOIN product_kinds pk ON pk.id=p.kind_id\nLEFT JOIN product_properties pp ON pp.sku=p.sku\nLEFT JOIN s\nLEFT JOIN inventory i ON i.store_id=s.id AND i.sku=p.sku\nWHERE (\n  p.model IN ('335-M1E','1UH-ALM','2X8-KJZ','KVU-5RJ','6OX-K48')\n  OR p.series LIKE '%Eco Citrus%'\n  OR p.series LIKE '%Urban Allroad%'\n  OR p.series LIKE '%Professional 600%'\n  OR p.series LIKE '%Compact Multi-Star%'\n  OR p.series LIKE '%SecureFit SF%'\n)\nORDER BY p.brand, pk.name, p.series, p.model, p.sku, pp.key;"
[32mOUT[0m: /bin/sql <<'SQL'
WITH s AS (
  SELECT id, path FROM stores WHERE id='store_graz_lend'
), brands AS (
  VALUES ('Frosch'),('Sparco'),('Hazet'),('Wolf-Garten'),('3M')
)
SELECT p.brand,
       pk.name AS kind_name,
       p.series,
       p.model,
       p.sku,
       p.path,
       pp.key,
       pp.value_text,
       pp.value_number,
       i.available_today,
       s.path AS store_path
FROM products p
JOIN brands b ON p.brand=b.column1
JOIN product_kinds pk ON pk.id=p.kind_id
LEFT JOIN product_properties pp ON pp.sku=p.sku
LEFT JOIN s
LEFT JOIN inventory i ON i.store_id=s.id AND i.sku=p.sku
WHERE (
  p.model IN ('335-M1E','1UH-ALM','2X8-KJZ','KVU-5RJ','6OX-K48')
  OR p.series LIKE '%Eco Citrus%'
  OR p.series LIKE '%Urban Allroad%'
  OR p.series LIKE '%Professional 600%'
  OR p.series LIKE '%Compact Multi-Star%'
  OR p.series LIKE '%SecureFit SF%'
)
ORDER BY p.brand, pk.name, p.series, p.model, p.sku, pp.key;
SQL
brand,kind_name,series,model,sku,path,key,value_text,value_number,available_today,store_path
