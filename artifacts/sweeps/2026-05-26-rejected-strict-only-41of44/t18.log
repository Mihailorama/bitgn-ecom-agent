[32mOUT[0m: /bin/sql <<'SQL'
WITH graz_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Graz'
),
product_candidates AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_properties pp_size ON pp_size.sku = p.sku
  WHERE p.brand = 'Portwest'
    AND p.series = 'PW3 DX'
    AND p.model = '3TU-ST2'
    AND p.name = 'Work Gloves'
    AND pp_size.key = 'size'
    AND pp_size.value_text = 'M'
)
SELECT
  gs.path AS store_path,
  pc.path AS product_path,
  pc.sku,
  COALESCE(i.available_today, 0) AS available_today
FROM graz_stores gs
CROSS JOIN product_candidates pc
LEFT JOIN inventory i ON i.store_id = gs.id AND i.sku = pc.sku
ORDER BY gs.path, pc.sku;
SQL
store_path,product_path,sku,available_today
