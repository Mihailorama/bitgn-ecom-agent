  [[32msafe[0m] tool='exec' path='/bin/sql' args=[] stdin="SELECT p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind,\n       MAX(CASE WHEN pp.key='anchor_type' THEN pp.value_text END) AS anchor_type,\n       MAX(CASE WHEN pp.key='diameter_mm' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS diameter_mm,\n       MAX(CASE WHEN pp.key='length_mm' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS length_mm\nFROM products p\nJOIN product_kinds pk ON pk.id = p.kind_id\nLEFT JOIN product_properties pp ON pp.sku = p.sku\nWHERE p.brand = 'Rawlplug'\nGROUP BY p.sku, p.path, p.brand, p.series, p.model, pk.name\nORDER BY p.series, p.model, p.sku;"
[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind,
       MAX(CASE WHEN pp.key='anchor_type' THEN pp.value_text END) AS anchor_type,
       MAX(CASE WHEN pp.key='diameter_mm' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS diameter_mm,
       MAX(CASE WHEN pp.key='length_mm' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS length_mm
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand = 'Rawlplug'
GROUP BY p.sku, p.path, p.brand, p.series, p.model, pk.name
ORDER BY p.series, p.model, p.sku;
