SELECT p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind,
       pp.key, pp.value_text, pp.value_number
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand = 'Rawlplug'
  AND p.series = 'Rawlplug Rapid'
  AND p.model = 'RAW 2YZ-I6T'
  AND pk.name = 'Anchor and Wall Plug'
  AND pp.key IN ('anchor_type','diameter_mm','length_mm')
ORDER BY p.sku, pp.key;
