[32mOUT[0m: /bin/sql <<'SQL'
SELECT s.id, s.path, s.city, COALESCE(i.available_today,0) AS available_today,
       SUM(COALESCE(i.available_today,0)) OVER () AS total_available_today
FROM stores s
LEFT JOIN inventory i
  ON i.store_id = s.id
 AND i.sku = 'FST-27FM81RC'
WHERE s.city = 'Vienna'
ORDER BY s.id;
