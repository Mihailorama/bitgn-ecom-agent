SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pp.key, pp.value_text
FROM products p
JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand) = 'carhartt'
  AND (
    lower(p.series) LIKE '%stretch rugged 3ey-11k%'
    OR lower(p.model) LIKE '%3ey-11k%'
    OR lower(p.name) LIKE '%stretch rugged 3ey-11k%'
  )
  AND lower(p.name) LIKE '%work trousers%'
ORDER BY p.sku, pp.key;
