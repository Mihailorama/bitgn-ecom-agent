SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       MAX(CASE WHEN pp.key='connector_type' THEN pp.value_text END) AS connector_type,
       MAX(CASE WHEN pp.key='diameter_mm' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS diameter_mm,
       MAX(CASE WHEN pp.key='thread_type' THEN pp.value_text END) AS thread_type,
       MAX(CASE WHEN pp.key='material' THEN pp.value_text END) AS material
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand='Giacomini'
  AND (p.name LIKE '%Valve and Connector%' OR p.model='R 1PA-6JD' OR p.series LIKE '%R Series%')
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
ORDER BY p.sku;
