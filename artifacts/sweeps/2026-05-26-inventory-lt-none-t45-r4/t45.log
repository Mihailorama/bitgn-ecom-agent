WITH req(req_id,brand,series,model,kind_name,p1k,p1v,p2k,p2v,p3k,p3v) AS (
  VALUES
  ('holzmann','Holzmann','Compact','D 327-RR0','Compressor and Dust Extractor','machine_type','compressor','voltage_v','230','power_w','1500'),
  ('viega','Viega','Professional','Sanpress 2OG-ENN','Pipe Fitting','fitting_type','pipe fitting','diameter_mm','15','connection_type','push fit'),
  ('bondex','Bondex','Garden','Classic 106-TS1','Wood Stain and Deck Oil','product_type','lacquer',NULL,NULL,NULL,NULL),
  ('sonax','Sonax','Workshop','XTREME 218-FC5','Automotive Cleaner','cleaner_type','screen wash',NULL,NULL,NULL,NULL),
  ('philips','Philips','Professional','Hue 3JS-MSN','LED Bulb','wattage_w','10','lumen','1521',NULL,NULL),
  ('bosch','Bosch','Compact','PKS 375-EOK','Corded Angle Grinder','disc_diameter_mm','180',NULL,NULL,NULL,NULL)
),
store_target AS (
  SELECT id, path FROM stores WHERE path='/proc/stores/store_linz_hauptplatz.json'
),
matched AS (
  SELECT r.req_id, p.sku, p.path AS product_path, i.available_today
  FROM req r
  JOIN products p
    ON lower(p.brand)=lower(r.brand)
   AND lower(p.series)=lower(r.series)
   AND lower(p.model)=lower(r.model)
  JOIN product_kinds k ON k.id=p.kind_id AND lower(k.name)=lower(r.kind_name)
  JOIN store_target s
  JOIN inventory i ON i.store_id=s.id AND i.sku=p.sku
  WHERE EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key=r.p1k AND lower(pp.value_text)=lower(r.p1v))
    AND (r.p2k IS NULL OR EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key=r.p2k AND lower(pp.value_text)=lower(r.p2v)))
    AND (r.p3k IS NULL OR EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key=r.p3k AND lower(pp.value_text)=lower(r.p3v)))
)
SELECT COUNT(*) AS qty_below_5
FROM matched
WHERE available_today < 5;
