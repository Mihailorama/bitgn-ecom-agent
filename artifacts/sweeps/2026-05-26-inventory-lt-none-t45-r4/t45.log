WITH target_store AS (
  SELECT id, path, name, city
  FROM stores
  WHERE lower(city) LIKE '%linz%'
     OR lower(name) LIKE '%linz%'
     OR lower(name) LIKE '%main square%'
), req AS (
  SELECT 'holzmann_compressor' AS req_id, 'Holzmann' AS brand, 'Compact' AS series, 'D 327-RR0' AS model, 'Compressor and Dust Extractor' AS kind_name, 'machine type' AS p1k, 'compressor' AS p1v, 'voltage' AS p2k, '230 V' AS p2v, 'power' AS p3k, '1500 W' AS p3v
  UNION ALL
  SELECT 'viega_pipe_fitting','Viega','Professional','Sanpress 2OG-ENN','Pipe Fitting','fitting type','pipe fitting','diameter','15 mm','connection type','push fit'
  UNION ALL
  SELECT 'bondex_wood_stain','Bondex','Garden','Classic 106-TS1','Wood Stain and Deck Oil','product type','lacquer',NULL,NULL,NULL,NULL
  UNION ALL
  SELECT 'sonax_cleaner','Sonax','Workshop','XTREME 218-FC5','Automotive Cleaner','cleaner type','screen wash',NULL,NULL,NULL,NULL
  UNION ALL
  SELECT 'philips_led','Philips','Professional','Hue 3JS-MSN','LED Bulb','wattage','10 W','luminous flux','1521 lm',NULL,NULL
  UNION ALL
  SELECT 'bosch_grinder','Bosch','Compact','PKS 375-EOK','Corded Angle Grinder','disc diameter','180 mm',NULL,NULL,NULL,NULL
), base AS (
  SELECT r.req_id, p.sku, p.path AS product_path, pk.name AS kind_name, p.brand, p.series, p.model,
         pp.key, COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) AS value
  FROM req r
  JOIN products p
    ON lower(p.brand)=lower(r.brand)
   AND lower(p.series)=lower(r.series)
   AND lower(p.model)=lower(r.model)
  JOIN product_kinds pk ON pk.id=p.kind_id
  LEFT JOIN product_properties pp ON pp.sku=p.sku
  WHERE lower(pk.name)=lower(r.kind_name)
)
SELECT ts.path AS store_path, ts.name AS store_name, ts.city,
       b.req_id, b.sku, b.product_path, b.kind_name, b.brand, b.series, b.model,
       b.key, b.value, i.available_today
FROM base b
JOIN target_store ts
JOIN inventory i ON i.store_id=ts.id AND i.sku=b.sku
ORDER BY b.req_id, b.sku, b.key;
