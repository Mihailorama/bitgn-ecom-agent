WITH bosch_kind AS (
  SELECT p.sku, p.path, p.series, p.model, p.name
  FROM products p
  JOIN product_kinds k ON k.id = p.kind_id
  WHERE p.brand = 'Bosch'
    AND k.name = 'Workshop Saw and Cutter'
)
SELECT bk.sku, bk.path, bk.series, bk.model, bk.name, pp.key, pp.value_text, pp.value_number
FROM bosch_kind bk
LEFT JOIN product_properties pp ON pp.sku = bk.sku
WHERE pp.key IN ('machine_type','voltage','voltage_v')
   OR pp.key LIKE '%machine%'
   OR pp.key LIKE '%voltage%'
ORDER BY bk.series, bk.model, bk.sku, pp.key;
