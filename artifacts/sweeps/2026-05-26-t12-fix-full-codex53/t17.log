WITH candidate_products AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
         MAX(CASE WHEN pp.key='fastener_type' THEN pp.value_text END) AS fastener_type
  FROM products p
  LEFT JOIN product_properties pp ON pp.sku = p.sku
  WHERE p.brand='Heco'
    AND (p.series='Heco Zinc Plated HECO 3DW-64B' OR p.name LIKE '%Heco Zinc Plated HECO 3DW-64B%')
    AND (p.name LIKE '%Nut Bolt and Washer%' OR p.model LIKE '%Nut Bolt and Washer%')
  GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
)
SELECT sku, path, brand, series, model, name, fastener_type
FROM candidate_products
WHERE fastener_type='threaded rod';
