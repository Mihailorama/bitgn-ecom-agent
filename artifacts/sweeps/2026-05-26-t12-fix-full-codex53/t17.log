  FROM graz_stores gs
  LEFT JOIN inventory i
    ON i.store_id = gs.id
   AND i.sku = 'FST-2JPIIG2S'
)
SELECT store_path, available_today,
       SUM(available_today) OVER () AS total_available_today
FROM per_store
ORDER BY store_path;
