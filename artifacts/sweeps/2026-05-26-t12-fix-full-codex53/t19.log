SELECT
  p.sku,
  p.path,
  p.brand,
  p.series,
  p.model,
  p.name,
  pk.name AS kind,
  MAX(CASE WHEN pp.key = 'size' THEN pp.value_text END) AS size,
  MAX(CASE WHEN pp.key = 'color_family' THEN pp.value_text END) AS color_family
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand = 'Uvex'
  AND p.series = 'Uvex Industrial'
  AND p.model = 'uvex 2KV-937'
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name
ORDER BY p.sku;
