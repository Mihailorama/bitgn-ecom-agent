[32mOUT[0m: /bin/sql <<'SQL'
WITH vienna_stores AS (
  SELECT id, path, name
  FROM stores
  WHERE city = 'Vienna'
)
SELECT
  vs.id AS store_id,
  vs.path AS store_path,
  vs.name AS store_name,
  COALESCE(i.available_today, 0) AS available_today,
  (
    SELECT SUM(COALESCE(i2.available_today, 0))
    FROM vienna_stores vs2
    LEFT JOIN inventory i2
      ON i2.store_id = vs2.id
     AND i2.sku = 'SFE-3DBHYCR3'
  ) AS total_available_today
FROM vienna_stores vs
LEFT JOIN inventory i
  ON i.store_id = vs.id
 AND i.sku = 'SFE-3DBHYCR3'
ORDER BY vs.id;
