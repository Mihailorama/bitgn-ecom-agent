SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind,
       pp.key, pp.value_text, pp.value_number
FROM products p
LEFT JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand = 'Makita'
  AND (
    p.series = 'XGT DHS 22O-UB5'
    OR p.model = 'XGT DHS 22O-UB5'
    OR p.name LIKE '%XGT DHS 22O-UB5%'
    OR p.name LIKE '%Workshop Drill Grinder and Sander%'
  )
ORDER BY p.sku, pp.key;
