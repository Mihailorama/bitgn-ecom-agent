[32mOUT[0m: /bin/sql <<'SQL'
WITH props AS (
  SELECT sku,
         MAX(CASE WHEN key='machine_type' THEN value_text END) AS machine_type,
         MAX(CASE WHEN key='power_w' THEN CAST(value_number AS INTEGER) END) AS power_w,
         MAX(CASE WHEN key='working_width_mm' THEN CAST(value_number AS INTEGER) END) AS working_width_mm,
         MAX(CASE WHEN key='voltage_v' THEN CAST(value_number AS INTEGER) END) AS voltage_v
  FROM product_properties
  GROUP BY sku
)
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       pr.machine_type, pr.power_w, pr.working_width_mm, pr.voltage_v
FROM products p
JOIN props pr ON pr.sku = p.sku
WHERE p.brand='Makita'
  AND p.series='XGT'
  AND p.model='DHS 22O-UB5'
  AND pr.machine_type='lathe'
  AND pr.power_w=500
  AND pr.working_width_mm=250
  AND pr.voltage_v=230
ORDER BY p.sku;

SELECT p.sku, p.path
FROM products p
JOIN product_properties pp ON pp.sku=p.sku
WHERE p.brand='Makita'
  AND p.series='XGT'
  AND p.model='DHS 22O-UB5'
  AND pp.key='voltage_v'
  AND CAST(pp.value_number AS INTEGER)=400
ORDER BY p.sku;
