Next step_5... Run a narrow Valeo-only product/properties query to confirm whether the requested 550mm multi-adapter Winter VF 1JR-UBR variant exists and get its sku/path. (20555 ms)
  [[32msafe[0m] tool='exec' path='/bin/sql' args=[] stdin="SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,\n       pp.key, pp.value_text, pp.value_number\nFROM products p\nLEFT JOIN product_properties pp ON pp.sku = p.sku\nWHERE lower(p.brand) = 'valeo'\n  AND lower(p.name) LIKE '%wiper blade%'\nORDER BY p.series, p.model, p.sku, pp.key;"
[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       pp.key, pp.value_text, pp.value_number
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand) = 'valeo'
  AND lower(p.name) LIKE '%wiper blade%'
ORDER BY p.series, p.model, p.sku, pp.key;
