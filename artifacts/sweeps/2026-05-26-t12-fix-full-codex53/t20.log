Next step_6... Query only Valeo + series/model Winter VF 1JR-UBR and return sku/path with length_mm and adapter_type properties. (13309 ms)
  [[32msafe[0m] tool='exec' path='/bin/sql' args=[] stdin="SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,\n       MAX(CASE WHEN pp.key='length_mm' THEN COALESCE(pp.value_number, CAST(pp.value_text AS REAL)) END) AS length_mm,\n       MAX(CASE WHEN pp.key='adapter_type' THEN pp.value_text END) AS adapter_type\nFROM products p\nLEFT JOIN product_properties pp ON pp.sku = p.sku\nWHERE lower(p.brand)='valeo'\n  AND lower(p.series)='winter vf'\n  AND lower(p.model)='1jr-ubr'\nGROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name\nORDER BY p.sku;"
[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       MAX(CASE WHEN pp.key='length_mm' THEN COALESCE(pp.value_number, CAST(pp.value_text AS REAL)) END) AS length_mm,
       MAX(CASE WHEN pp.key='adapter_type' THEN pp.value_text END) AS adapter_type
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand)='valeo'
  AND lower(p.series)='winter vf'
  AND lower(p.model)='1jr-ubr'
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
ORDER BY p.sku;
