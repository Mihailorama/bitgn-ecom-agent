Next step_7... Query Valeo products in series matching Winter VF and filter by properties length_mm=550 and adapter_type='multi adapter' to discover actual model/sku/path. (14985 ms)
  [[32msafe[0m] tool='exec' path='/bin/sql' args=[] stdin="SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,\n       MAX(CASE WHEN pp.key='length_mm' THEN COALESCE(pp.value_number, CAST(pp.value_text AS REAL)) END) AS length_mm,\n       MAX(CASE WHEN pp.key='adapter_type' THEN lower(pp.value_text) END) AS adapter_type\nFROM products p\nJOIN product_properties pp ON pp.sku = p.sku\nWHERE lower(p.brand)='valeo'\n  AND lower(p.series) LIKE '%winter vf%'\nGROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name\nHAVING length_mm = 550\n   AND adapter_type = 'multi adapter'\nORDER BY p.series, p.model, p.sku;"
[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       MAX(CASE WHEN pp.key='length_mm' THEN COALESCE(pp.value_number, CAST(pp.value_text AS REAL)) END) AS length_mm,
       MAX(CASE WHEN pp.key='adapter_type' THEN lower(pp.value_text) END) AS adapter_type
FROM products p
JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand)='valeo'
  AND lower(p.series) LIKE '%winter vf%'
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
