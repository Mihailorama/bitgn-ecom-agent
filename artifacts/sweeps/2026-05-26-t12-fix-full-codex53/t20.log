  [[32msafe[0m] tool='exec' path='/bin/sql' args=[] stdin="SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,\n       MAX(CASE WHEN pp.key='length_mm' THEN COALESCE(pp.value_number, CAST(pp.value_text AS REAL)) END) AS length_mm,\n       MAX(CASE WHEN pp.key='adapter_type' THEN pp.value_text END) AS adapter_type\nFROM products p\nJOIN product_properties pp ON pp.sku = p.sku\nWHERE p.brand = 'Valeo'\n  AND p.series = 'Valeo Winter VF'\n  AND p.model = '1JR-UBR'\n  AND p.name = 'Wiper Blade'\nGROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name\nHAVING length_mm = 550\n   AND adapter_type = 'multi adapter';"
[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       MAX(CASE WHEN pp.key='length_mm' THEN COALESCE(pp.value_number, CAST(pp.value_text AS REAL)) END) AS length_mm,
       MAX(CASE WHEN pp.key='adapter_type' THEN pp.value_text END) AS adapter_type
FROM products p
JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand = 'Valeo'
  AND p.series = 'Valeo Winter VF'
  AND p.model = '1JR-UBR'
  AND p.name = 'Wiper Blade'
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
HAVING length_mm = 550
   AND adapter_type = 'multi adapter';
