[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       MAX(CASE WHEN pp.key='protection_type' THEN pp.value_text END) AS protection_type,
       MAX(CASE WHEN pp.key='color_family' THEN pp.value_text END) AS color_family,
       MAX(CASE WHEN pp.key IN ('voice_control','supports_voice_control','voice_control_support') THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS voice_control_flag
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand='JSP'
  AND (p.series='Sonis EVO 2VP-6RD' OR p.model='Sonis EVO 2VP-6RD' OR p.name LIKE '%Sonis EVO 2VP-6RD%')
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
ORDER BY p.sku;
