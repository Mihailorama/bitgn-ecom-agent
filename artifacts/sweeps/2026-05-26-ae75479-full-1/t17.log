WITH target_product AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name
  FROM products p
  JOIN product_properties pp
    ON pp.sku = p.sku
  WHERE p.brand = 'Heco'
    AND (p.name LIKE '%Nut Bolt and Washer%' OR p.model LIKE '%3DW-64B%' OR p.series LIKE '%HECO%')
    AND pp.key = 'fastener_type'
    AND lower(pp.value_text) = 'threaded rod'
), graz_stores AS (
  SELECT id, path, name, city
  FROM stores
  WHERE city = 'Graz'
)
SELECT gs.id AS store_id,
       gs.path AS store_path,
       tp.sku,
       tp.path AS product_path,
       COALESCE(i.available_today, 0) AS available_today
FROM graz_stores gs
CROSS JOIN target_product tp
LEFT JOIN inventory i
  ON i.store_id = gs.id
 AND i.sku = tp.sku
ORDER BY gs.id, tp.sku;
