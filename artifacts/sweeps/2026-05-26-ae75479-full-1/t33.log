WITH target_products AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name
  FROM products p
  JOIN product_kinds k ON k.id = p.kind_id
  JOIN product_properties cf ON cf.sku = p.sku AND cf.key = 'color_family' AND cf.value_text = 'Yellow'
  JOIN product_properties lm ON lm.sku = p.sku AND lm.key = 'length_m' AND (
    lm.value_number = 3 OR lm.value_text IN ('3', '3 m', '3m')
  )
  JOIN product_properties ip ON ip.sku = p.sku AND ip.key = 'ip_rating' AND ip.value_text = 'IP20'
  WHERE p.brand = 'Hager'
    AND p.series = 'Hager Workshop'
    AND p.model = 'HAG 1RH-81U'
    AND k.name = 'Extension Cable'
)
SELECT s.path AS store_path,
       tp.path AS product_path,
       tp.sku,
       i.available_today
FROM stores s
JOIN inventory i ON i.store_id = s.id
JOIN target_products tp ON tp.sku = i.sku
WHERE s.city = 'Graz' AND s.is_open = 1
ORDER BY s.path;
