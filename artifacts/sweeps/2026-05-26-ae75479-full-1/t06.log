SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pp.key, pp.value_text, pp.value_number
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand) = 'sika'
  AND (
    lower(p.series) LIKE '%sika professional%'
    OR lower(p.model) LIKE '%28t-uv8%'
    OR lower(p.name) LIKE '%28t-uv8%'
  )
  AND pp.key IN ('sealant_type','color_family','volume_ml')
ORDER BY p.sku, pp.key;
