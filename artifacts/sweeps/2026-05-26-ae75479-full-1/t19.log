WITH graz_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Graz'
)
SELECT gs.path AS store_path,
       '/proc/catalog/storage/shelving_cabinets/STO-506I7GMV.json' AS product_path,
       COALESCE(i.available_today, 0) AS available_today,
       SUM(COALESCE(i.available_today, 0)) OVER () AS total_available_today
FROM graz_stores gs
LEFT JOIN inventory i
  ON i.store_id = gs.id
 AND i.sku = 'STO-506I7GMV'
ORDER BY gs.path;
