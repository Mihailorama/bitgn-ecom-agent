[32mOUT[0m: /bin/sql <<'SQL'
WITH target_product AS (
  SELECT DISTINCT p.sku, p.path
  FROM products p
  JOIN product_kinds k ON k.id = p.kind_id
  JOIN product_properties pp1 ON pp1.sku = p.sku AND pp1.key = 'storage_type' AND pp1.value_text = 'shelving unit'
  JOIN product_properties pp2 ON pp2.sku = p.sku AND pp2.key = 'color_family' AND pp2.value_text = 'Blue'
  WHERE p.brand = 'Keter'
    AND p.series = 'Keter Mobile'
    AND p.model = 'KET 3R8-36F'
    AND k.name = 'Shelving and Cabinet'
), graz_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Graz'
)
SELECT gs.path AS store_path,
       tp.path AS product_path,
       COALESCE(i.available_today, 0) AS available_today,
       (SELECT SUM(COALESCE(i2.available_today,0))
          FROM graz_stores gs2
          LEFT JOIN inventory i2 ON i2.store_id = gs2.id AND i2.sku = tp.sku) AS total_available_today
FROM graz_stores gs
CROSS JOIN target_product tp
LEFT JOIN inventory i ON i.store_id = gs.id AND i.sku = tp.sku
ORDER BY gs.path;
SQL
store_path,product_path,available_today,total_available_today
