WITH target_product AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_properties pp ON pp.sku = p.sku
  WHERE p.brand = 'Mascot'
    AND p.series = 'Mascot Advanced ACC 35W-IIS Work Jacket'
    AND p.name = 'Work Jacket'
    AND pp.key = 'color_family'
    AND pp.value_text = 'Black'
), vienna_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Vienna'
)
SELECT tp.path AS product_path,
       vs.path AS store_path,
       COALESCE(i.available_today, 0) AS store_available_today,
       SUM(COALESCE(i.available_today, 0)) OVER () AS total_available_today
FROM vienna_stores vs
CROSS JOIN target_product tp
LEFT JOIN inventory i
  ON i.store_id = vs.id
 AND i.sku = tp.sku
ORDER BY vs.path;
