SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       pp.key, pp.value_text, pp.value_number
FROM products p
JOIN product_properties pp ON pp.sku = p.sku
WHERE LOWER(p.brand) = LOWER('DeWalt')
  AND (p.series LIKE '%FlexVolt%' OR p.name LIKE '%FlexVolt%')
  AND (p.model = 'DCS 38Q-XAV' OR p.name LIKE '%DCS 38Q-XAV%')
  AND pp.key IN ('machine_type','voltage_v','power_w','tank_volume_l')
ORDER BY p.sku, pp.key;
