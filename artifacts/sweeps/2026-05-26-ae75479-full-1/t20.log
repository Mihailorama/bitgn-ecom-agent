[32mOUT[0m: /bin/sql <<'SQL'
WITH target_product AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_kinds pk ON pk.id = p.kind_id
  JOIN product_properties pp ON pp.sku = p.sku
  WHERE p.brand = 'Schneider Electric'
    AND p.series = 'Merten Acti'
    AND p.model = 'M5T-N4C'
    AND pk.name = 'Wiring Device'
    AND pp.key = 'device_type'
    AND pp.value_text = 'cable tie'
),
vienna_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Vienna'
)
SELECT
  tp.sku,
  tp.path AS product_path,
  vs.id AS store_id,
  vs.path AS store_path,
  COALESCE(i.available_today, 0) AS available_today,
  SUM(COALESCE(i.available_today, 0)) OVER () AS total_available_today
FROM target_product tp
CROSS JOIN vienna_stores vs
LEFT JOIN inventory i
  ON i.store_id = vs.id
 AND i.sku = tp.sku
ORDER BY vs.path;
