WITH candidates AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind_name
  FROM products p
  JOIN product_kinds pk ON pk.id = p.kind_id
  WHERE p.brand = 'Schneider Electric'
    AND pk.name = 'Wiring Device'
)
SELECT c.sku, c.path, c.brand, c.series, c.model, c.name, c.kind_name, pp.key, pp.value_text
FROM candidates c
LEFT JOIN product_properties pp ON pp.sku = c.sku
WHERE c.series LIKE '%Merten%'
   OR c.model LIKE '%M5T-N4C%'
   OR c.name LIKE '%Merten%'
   OR c.name LIKE '%M5T-N4C%'
   OR pp.value_text LIKE '%cable%'
   OR pp.value_text LIKE '%tie%'
ORDER BY c.path, pp.key;
