SELECT id, path, name, city, is_open FROM stores WHERE lower(city) LIKE '%salzburg%' OR lower(name) LIKE '%salzburg%' OR lower(name) LIKE '%station%' ORDER BY city, name;

WITH q AS (
  SELECT 'gardena' AS brand,'powermax 280-5fi' AS model,'manual garden tool' AS kind_name
  UNION ALL SELECT 'gorilla','grip 2zq-d83','adhesive and glue'
  UNION ALL SELECT 'holzmann','d 327-rr0','compressor and dust extractor'
  UNION ALL SELECT 'bahco','bah 3vz-sph','hammer measuring and cutting tool'
  UNION ALL SELECT '3m','securefit 2ce-b35','safety eyewear'
  UNION ALL SELECT 'ryobi','rlm 2kq-r4c','cordless saw and sander'
)
SELECT p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind_name, pp.key, pp.value_text
FROM q
JOIN products p ON lower(p.brand)=q.brand AND lower(p.model)=q.model
JOIN product_kinds pk ON pk.id=p.kind_id
LEFT JOIN product_properties pp ON pp.sku=p.sku
WHERE lower(pk.name)=q.kind_name
ORDER BY p.brand, p.model, p.sku, pp.key;
