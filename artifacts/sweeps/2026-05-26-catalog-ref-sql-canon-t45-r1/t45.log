WITH target_store AS (
  SELECT id, path, name, city
  FROM stores
  WHERE lower(name) LIKE '%salzburg%' AND lower(name) LIKE '%station%'
), requested AS (
  SELECT 'gardena' AS brand, 'Gardena Smart' AS series, 'PowerMax 280-5FI' AS model, 'Manual Garden Tool' AS kind_name, 'tool_type' AS k1, 'pruning saw' AS v1, NULL AS k2, NULL AS v2, NULL AS k3, NULL AS v3
  UNION ALL SELECT 'gorilla','Gorilla Crystal','Grip 2ZQ-D83','Adhesive and Glue','adhesive_type','contact adhesive',NULL,NULL,NULL,NULL
  UNION ALL SELECT 'holzmann','Holzmann Compact','D 327-RR0','Compressor and Dust Extractor','machine_type','compressor','voltage_v','230','power_w','3000'
  UNION ALL SELECT 'bahco','Bahco Workshop','BAH 3VZ-SPH','Hammer Measuring and Cutting Tool','tool_type','measuring tape',NULL,NULL,NULL,NULL
  UNION ALL SELECT '3M','3M Ventilated','SecureFit 2CE-B35','Safety Eyewear','lens_color','Clear','size','XL',NULL,NULL
  UNION ALL SELECT 'ryobi','Ryobi Precision','RLM 2KQ-R4C','Cordless Saw and Sander','tool_type','planer',NULL,NULL,NULL,NULL
)
SELECT
  ts.id AS store_id,
  ts.path AS store_path,
  ts.name AS store_name,
  p.sku,
  p.path AS product_path,
  p.brand,
  p.series,
  p.model,
  pk.name AS kind_name,
  pp1.key AS prop1_key, pp1.value_text AS prop1_val,
  pp2.key AS prop2_key, pp2.value_text AS prop2_val,
  pp3.key AS prop3_key, pp3.value_text AS prop3_val,
  i.available_today
FROM requested r
JOIN products p
  ON lower(p.brand)=lower(r.brand)
 AND lower(p.series)=lower(r.series)
 AND lower(p.model)=lower(r.model)
JOIN product_kinds pk ON pk.id=p.kind_id
JOIN product_properties pp1
  ON pp1.sku=p.sku AND lower(pp1.key)=lower(r.k1) AND lower(pp1.value_text)=lower(r.v1)
LEFT JOIN product_properties pp2
  ON r.k2 IS NOT NULL AND pp2.sku=p.sku AND lower(pp2.key)=lower(r.k2) AND lower(pp2.value_text)=lower(r.v2)
LEFT JOIN product_properties pp3
  ON r.k3 IS NOT NULL AND pp3.sku=p.sku AND lower(pp3.key)=lower(r.k3) AND lower(pp3.value_text)=lower(r.v3)
JOIN target_store ts
JOIN inventory i ON i.store_id=ts.id AND i.sku=p.sku
WHERE lower(pk.name)=lower(r.kind_name)
ORDER BY p.brand, p.series, p.model, p.sku;
