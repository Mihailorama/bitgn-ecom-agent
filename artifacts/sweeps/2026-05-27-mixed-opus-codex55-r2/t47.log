WITH active_store AS (
  SELECT e.id AS employee_id, e.path AS employee_path, s.id AS store_id, s.path AS store_path
  FROM employees e
  JOIN stores s ON s.id = e.store_id
  WHERE e.id = 'emp_016'
), candidates AS (
  SELECT '4gfU5' AS rowid, 4 AS req_qty, p.*
  FROM products p
  WHERE p.brand = 'Husqvarna' AND (p.name LIKE '%Trimmer%' OR p.name LIKE '%Blower%' OR p.model LIKE '%2ID%' OR p.series LIKE '%Compact%')
  UNION ALL
  SELECT '3WiNF', 3, p.*
  FROM products p
  WHERE p.brand = 'DeWalt' AND (p.name LIKE '%Angle Grinder%' OR p.model LIKE '%2BH%' OR p.series LIKE '%Professional%')
  UNION ALL
  SELECT 'EdBNN', 5, p.*
  FROM products p
  WHERE p.brand = 'Keter' AND (p.name LIKE '%Storage Bin%' OR p.name LIKE '%Organizer%' OR p.model LIKE '%99Z%' OR p.series LIKE '%Stack%')
  UNION ALL
  SELECT '6t12J', 1, p.*
  FROM products p
  WHERE p.brand = 'Makita' AND (p.name LIKE '%Saw%' OR p.name LIKE '%Sander%' OR p.model LIKE '%26V%' OR p.series LIKE '%Precision%')
  UNION ALL
  SELECT 'U3Ppb', 6, p.*
  FROM products p
  WHERE p.brand = 'Ceresit' AND (p.name LIKE '%Adhesive%' OR p.name LIKE '%Glue%' OR p.model LIKE '%OY1%' OR p.series LIKE '%Universal%')
)
SELECT
  c.rowid,
  c.req_qty,
  ast.employee_path,
  ast.store_path,
  c.sku,
  c.path AS product_path,
  c.brand,
  c.series,
  c.model,
  pk.name AS kind_name,
  c.name,
  pp.key,
  pp.value_text,
  pp.value_number,
  i.available_today
FROM candidates c
CROSS JOIN active_store ast
LEFT JOIN product_kinds pk ON pk.id = c.kind_id
LEFT JOIN product_properties pp ON pp.sku = c.sku
LEFT JOIN inventory i ON i.store_id = ast.store_id AND i.sku = c.sku
ORDER BY c.rowid, c.sku, pp.key;
