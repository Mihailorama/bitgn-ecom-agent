WITH active_store AS (
  SELECT e.id AS employee_id, e.path AS employee_path, s.id AS store_id, s.path AS store_path
  FROM employees e
  JOIN stores s ON s.id = e.store_id
  WHERE e.id = 'emp_016'
), requested(rowid, req_qty, brand, series, model, kind_name) AS (
  VALUES
    ('4gfU5',4,'Husqvarna','Compact','435 2ID-D4H','Trimmer and Blower'),
    ('3WiNF',3,'DeWalt','Professional','DCG 2BH-302','Corded Angle Grinder'),
    ('EdBNN',5,'Keter','Compact Stack','99Z-RIS','Storage Bin and Organizer'),
    ('6t12J',1,'Makita','Precision','DDF 26V-AVZ','Cordless Saw and Sander'),
    ('U3Ppb',6,'Ceresit','Universal CT','OY1-0BK','Adhesive and Glue')
), exact_candidates AS (
  SELECT r.rowid, r.req_qty, p.sku, p.path AS product_path
  FROM requested r
  JOIN products p ON p.brand = r.brand AND p.series = r.series AND p.model = r.model
  JOIN product_kinds pk ON pk.id = p.kind_id AND pk.name = r.kind_name
  WHERE (
    r.rowid = '4gfU5'
    AND EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key='tool_type' AND pp.value_text='grass trimmer')
    AND EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key='power_source' AND pp.value_text='petrol')
    AND EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key='cutting_width_cm' AND pp.value_number=18)
  ) OR (
    r.rowid = '3WiNF'
    AND EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key='disc_diameter_mm' AND pp.value_number=150)
    AND EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key='power_w' AND pp.value_number=1500)
    AND EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key='disc_diameter_mm' AND pp.value_number=125)
  ) OR (
    r.rowid = 'EdBNN'
    AND EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key='storage_type' AND pp.value_text='stacking box')
    AND EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key='color_family' AND pp.value_text='Blue')
  ) OR (
    r.rowid = '6t12J'
    AND EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key='tool_type' AND pp.value_text='jigsaw')
    AND EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key='voltage_v' AND pp.value_number=36)
  ) OR (
    r.rowid = 'U3Ppb'
    AND EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key='adhesive_type' AND pp.value_text='mounting adhesive')
    AND EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key='color_family' AND pp.value_text='White')
  )
)
SELECT
  r.rowid,
  r.req_qty,
  ast.employee_path,
  ast.store_path,
  ec.sku,
  ec.product_path,
  COALESCE(i.available_today, 0) AS available_today,
  GROUP_CONCAT(pp.key || '=' || pp.value_text, '; ') AS properties
FROM requested r
CROSS JOIN active_store ast
LEFT JOIN exact_candidates ec ON ec.rowid = r.rowid
LEFT JOIN inventory i ON i.store_id = ast.store_id AND i.sku = ec.sku
LEFT JOIN product_properties pp ON pp.sku = ec.sku
GROUP BY r.rowid, r.req_qty, ast.employee_path, ast.store_path, ec.sku, ec.product_path, i.available_today
ORDER BY CASE r.rowid WHEN '4gfU5' THEN 1 WHEN '3WiNF' THEN 2 WHEN 'EdBNN' THEN 3 WHEN '6t12J' THEN 4 WHEN 'U3Ppb' THEN 5 END;
