WITH active_store AS (
  SELECT e.path AS employee_path, s.id AS store_id, s.path AS store_path
  FROM employees e
  JOIN stores s ON s.id = e.store_id
  WHERE e.id = 'emp_016'
), candidates AS (
  SELECT 'EdBNN' AS rowid, 5 AS req_qty, p.*
  FROM products p
  JOIN product_kinds pk ON pk.id = p.kind_id
  WHERE p.brand = 'Keter'
    AND (p.series LIKE '%Compact%' OR p.series LIKE '%Stack%' OR p.model LIKE '%99Z%' OR p.name LIKE '%Storage Bin%' OR p.name LIKE '%Organizer%')
  UNION ALL
  SELECT 'U3Ppb' AS rowid, 6 AS req_qty, p.*
  FROM products p
  JOIN product_kinds pk ON pk.id = p.kind_id
  WHERE p.brand = 'Ceresit'
    AND (p.series LIKE '%Universal%' OR p.model LIKE '%OY1%' OR p.name LIKE '%Adhesive%' OR p.name LIKE '%Glue%')
)
SELECT
  c.rowid,
  c.req_qty,
  ast.employee_path,
  ast.store_path,
  c.sku,
  c.path AS product_path,
  c.brand,
  c.series,
  c.model,
  pk.name AS kind_name,
  c.name,
  COALESCE(i.available_today,0) AS available_today,
  GROUP_CONCAT(pp.key || '=' || pp.value_text, '; ') AS properties
FROM candidates c
CROSS JOIN active_store ast
JOIN product_kinds pk ON pk.id = c.kind_id
LEFT JOIN inventory i ON i.store_id = ast.store_id AND i.sku = c.sku
LEFT JOIN product_properties pp ON pp.sku = c.sku
GROUP BY c.rowid, c.req_qty, ast.employee_path, ast.store_path, c.sku, c.path, c.brand, c.series, c.model, pk.name, c.name, i.available_today
ORDER BY c.rowid, c.sku;
