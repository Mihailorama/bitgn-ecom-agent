       MAX(CASE WHEN pp.key='cleaner_type' THEN pp.value_text END) AS cleaner_type
FROM products p
JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand)='ajax'
  AND lower(p.name) LIKE '%cleaning liquid%'
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
HAVING lower(MAX(CASE WHEN pp.key='cleaner_type' THEN pp.value_text END))='degreaser'
   AND lower(p.series) LIKE '%eco classic%'
   AND lower(p.model) LIKE '%25c-dxe%';

WITH target AS (
  SELECT p.sku
  FROM products p
  JOIN product_properties pp ON pp.sku = p.sku
  WHERE lower(p.brand)='ajax'
    AND lower(p.name) LIKE '%cleaning liquid%'
