), vienna AS (
  SELECT id, path FROM stores WHERE lower(city)='vienna'
)
SELECT COALESCE(SUM(COALESCE(i.available_today,0)),0) AS total_available_today
FROM vienna v
LEFT JOIN inventory i ON i.store_id = v.id
LEFT JOIN target t ON t.sku = i.sku;
