WITH target_product AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_properties pp_type
    ON pp_type.sku = p.sku
   AND pp_type.key = 'sealant_type'
   AND lower(pp_type.value_text) = 'silicone sealant'
  JOIN product_properties pp_color
    ON pp_color.sku = p.sku
   AND pp_color.key = 'color_family'
   AND lower(pp_color.value_text) = 'clear'
  WHERE lower(p.brand) = 'sika'
    AND lower(p.kind_id) IN (lower(p.kind_id))
    AND (
      lower(p.series) LIKE '%sika professional%'
      OR lower(p.name) LIKE '%sika professional%'
    )
    AND (
      lower(p.model) LIKE '%28t-uv8%'
      OR lower(p.name) LIKE '%28t-uv8%'
    )
    AND lower(p.name) LIKE '%sealant%'
)
SELECT
  tp.sku,
  tp.path AS product_path,
  s.id AS store_id,
  s.path AS store_path,
  COALESCE(i.available_today, 0) AS available_today
FROM stores s
CROSS JOIN target_product tp
LEFT JOIN inventory i
  ON i.store_id = s.id
 AND i.sku = tp.sku
WHERE lower(s.city) = 'graz'
ORDER BY s.path;
