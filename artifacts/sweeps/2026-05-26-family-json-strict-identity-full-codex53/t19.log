), target_product AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name
  FROM products p
  JOIN product_properties pg ON pg.sku = p.sku AND pg.key='garment_type' AND lower(pg.value_text)='t-shirt'
  JOIN product_properties pc ON pc.sku = p.sku AND pc.key='color_family' AND lower(pc.value_text)='yellow'
  WHERE lower(p.brand)='dickies'
    AND lower(p.series)='dickies fleece redhawk'
    AND lower(p.model)='mrb-wye'
    AND lower(p.name)='work top'
)
SELECT 'store' AS row_type, vs.id AS id_or_sku, vs.path, vs.city, NULL AS brand, NULL AS series, NULL AS model, NULL AS name
FROM vienna_stores vs
UNION ALL
SELECT 'product' AS row_type, tp.sku AS id_or_sku, tp.path, NULL AS city, tp.brand, tp.series, tp.model, tp.name
FROM target_product tp
ORDER BY row_type, path;
