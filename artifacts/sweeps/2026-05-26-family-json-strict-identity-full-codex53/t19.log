WITH target_product AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_properties pp_garment
    ON pp_garment.sku = p.sku
   AND pp_garment.key = 'garment_type'
   AND lower(pp_garment.value_text) = 't-shirt'
  JOIN product_properties pp_color
    ON pp_color.sku = p.sku
   AND pp_color.key = 'color_family'
   AND lower(pp_color.value_text) = 'yellow'
  WHERE lower(p.brand) = 'dickies'
    AND lower(p.series) = 'dickies fleece redhawk'
    AND lower(p.model) = 'mrb-wye'
    AND lower(p.name) = 'work top'
), vienna_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Vienna'
)
SELECT
  vs.path AS store_path,
  tp.path AS product_path,
  tp.sku,
  COALESCE(i.available_today, 0) AS available_today
FROM vienna_stores vs
CROSS JOIN target_product tp
LEFT JOIN inventory i
  ON i.store_id = vs.id
 AND i.sku = tp.sku
ORDER BY vs.path;
