WITH target_product AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_kinds k ON k.id = p.kind_id
  JOIN product_properties pp ON pp.sku = p.sku
  WHERE lower(p.brand) = 'irwin'
    AND lower(p.series) = 'irwin professional vise-grip'
    AND lower(p.model) = '1ha-73r'
    AND lower(k.name) = 'pliers and wrenches'
    AND lower(pp.key) = 'tool_type'
    AND lower(pp.value_text) = 'socket wrench'
), graz_stores AS (
  SELECT id, path
  FROM stores
  WHERE lower(city) = 'graz'
)
SELECT gs.path AS store_path,
       tp.path AS product_path,
       COALESCE(i.available_today, 0) AS available_today,
       (SELECT SUM(COALESCE(i2.available_today,0))
        FROM graz_stores gs2
        LEFT JOIN inventory i2
          ON i2.store_id = gs2.id
         AND i2.sku = tp.sku) AS total_available_today
FROM graz_stores gs
CROSS JOIN target_product tp
LEFT JOIN inventory i
  ON i.store_id = gs.id
 AND i.sku = tp.sku
ORDER BY gs.path;
