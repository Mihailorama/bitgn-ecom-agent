WITH graz_candidates AS (
  SELECT id, path, name, city
  FROM stores
  WHERE lower(city) LIKE '%graz%'
), irwin_candidates AS (
  SELECT p.sku,
         p.path,
         p.brand,
         p.series,
         p.model,
         k.name AS kind_name
  FROM products p
  JOIN product_kinds k ON k.id = p.kind_id
  WHERE lower(p.brand) = 'irwin'
    AND (
      lower(p.series) LIKE '%vise-grip%'
      OR lower(p.model) LIKE '%1ha-73r%'
      OR lower(p.name) LIKE '%1ha-73r%'
    )
)
SELECT 'STORE' AS row_type,
       gc.path AS path,
       gc.id AS id_or_sku,
       gc.city AS c1,
       gc.name AS c2,
       NULL AS c3,
       NULL AS c4
FROM graz_candidates gc
UNION ALL
SELECT 'PRODUCT' AS row_type,
       ic.path AS path,
       ic.sku AS id_or_sku,
       ic.brand AS c1,
       ic.series AS c2,
       ic.model AS c3,
       ic.kind_name AS c4
FROM irwin_candidates ic
UNION ALL
SELECT 'PROP' AS row_type,
       ic.path AS path,
       pp.sku AS id_or_sku,
       pp.key AS c1,
       pp.value_text AS c2,
       COALESCE(CAST(pp.value_number AS TEXT),'') AS c3,
       '' AS c4
FROM irwin_candidates ic
JOIN product_properties pp ON pp.sku = ic.sku
WHERE lower(pp.key) LIKE '%tool%'
   OR lower(pp.value_text) LIKE '%socket%'
ORDER BY row_type, path, id_or_sku;
