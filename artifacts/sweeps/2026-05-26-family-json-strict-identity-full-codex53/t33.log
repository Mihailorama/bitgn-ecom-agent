[32mOUT[0m: /bin/sql <<'SQL'
WITH candidates AS (
  SELECT p.sku, p.path AS product_path, p.brand, p.series, p.model, p.name,
         pk.name AS kind_name
  FROM products p
  LEFT JOIN product_kinds pk ON pk.id = p.kind_id
  WHERE lower(p.brand) = 'milwaukee'
    AND (
      lower(p.series) LIKE '%professional fuel nrg-onk%'
      OR lower(p.name) LIKE '%professional fuel nrg-onk%'
      OR lower(p.name) LIKE '%cordless drill driver%'
    )
)
SELECT c.sku, c.product_path, c.kind_name, pp.key, pp.value_text
FROM candidates c
LEFT JOIN product_properties pp ON pp.sku = c.sku
ORDER BY c.sku, pp.key;
