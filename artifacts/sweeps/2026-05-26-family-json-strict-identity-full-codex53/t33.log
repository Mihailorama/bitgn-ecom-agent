WITH target_products AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_properties v ON v.sku = p.sku AND v.key = 'voltage' AND lower(v.value_text) = '18 v'
  JOIN product_properties bp ON bp.sku = p.sku AND bp.key = 'battery_platform' AND lower(bp.value_text) = '18v-system'
  JOIN product_properties kc ON kc.sku = p.sku AND kc.key = 'kit_contents' AND lower(kc.value_text) = 'bare tool'
  WHERE lower(p.brand) = 'milwaukee'
    AND lower(p.series) = 'professional fuel nrg-onk'
    AND lower(p.kind_id) IN (SELECT lower(id) FROM product_kinds WHERE lower(name) = 'cordless drill driver')
    AND lower(p.name) LIKE '%cordless drill driver%'
), vienna_inventory AS (
  SELECT s.path AS store_path, tp.path AS product_path, i.available_today
  FROM target_products tp
  JOIN inventory i ON i.sku = tp.sku
  JOIN stores s ON s.id = i.store_id
  WHERE lower(s.city) = 'vienna'
)
SELECT product_path, store_path, available_today
FROM vienna_inventory
ORDER BY store_path;
