SELECT p.sku, p.path, p.brand, p.series, p.model, pk.name AS product_kind,
       pp_type.value_text AS type_value,
       pp_color.value_text AS color_family
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN product_properties pp_type
  ON pp_type.sku = p.sku AND pp_type.key IN ('product_type','tool_type','type')
LEFT JOIN product_properties pp_color
  ON pp_color.sku = p.sku AND pp_color.key = 'color_family'
WHERE lower(p.brand) = 'den braven'
  AND lower(p.series) = lower('Den Braven Weatherproof DB 1U7-4EX Tape and Foam')
  AND lower(pk.name) = 'masking tape'
  AND lower(COALESCE(pp_color.value_text,'')) = 'clear'
ORDER BY p.sku;
