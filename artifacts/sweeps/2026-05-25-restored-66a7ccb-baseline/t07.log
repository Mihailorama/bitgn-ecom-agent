SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pp.key, pp.value_text, pp.value_number
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand) = 'raaco'
  AND (
    lower(p.series) LIKE '%carrylite%'
    OR lower(p.model) LIKE '%1qb-902%'
    OR lower(p.name) LIKE '%carrylite%'
    OR lower(p.name) LIKE '%1qb-902%'
  )
ORDER BY p.sku, pp.key;
