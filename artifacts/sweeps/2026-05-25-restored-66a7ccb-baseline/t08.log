SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       pp.key, pp.value_text, pp.value_number
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand) = 'ryobi'
  AND (
    lower(p.series) LIKE '%max power%'
    OR lower(p.model) LIKE '%rcs 3fx-qdi%'
    OR lower(p.name) LIKE '%cordless saw and sander%'
  )
  AND (
    pp.key IN ('tool_type','voltage_v','battery_platform','kit_contents')
    OR pp.key IS NULL
  )
ORDER BY p.sku, pp.key;
