[32mOUT[0m: /bin/sql <<'SQL'
WITH graz_stores AS (
  SELECT id, path, name, city
  FROM stores
  WHERE city = 'Graz'
), candidate_products AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind
  FROM products p
  JOIN product_kinds pk ON pk.id = p.kind_id
  WHERE p.brand = 'Rust-Oleum'
    AND pk.name = 'Wood Stain and Deck Oil'
    AND (
      p.series LIKE '%Exterior%'
      OR p.model LIKE '%RO 38D-69D%'
      OR p.name LIKE '%RO 38D-69D%'
      OR p.name LIKE '%Wood Stain and Deck Oil%'
    )
)
SELECT 'STORE' AS row_type,
       gs.id AS store_id,
       gs.path AS store_path,
       gs.name AS store_name,
       gs.city,
       NULL AS sku,
       NULL AS product_path,
       NULL AS brand,
       NULL AS series,
       NULL AS model,
       NULL AS product_name,
       NULL AS kind,
       NULL AS prop_key,
       NULL AS prop_value
FROM graz_stores gs
UNION ALL
SELECT 'PRODUCT' AS row_type,
       NULL AS store_id,
       NULL AS store_path,
       NULL AS store_name,
       NULL AS city,
       cp.sku,
       cp.path AS product_path,
       cp.brand,
       cp.series,
       cp.model,
       cp.name AS product_name,
       cp.kind,
       pp.key AS prop_key,
       pp.value_text AS prop_value
FROM candidate_products cp
LEFT JOIN product_properties pp ON pp.sku = cp.sku
ORDER BY row_type, store_id, sku, prop_key;
