WITH base AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name
  FROM products p
  WHERE p.brand='Einhell'
    AND (p.series='Professional' OR p.name LIKE '%Professional%')
    AND (p.model='GC 2VB-YVV' OR p.name LIKE '%GC 2VB-YVV%')
    AND p.name LIKE '%Workshop Drill Grinder and Sander%'
), props AS (
  SELECT b.sku, b.path,
         MAX(CASE WHEN pp.key IN ('machine_type','tool_type') THEN pp.value_text END) AS machine_type,
         MAX(CASE WHEN pp.key IN ('voltage_v','voltage') THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS voltage,
         MAX(CASE WHEN pp.key IN ('power_w','power') THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS power,
         MAX(CASE WHEN pp.key IN ('wifi_enabled','wifi','wireless') THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS wifi_capability
  FROM base b
  LEFT JOIN product_properties pp ON pp.sku=b.sku
  GROUP BY b.sku, b.path
)
SELECT *
FROM props
WHERE machine_type='belt sander' AND (voltage='230' OR voltage='230 V') AND (power='250' OR power='250 W');
