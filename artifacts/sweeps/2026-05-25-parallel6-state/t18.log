[32mOUT[0m: /bin/sql <<'SQL'
SELECT s.path AS store_path,
       COALESCE(i.available_today, 0) AS available_today,
       totals.total_available
FROM stores s
LEFT JOIN inventory i
  ON i.store_id = s.id
 AND i.sku = 'WRK-2F0C5CUL'
CROSS JOIN (
  SELECT COALESCE(SUM(COALESCE(i2.available_today,0)),0) AS total_available
  FROM stores s2
  LEFT JOIN inventory i2
    ON i2.store_id = s2.id
   AND i2.sku = 'WRK-2F0C5CUL'
  WHERE s2.city = 'Vienna'
) totals
WHERE s.city = 'Vienna'
ORDER BY s.path;
