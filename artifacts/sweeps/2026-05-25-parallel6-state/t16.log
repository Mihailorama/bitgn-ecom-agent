SELECT id, path, name, city
FROM stores
WHERE lower(city) LIKE '%salzburg%'
   OR lower(name) LIKE '%salzburg%'
   OR lower(name) LIKE '%power%tool%'
ORDER BY city, name;

SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind_name,
       pp.key, COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) AS value
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand) IN ('milwaukee','bondex','makita','husqvarna','really useful box','hammerite')
   OR lower(p.name) LIKE '%2b6-rbf%'
   OR lower(p.name) LIKE '%28s-4ut%'
   OR lower(p.name) LIKE '%22o-ub5%'
   OR lower(p.name) LIKE '%3a7-co9%'
   OR lower(p.name) LIKE '%24u-3br%'
   OR lower(p.name) LIKE '%b5f-chg%'
   OR lower(p.model) LIKE '%2b6-rbf%'
   OR lower(p.model) LIKE '%28s-4ut%'
   OR lower(p.model) LIKE '%22o-ub5%'
   OR lower(p.model) LIKE '%3a7-co9%'
   OR lower(p.model) LIKE '%24u-3br%'
   OR lower(p.model) LIKE '%b5f-chg%'
ORDER BY p.brand, p.series, p.model, p.sku, pp.key;
