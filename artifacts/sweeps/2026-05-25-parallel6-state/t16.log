SELECT id, path, name, city
FROM stores
WHERE lower(city)='salzburg'
  AND lower(name) LIKE '%central%'
  AND lower(name) LIKE '%powertool%';

WITH requested(brand, series, model, kind_name, p1k, p1v, p2k, p2v, p3k, p3v, p4k, p4v, p5k, p5v) AS (
  VALUES
  ('Milwaukee','Heavy Duty PACKOUT','2B6-RBF','Tool Box and Bag','storage_type','tool box','color_family','Gray',NULL,NULL,NULL,NULL,NULL,NULL),
  ('Bondex','Eco Classic','28S-4UT','Wood Stain and Deck Oil','product_type','lacquer','color_family','Black',NULL,NULL,NULL,NULL,NULL,NULL),
  ('Makita','XGT DHS','22O-UB5','Workshop Drill Grinder and Sander','machine_type','lathe','voltage_v','230','power_w','500','working_width_mm','250',NULL,NULL),
  ('Husqvarna','Eco LC','3A7-CO9','Lawn Mower','power_source','manual','cutting_width_cm','32',NULL,NULL,NULL,NULL,NULL,NULL),
  ('Really Useful Box','Clear Lid Really','24U-3BR','Storage Bin and Organizer','storage_type','storage bin','color_family','Black',NULL,NULL,NULL,NULL,NULL,NULL),
  ('Hammerite','Direct to Rust Direct','B5F-CHG','Metal and Concrete Paint','product_type','facade paint','color_family','White',NULL,NULL,NULL,NULL,NULL,NULL)
)
SELECT r.brand, r.series, r.model, r.kind_name,
       p.sku, p.path,
       p.brand AS product_brand, p.series AS product_series, p.model AS product_model, p.name AS product_name,
       pk.name AS product_kind,
       MAX(CASE WHEN pp.key=r.p1k THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS prop1,
       MAX(CASE WHEN pp.key=r.p2k THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS prop2,
       MAX(CASE WHEN pp.key=r.p3k THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS prop3,
       MAX(CASE WHEN pp.key=r.p4k THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS prop4,
       MAX(CASE WHEN pp.key=r.p5k THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS prop5
FROM requested r
JOIN products p
  ON lower(p.brand)=lower(r.brand)
 AND lower(p.series)=lower(r.series)
 AND lower(p.model)=lower(r.model)
JOIN product_kinds pk ON pk.id=p.kind_id
LEFT JOIN product_properties pp ON pp.sku=p.sku
GROUP BY r.brand,r.series,r.model,r.kind_name,p.sku,p.path,p.brand,p.series,p.model,p.name,pk.name
ORDER BY r.brand,r.series,r.model,p.sku;
