[32mOUT[0m: /bin/sql <<'SQL'
WITH candidate AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_kinds k ON k.id = p.kind_id
  JOIN product_properties pp1 ON pp1.sku = p.sku AND pp1.key IN ('screw_type','screw type') AND lower(pp1.value_text) = 'wood screw'
  JOIN product_properties pp2 ON pp2.sku = p.sku AND pp2.key IN ('diameter_mm','diameter mm','diameter') AND (
    pp2.value_number = 6 OR lower(pp2.value_text) IN ('6','6 mm','6mm')
  )
  WHERE lower(p.brand) = 'heco'
    AND lower(k.name) = 'wood and drywall screw'
    AND lower(p.series) = lower('Heco Zinc Plated TopFix GTU-YPJ Wood and Drywall Screw')
)
SELECT s.id AS store_id, s.path AS store_path, c.sku, c.path AS product_path,
       COALESCE(i.available_today,0) AS available_today,
       (
         SELECT SUM(COALESCE(i2.available_today,0))
         FROM stores s2
         CROSS JOIN candidate c2
         LEFT JOIN inventory i2 ON i2.store_id = s2.id AND i2.sku = c2.sku
         WHERE lower(s2.city) = 'vienna'
       ) AS qty_all_vienna
FROM stores s
CROSS JOIN candidate c
LEFT JOIN inventory i ON i.store_id = s.id AND i.sku = c.sku
WHERE lower(s.city) = 'vienna'
ORDER BY s.id;
SQL
store_id,store_path,sku,product_path,available_today,qty_all_vienna
