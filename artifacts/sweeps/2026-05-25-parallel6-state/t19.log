[32mOUT[0m: /bin/sql <<'SQL'
WITH target_product AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_properties w ON w.sku = p.sku AND w.key IN ('wattage_w','wattage')
  JOIN product_properties l ON l.sku = p.sku AND l.key IN ('luminous_flux_lm','luminous_flux')
  WHERE p.brand = 'Osram'
    AND p.series = 'Eco Classic 3PW-R88'
    AND p.name = 'LED Bulb'
    AND (
      w.value_number = 15 OR w.value_text IN ('15','15 W','15W')
    )
    AND (
      l.value_number = 806 OR l.value_text IN ('806','806 lm','806lm')
    )
), graz_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Graz'
)
SELECT tp.path AS product_path,
       gs.path AS store_path,
       COALESCE(i.available_today,0) AS available_today,
       SUM(COALESCE(i.available_today,0)) OVER () AS total_available_today
FROM graz_stores gs
CROSS JOIN target_product tp
LEFT JOIN inventory i ON i.store_id = gs.id AND i.sku = tp.sku
ORDER BY gs.path;
SQL
product_path,store_path,available_today,total_available_today
