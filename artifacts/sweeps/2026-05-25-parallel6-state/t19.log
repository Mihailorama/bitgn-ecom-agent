[32mOUT[0m: /bin/sql <<'SQL'
WITH target AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_properties w ON w.sku = p.sku AND w.key = 'wattage_w'
  JOIN product_properties l ON l.sku = p.sku AND l.key = 'lumen'
  WHERE p.brand = 'Osram'
    AND p.series = 'Eco'
    AND p.model = 'Classic 3PW-R88'
    AND w.value_number = 15
    AND l.value_number = 806
), graz AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Graz'
)
SELECT t.path AS product_path,
       g.path AS store_path,
       COALESCE(i.available_today, 0) AS available_today,
       SUM(COALESCE(i.available_today, 0)) OVER () AS total_available_today
FROM graz g
CROSS JOIN target t
LEFT JOIN inventory i
  ON i.store_id = g.id
 AND i.sku = t.sku
ORDER BY g.path;
