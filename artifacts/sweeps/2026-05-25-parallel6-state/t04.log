[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind, pp.key, pp.value_text
FROM products p
LEFT JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE (p.brand = 'Den Braven' OR p.name LIKE '%Den Braven%' OR p.series LIKE '%Den Braven%')
  AND (p.series LIKE '%Universal Zwaluw UQC-XMO%' OR p.model LIKE '%Universal Zwaluw UQC-XMO%' OR p.name LIKE '%Universal Zwaluw UQC-XMO%')
ORDER BY p.sku, pp.key;
