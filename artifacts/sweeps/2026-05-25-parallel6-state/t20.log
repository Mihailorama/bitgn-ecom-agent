  [[32msafe[0m] tool='exec' path='/bin/sql' args=[] stdin="WITH helios_wall_paint AS (\n  SELECT p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind\n  FROM products p\n  JOIN product_kinds pk ON pk.id = p.kind_id\n  WHERE p.brand = 'Helios'\n    AND pk.name = 'Wall Paint'\n)\nSELECT h.sku,\n       h.path,\n       h.brand,\n       h.series,\n       h.model,\n       MAX(CASE WHEN pp.key='color_family' THEN pp.value_text END) AS color_family,\n       MAX(CASE WHEN pp.key='finish' THEN pp.value_text END) AS finish\nFROM helios_wall_paint h\nLEFT JOIN product_properties pp ON pp.sku = h.sku\nGROUP BY h.sku, h.path, h.brand, h.series, h.model\nORDER BY h.series, h.model, h.sku;"
[32mOUT[0m: /bin/sql <<'SQL'
WITH helios_wall_paint AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind
  FROM products p
  JOIN product_kinds pk ON pk.id = p.kind_id
  WHERE p.brand = 'Helios'
    AND pk.name = 'Wall Paint'
)
SELECT h.sku,
       h.path,
       h.brand,
       h.series,
       h.model,
       MAX(CASE WHEN pp.key='color_family' THEN pp.value_text END) AS color_family,
       MAX(CASE WHEN pp.key='finish' THEN pp.value_text END) AS finish
FROM helios_wall_paint h
LEFT JOIN product_properties pp ON pp.sku = h.sku
GROUP BY h.sku, h.path, h.brand, h.series, h.model
ORDER BY h.series, h.model, h.sku;
SQL
sku,path,brand,series,model,color_family,finish
