[32mOUT[0m: /bin/sql <<'SQL'
WITH target_product AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_properties pp_color ON pp_color.sku = p.sku AND pp_color.key = 'color_family' AND pp_color.value_text = 'Red'
  JOIN product_properties pp_finish ON pp_finish.sku = p.sku AND pp_finish.key = 'finish' AND pp_finish.value_text = 'eggshell'
  WHERE p.brand = 'Helios'
    AND p.series = 'Helios Eco Mobihel'
    AND p.model = '3MJ-ZFN'
    AND p.kind_id IN (SELECT id FROM product_kinds WHERE name = 'Wall Paint')
)
SELECT s.path AS store_path,
       tp.path AS product_path,
       COALESCE(i.available_today, 0) AS available_today
FROM stores s
CROSS JOIN target_product tp
LEFT JOIN inventory i ON i.store_id = s.id AND i.sku = tp.sku
WHERE s.city = 'Graz'
ORDER BY s.path;
