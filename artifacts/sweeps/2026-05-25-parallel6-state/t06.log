FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE (
  lower(p.brand) LIKE '%metabo%'
  OR lower(p.name) LIKE '%metabo%'
)
AND (
  lower(p.name) LIKE '%cordless drill driver%'
  OR lower(p.series) LIKE '%brushless bs 1ow-ik5%'
  OR lower(p.model) LIKE '%bs 1ow-ik5%'
)
ORDER BY p.sku, pp.key;
