WITH my_store AS (
  SELECT e.id AS employee_id, e.path AS employee_path, s.id AS store_id, s.path AS store_path
  FROM employees e
  JOIN stores s ON s.id = e.store_id
  WHERE e.id = 'emp_031'
), candidates AS (
  SELECT p.*, pk.name AS kind_name
  FROM products p
  JOIN product_kinds pk ON pk.id = p.kind_id
  WHERE p.brand IN ('Mascot','Sika','Bahco','Fiskars','Viega','Holzmann')
     OR p.name LIKE '%ACC 35W-IIS%'
     OR p.name LIKE '%Sika 28T-UV8%'
     OR p.name LIKE '%BAH 3VZ-SPH%'
     OR p.name LIKE '%1CD-A3X%'
     OR p.name LIKE '%Sanpress 2OG-ENN%'
     OR p.name LIKE '%327-RR0%'
     OR p.model IN ('ACC 35W-IIS','Sika 28T-UV8','BAH 3VZ-SPH','1CD-A3X','Sanpress 2OG-ENN','327-RR0')
)
SELECT
  ms.employee_path,
  ms.store_id,
  ms.store_path,
  c.sku,
  c.path AS product_path,
  c.brand,
  c.series,
  c.model,
  c.kind_name,
  c.name,
  COALESCE(i.available_today, 0) AS available_today,
  pp.key,
  pp.value_text,
  pp.value_number
FROM my_store ms
JOIN candidates c
LEFT JOIN inventory i ON i.store_id = ms.store_id AND i.sku = c.sku
LEFT JOIN product_properties pp ON pp.sku = c.sku
ORDER BY c.brand, c.series, c.model, c.sku, pp.key;
