[32mOUT[0m: /bin/sql <<'SQL'
WITH candidate_products AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind_name
  FROM products p
  JOIN product_kinds pk ON pk.id = p.kind_id
  WHERE lower(p.brand) = lower('Facom')
    AND lower(pk.name) = lower('Screwdriver and Hex Key Set')
    AND (lower(p.series) LIKE '%comfort grip r 26k-pfn%'
         OR lower(p.model) LIKE '%26k-pfn%'
         OR lower(p.name) LIKE '%comfort grip r 26k-pfn%')
), exact_products AS (
  SELECT cp.*
  FROM candidate_products cp
  JOIN product_properties pp ON pp.sku = cp.sku
  WHERE pp.key = 'tool_profile' AND lower(pp.value_text) = lower('pozidriv')
), graz_inventory AS (
  SELECT ep.sku, ep.path AS product_path, ep.brand, ep.series, ep.model, ep.name, ep.kind_name,
         s.id AS store_id, s.path AS store_path, s.name AS store_name, s.city,
         i.available_today
  FROM exact_products ep
  JOIN inventory i ON i.sku = ep.sku
  JOIN stores s ON s.id = i.store_id
  WHERE lower(s.city) = lower('Graz')
)
SELECT 'PRODUCT' AS row_type, ep.sku, ep.path, ep.brand, ep.series, ep.model, ep.name, ep.kind_name,
       pp.key, pp.value_text, NULL AS store_id, NULL AS store_path, NULL AS store_name, NULL AS city,
       NULL AS available_today, NULL AS total_available_today
FROM exact_products ep
JOIN product_properties pp ON pp.sku = ep.sku
UNION ALL
SELECT 'STORE_INVENTORY' AS row_type, gi.sku, gi.product_path, gi.brand, gi.series, gi.model, gi.name, gi.kind_name,
       NULL AS key, NULL AS value_text, gi.store_id, gi.store_path, gi.store_name, gi.city,
       gi.available_today, (SELECT SUM(available_today) FROM graz_inventory) AS total_available_today
FROM graz_inventory gi
ORDER BY row_type, sku, store_id, key;
