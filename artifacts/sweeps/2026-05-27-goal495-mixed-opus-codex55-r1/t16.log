)"
stores,"CREATE TABLE stores (
	id TEXT PRIMARY KEY,
	path TEXT NOT NULL,
	name TEXT NOT NULL,
	city TEXT NOT NULL,
	is_open INTEGER NOT NULL,
	lat REAL NOT NULL,
