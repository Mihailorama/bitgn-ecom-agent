[32mOUT[0m: /bin/sql <<'SQL'
WITH vienna_stores AS (
  SELECT id, path, name
  FROM stores
  WHERE city = 'Vienna'
),
product_candidates AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
         MAX(CASE WHEN pp.key='wattage_w' THEN COALESCE(pp.value_number, CAST(pp.value_text AS REAL)) END) AS wattage_w,
         MAX(CASE WHEN pp.key='luminous_flux_lm' THEN COALESCE(pp.value_number, CAST(pp.value_text AS REAL)) END) AS luminous_flux_lm,
         MAX(CASE WHEN pp.key='fitting' THEN pp.value_text END) AS fitting
  FROM products p
  JOIN product_properties pp ON pp.sku = p.sku
  WHERE p.brand = 'Osram'
    AND p.series = 'Warm Classic 2NL-Z7I'
    AND p.name LIKE '%LED Bulb%'
  GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
)
SELECT *
FROM product_candidates
WHERE wattage_w = 10
  AND luminous_flux_lm = 470
  AND fitting = 'E14'
ORDER BY sku;
