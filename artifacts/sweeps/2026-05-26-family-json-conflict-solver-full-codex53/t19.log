[32mOUT[0m: /bin/sql <<'SQL'
WITH target AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_properties w ON w.sku = p.sku AND w.key = 'wattage_w' AND COALESCE(w.value_number, CAST(w.value_text AS REAL)) = 10
  JOIN product_properties l ON l.sku = p.sku AND l.key = 'luminous_flux_lm' AND COALESCE(l.value_number, CAST(l.value_text AS REAL)) = 470
  JOIN product_properties f ON f.sku = p.sku AND f.key = 'fitting' AND f.value_text = 'E14'
  WHERE p.brand = 'Osram'
    AND p.series = 'Warm'
    AND p.model = 'Classic 2NL-Z7I'
    AND p.name LIKE '%LED Bulb%'
),
vienna AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Vienna'
)
SELECT v.path AS store_path,
       t.path AS product_path,
       COALESCE(i.available_today, 0) AS available_today,
       SUM(COALESCE(i.available_today, 0)) OVER () AS total_qty
FROM vienna v
CROSS JOIN target t
LEFT JOIN inventory i
  ON i.store_id = v.id
 AND i.sku = t.sku
ORDER BY v.path;
