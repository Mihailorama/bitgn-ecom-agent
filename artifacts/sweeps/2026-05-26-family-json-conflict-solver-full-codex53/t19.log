WITH vienna AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Vienna'
)
SELECT v.path AS store_path,
       '/proc/catalog/electrical/led_bulbs/ELC-OBJUYBUC.json' AS product_path,
       COALESCE(i.available_today, 0) AS available_today,
       SUM(COALESCE(i.available_today, 0)) OVER () AS total_qty
FROM vienna v
LEFT JOIN inventory i
  ON i.store_id = v.id
 AND i.sku = 'ELC-OBJUYBUC'
ORDER BY v.path;
