SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       pp.key, pp.value_text, pp.value_number
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand) = 'proxxon'
  AND (
    lower(p.series) LIKE '%bench micro 11h-xd8%'
    OR lower(p.model) LIKE '%11h-xd8%'
    OR lower(p.name) LIKE '%workshop drill grinder and sander%'
  )
ORDER BY p.sku, pp.key;
