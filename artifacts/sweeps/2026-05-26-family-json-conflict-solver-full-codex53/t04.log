SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
WHERE lower(p.brand) LIKE '%heco%'
   OR lower(p.series) LIKE '%heco%'
   OR lower(p.model) LIKE '%np7%'
   OR lower(p.name) LIKE '%anchor%'
ORDER BY p.brand, p.series, p.model, p.sku;
