  [[32msafe[0m] tool='exec' path='/bin/sql' args=[] stdin="SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,\n       at.value_text AS anchor_type,\n       d.value_number AS diameter_mm,\n       l.value_number AS length_mm,\n       pc.value_number AS pack_count\nFROM products p\nJOIN product_kinds pk ON pk.id = p.kind_id\nJOIN product_properties at ON at.sku = p.sku AND at.key = 'anchor_type'\nJOIN product_properties d  ON d.sku = p.sku  AND d.key  = 'diameter_mm'\nJOIN product_properties l  ON l.sku = p.sku  AND l.key  = 'length_mm'\nJOIN product_properties pc ON pc.sku = p.sku AND pc.key = 'pack_count'\nWHERE p.brand = 'Heco'\n  AND pk.name = 'Anchor and Wall Plug'\n  AND (lower(p.series) LIKE '%unix%' OR lower(p.model) LIKE '%np7%' OR lower(p.model) LIKE '%dbm%')\n  AND lower(at.value_text) = 'wall plug'\n  AND d.value_number = 5\n  AND l.value_number = 40\n  AND pc.value_number = 25\nORDER BY p.series, p.model, p.sku;"
[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       at.value_text AS anchor_type,
       d.value_number AS diameter_mm,
       l.value_number AS length_mm,
       pc.value_number AS pack_count
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
JOIN product_properties at ON at.sku = p.sku AND at.key = 'anchor_type'
JOIN product_properties d  ON d.sku = p.sku  AND d.key  = 'diameter_mm'
JOIN product_properties l  ON l.sku = p.sku  AND l.key  = 'length_mm'
JOIN product_properties pc ON pc.sku = p.sku AND pc.key = 'pack_count'
WHERE p.brand = 'Heco'
  AND pk.name = 'Anchor and Wall Plug'
  AND (lower(p.series) LIKE '%unix%' OR lower(p.model) LIKE '%np7%' OR lower(p.model) LIKE '%dbm%')
  AND lower(at.value_text) = 'wall plug'
  AND d.value_number = 5
  AND l.value_number = 40
  AND pc.value_number = 25
ORDER BY p.series, p.model, p.sku;
