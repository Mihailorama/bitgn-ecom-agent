SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind,
       pp1.value_text AS anchor_type,
       pp2.value_number AS diameter_mm,
       pp3.value_number AS length_mm,
       pp4.value_number AS pack_count
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN product_properties pp1 ON pp1.sku = p.sku AND pp1.key = 'anchor_type'
LEFT JOIN product_properties pp2 ON pp2.sku = p.sku AND pp2.key = 'diameter_mm'
LEFT JOIN product_properties pp3 ON pp3.sku = p.sku AND pp3.key = 'length_mm'
LEFT JOIN product_properties pp4 ON pp4.sku = p.sku AND pp4.key = 'pack_count'
WHERE p.brand = 'Heco'
  AND p.series = 'Heco Unix'
  AND p.model = 'HECO NP7-DBM'
  AND pk.name = 'Anchor and Wall Plug';
