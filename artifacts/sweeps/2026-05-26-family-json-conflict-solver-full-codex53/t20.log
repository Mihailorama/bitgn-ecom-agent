SELECT p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind,
       MAX(CASE WHEN pp.key IN ('wattage_w','wattage') THEN COALESCE(pp.value_number, CAST(pp.value_text AS REAL)) END) AS wattage,
       MAX(CASE WHEN pp.key IN ('luminous_flux_lm','luminous_flux') THEN COALESCE(pp.value_number, CAST(pp.value_text AS REAL)) END) AS luminous_flux
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand = 'Legrand'
  AND p.series = 'Eco Plexo'
  AND p.model = 'L8U-IV2'
  AND pk.name = 'LED Bulb'
GROUP BY p.sku, p.path, p.brand, p.series, p.model, pk.name
HAVING wattage = 15 AND luminous_flux = 806;
