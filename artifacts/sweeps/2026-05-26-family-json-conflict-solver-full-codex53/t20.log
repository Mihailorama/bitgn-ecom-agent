[32mOUT[0m: /bin/sql <<'SQL'
WITH target AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_kinds pk ON pk.id = p.kind_id
  JOIN product_properties w ON w.sku = p.sku AND w.key = 'wattage_w'
  JOIN product_properties l ON l.sku = p.sku AND l.key = 'lumen'
  WHERE p.brand = 'Legrand'
    AND p.series = 'Eco'
    AND p.model = 'Plexo L8U-IV2'
    AND pk.name = 'LED Bulb'
    AND COALESCE(w.value_number, CAST(w.value_text AS REAL)) = 15
    AND COALESCE(l.value_number, CAST(l.value_text AS REAL)) = 806
), vienna_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Vienna'
)
SELECT t.sku,
       t.path AS product_path,
       vs.path AS store_path,
       COALESCE(i.available_today, 0) AS store_available_today,
       (
         SELECT SUM(COALESCE(i2.available_today,0))
         FROM vienna_stores vs2
         LEFT JOIN inventory i2 ON i2.store_id = vs2.id AND i2.sku = t.sku
       ) AS total_available_today
FROM target t
CROSS JOIN vienna_stores vs
LEFT JOIN inventory i ON i.store_id = vs.id AND i.sku = t.sku
ORDER BY vs.path;
