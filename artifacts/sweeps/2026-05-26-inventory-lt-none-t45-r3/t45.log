[32mOUT[0m: /bin/sql <<'SQL'
WITH target_store AS (
  SELECT id, path
  FROM stores
  WHERE id = 'store_salzburg_elisabeth_vorstadt'
), target_skus AS (
  SELECT 'AUT-2U9RS1B3' AS sku UNION ALL
  SELECT 'GRD-20882ATT' UNION ALL
  SELECT 'GRD-J7SZGV8K' UNION ALL
  SELECT 'PNT-LL3H18J6' UNION ALL
  SELECT 'PWR-19KDUD1W' UNION ALL
  SELECT 'WRK-I5345IR9'
)
SELECT COUNT(*) AS low_stock_count
FROM target_skus s
CROSS JOIN target_store ts
LEFT JOIN inventory i
  ON i.store_id = ts.id AND i.sku = s.sku
WHERE COALESCE(i.available_today, 0) < 5;
