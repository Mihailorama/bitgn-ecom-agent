WITH target_store AS (
  SELECT id, path, name, city
  FROM stores
  WHERE lower(city) LIKE '%salzburg%'
     OR lower(name) LIKE '%salzburg%'
     OR lower(name) LIKE '%station%'
), req AS (
  SELECT 'castrol_cleaner' AS req_key, 'Castrol' AS brand, 'Workshop' AS series, 'MAGNATEC 213-NWR' AS model, 'Automotive Cleaner' AS kind UNION ALL
  SELECT 'karcher_trimmer_blower','Karcher','Professional','FC 33Z-7OP','Trimmer and Blower' UNION ALL
  SELECT 'gardena_manual_tool','Gardena','PowerMax','EasyCut 2KS-5HO','Manual Garden Tool' UNION ALL
  SELECT 'sikkens_wall_paint','Sikkens','Professional','Rubbol 1EP-LF5','Wall Paint' UNION ALL
  SELECT 'makita_cordless_saw_sander','Makita','Precision','DDF 26V-AVZ','Cordless Saw and Sander' UNION ALL
  SELECT 'uvex_work_jacket','Uvex','Bionic','x-fit Y59-F8N','Work Jacket'
), base AS (
  SELECT r.req_key, p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind_name
  FROM req r
  JOIN products p
    ON p.brand = r.brand AND p.series = r.series AND p.model = r.model
  JOIN product_kinds pk
    ON pk.id = p.kind_id
  WHERE pk.name = r.kind
), props AS (
  SELECT b.req_key, b.sku,
         MAX(CASE WHEN pp.key='cleaner_type' THEN pp.value_text END) AS cleaner_type,
         MAX(CASE WHEN pp.key='volume_ml' THEN COALESCE(pp.value_number, CAST(pp.value_text AS REAL)) END) AS volume_ml,
         MAX(CASE WHEN pp.key='tool_type' THEN pp.value_text END) AS tool_type,
         MAX(CASE WHEN pp.key='power_source' THEN pp.value_text END) AS power_source,
         MAX(CASE WHEN pp.key='cutting_width_cm' THEN COALESCE(pp.value_number, CAST(pp.value_text AS REAL)) END) AS cutting_width_cm,
         MAX(CASE WHEN pp.key='length_mm' THEN COALESCE(pp.value_number, CAST(pp.value_text AS REAL)) END) AS length_mm,
         MAX(CASE WHEN pp.key='color_family' THEN pp.value_text END) AS color_family,
         MAX(CASE WHEN pp.key='finish' THEN pp.value_text END) AS finish,
         MAX(CASE WHEN pp.key='voltage_v' THEN COALESCE(pp.value_number, CAST(pp.value_text AS REAL)) END) AS voltage_v,
         MAX(CASE WHEN pp.key='size' THEN pp.value_text END) AS size,
         MAX(CASE WHEN pp.key='fit' THEN pp.value_text END) AS fit
  FROM base b
  JOIN product_properties pp ON pp.sku = b.sku
  GROUP BY b.req_key, b.sku
)
SELECT ts.id AS store_id, ts.path AS store_path, ts.name AS store_name, ts.city,
       b.req_key, b.sku, b.path AS product_path,
       pr.cleaner_type, pr.volume_ml, pr.tool_type, pr.power_source, pr.cutting_width_cm,
       pr.length_mm, pr.color_family, pr.finish, pr.voltage_v, pr.size, pr.fit,
       i.available_today
FROM target_store ts
CROSS JOIN base b
JOIN props pr ON pr.req_key = b.req_key AND pr.sku = b.sku
LEFT JOIN inventory i ON i.store_id = ts.id AND i.sku = b.sku
ORDER BY b.req_key, b.sku;
