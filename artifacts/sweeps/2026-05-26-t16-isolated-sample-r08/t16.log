)"
customers,"CREATE TABLE customers (
	id TEXT PRIMARY KEY,
	path TEXT NOT NULL,
	display_name TEXT NOT NULL,
	email TEXT NOT NULL,
	city TEXT NOT NULL,
	home_lat REAL NOT NULL,
	home_lon REAL NOT NULL
)"
employees,"CREATE TABLE employees (
	id TEXT PRIMARY KEY,
	path TEXT NOT NULL,
	display_name TEXT NOT NULL,
	email TEXT NOT NULL,
	title TEXT NOT NULL,
