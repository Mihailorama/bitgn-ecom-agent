SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind, pp.key, pp.value_text, pp.value_number
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand IN ('Heco','Mascot','Philips','Geberit','Gorilla','Mellerud')
  AND pk.name IN ('Nut Bolt and Washer','Work Jacket','LED Bulb','Valve and Connector','Adhesive and Glue','Cleaning Liquid')
  AND (
    p.series LIKE '%Unix%' OR p.model LIKE '%2VD-VNA%' OR
    p.series LIKE '%Advanced%' OR p.model LIKE '%35W-IIS%' OR
    p.series LIKE '%Professional Hue%' OR p.model LIKE '%3JS-MSN%' OR
    p.series LIKE '%Mapress Silent%' OR p.model LIKE '%IC5-GU6%' OR
    p.series LIKE '%Crystal Grip%' OR p.model LIKE '%2ZQ-D83%' OR
    p.series LIKE '%Bio%' OR p.model LIKE '%233-MOB%'
  )
  AND (
    pp.key IS NULL OR pp.key IN (
      'fastener_type','color_family','connector_type','adhesive_type','cleaner_type',
      'wattage','wattage_w','luminous_flux','luminous_flux_lm'
    )
  )
ORDER BY p.brand, pk.name, p.series, p.model, p.sku, pp.key;
