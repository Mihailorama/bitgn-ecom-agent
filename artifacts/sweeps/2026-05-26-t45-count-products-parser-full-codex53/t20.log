WITH graz_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Graz'
)
SELECT gs.path AS store_path,
       COALESCE(i.available_today, 0) AS available_today,
       (
         SELECT COALESCE(SUM(COALESCE(i2.available_today,0)),0)
         FROM graz_stores gs2
         LEFT JOIN inventory i2
           ON i2.store_id = gs2.id
          AND i2.sku = 'HND-1PA2DPAI'
       ) AS total_available_today
FROM graz_stores gs
LEFT JOIN inventory i
  ON i.store_id = gs.id
 AND i.sku = 'HND-1PA2DPAI'
ORDER BY gs.path;
