SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       MAX(CASE WHEN pp.key='storage_type' THEN pp.value_text END) AS storage_type,
       MAX(CASE WHEN pp.key='color_family' THEN pp.value_text END) AS color_family,
       MAX(CASE WHEN pp.key='volume_l' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS volume_l
FROM products p
JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand = 'Raaco'
  AND p.series = 'Raaco Stackable Assorter 20C-L8E'
  AND p.kind_id IN (SELECT id FROM product_kinds WHERE name = 'Storage Bin and Organizer')
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
HAVING MAX(CASE WHEN pp.key='storage_type' THEN pp.value_text END) = 'storage bin'
