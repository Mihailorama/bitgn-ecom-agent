       pp.key, pp.value_text, pp.value_number
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand) = 'carhartt'
  AND (lower(p.series) LIKE '%lightweight duck%' OR lower(p.name) LIKE '%lightweight duck%')
  AND (lower(p.model) = '2vs-evp' OR lower(p.name) LIKE '%2vs-evp%')
  AND lower(p.name) LIKE '%work jacket%'
ORDER BY p.sku, pp.key;
