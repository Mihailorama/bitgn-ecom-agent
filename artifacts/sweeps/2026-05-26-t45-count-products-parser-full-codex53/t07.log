SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind_name, pp.key, pp.value_text, pp.value_number
FROM products p
LEFT JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE (p.brand LIKE '%Tesa%' OR p.name LIKE '%Tesa%')
  AND (p.series LIKE '%Powerbond%' OR p.model LIKE '%1RD-FPW%' OR p.name LIKE '%Powerbond%' OR p.name LIKE '%1RD-FPW%')
ORDER BY p.sku, pp.key;
