WITH heco_candidates AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, k.name AS kind_name
  FROM products p
  JOIN product_kinds k ON k.id = p.kind_id
  WHERE lower(p.brand)=lower('Heco')
    AND lower(k.name)=lower('Nut Bolt and Washer')
)
SELECT hc.sku, hc.path, hc.brand, hc.series, hc.model, hc.name, hc.kind_name,
       pp.key, pp.value_text, pp.value_number
FROM heco_candidates hc
LEFT JOIN product_properties pp ON pp.sku = hc.sku
ORDER BY hc.series, hc.model, hc.sku, pp.key;
