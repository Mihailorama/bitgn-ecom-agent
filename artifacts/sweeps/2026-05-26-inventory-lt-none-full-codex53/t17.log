WITH target_product AS (
  SELECT p.sku, p.path AS product_path
  FROM products p
  JOIN product_kinds k ON k.id = p.kind_id
  JOIN product_properties pp ON pp.sku = p.sku
  WHERE lower(p.brand) = lower('Heco')
    AND lower(k.name) = lower('Nut Bolt and Washer')
    AND lower(p.series) = lower('Heco Zinc Plated')
    AND lower(p.model) = lower('HECO 3DW-64B')
    AND lower(pp.key) = 'fastener_type'
    AND lower(pp.value_text) = lower('threaded rod')
), graz_stores AS (
  SELECT id, path
  FROM stores
  WHERE lower(city) = lower('Graz')
)
SELECT 'PRODUCT' AS row_type, tp.sku AS sku, tp.product_path AS path, NULL AS store_id, NULL AS available_today
FROM target_product tp
UNION ALL
SELECT 'STORE' AS row_type, tp.sku AS sku, gs.path AS path, gs.id AS store_id,
       COALESCE(i.available_today, 0) AS available_today
FROM graz_stores gs
CROSS JOIN target_product tp
LEFT JOIN inventory i ON i.store_id = gs.id AND i.sku = tp.sku
UNION ALL
SELECT 'TOTAL' AS row_type, tp.sku AS sku, tp.product_path AS path, NULL AS store_id,
       COALESCE(SUM(COALESCE(i.available_today, 0)), 0) AS available_today
FROM graz_stores gs
CROSS JOIN target_product tp
LEFT JOIN inventory i ON i.store_id = gs.id AND i.sku = tp.sku;
