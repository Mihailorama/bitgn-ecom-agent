[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       MAX(CASE WHEN pp.key IN ('disc_diameter_mm','disc_diameter') THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS disc_diameter,
       MAX(CASE WHEN pp.key IN ('power_w','power') THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS power_w,
       MAX(CASE WHEN pp.key IN ('wifi_enabled','wifi','wireless') THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS wifi_prop
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand = 'Einhell'
  AND (p.series = 'Einhell Workshop' OR p.name LIKE '%Einhell Workshop%')
  AND p.model = 'TE 2NA-IZ4'
  AND (p.name LIKE '%Corded Angle Grinder%' OR p.kind_id IN (
      SELECT id FROM product_kinds WHERE name = 'Corded Angle Grinder'
  ))
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
ORDER BY p.sku;
