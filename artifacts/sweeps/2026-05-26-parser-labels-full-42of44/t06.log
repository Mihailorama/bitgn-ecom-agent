SELECT p.sku, p.path, p.brand, p.series, p.model,
       MAX(CASE WHEN pp.key='storage_type' THEN pp.value_text END) AS storage_type,
       MAX(CASE WHEN pp.key='color_family' THEN pp.value_text END) AS color_family
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand='Keter'
  AND (p.series='Deep Stack' OR p.name LIKE '%Deep Stack%')
  AND (p.model='2OO-VJU' OR p.name LIKE '%2OO-VJU%')
GROUP BY p.sku, p.path, p.brand, p.series, p.model
ORDER BY p.sku;
