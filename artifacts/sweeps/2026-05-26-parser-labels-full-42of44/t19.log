[32mOUT[0m: /bin/sql <<'SQL'
WITH graz_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Graz'
),
per_store AS (
  SELECT gs.id,
         gs.path,
         COALESCE(SUM(i.available_today), 0) AS available_today
  FROM graz_stores gs
  LEFT JOIN inventory i
    ON i.store_id = gs.id
   AND i.sku = 'PNT-TUX2S5U6'
  GROUP BY gs.id, gs.path
)
SELECT path,
       available_today,
       (SELECT SUM(available_today) FROM per_store) AS total_available_today
FROM per_store
ORDER BY path;
