[32mOUT[0m: /bin/sql <<'SQL'
WITH vienna_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Vienna'
), per_store AS (
  SELECT vs.path AS store_path,
         COALESCE(i.available_today, 0) AS available_today
  FROM vienna_stores vs
  LEFT JOIN inventory i
    ON i.store_id = vs.id
   AND i.sku = 'ADH-1OFQ65WN'
)
SELECT store_path, available_today
FROM per_store
ORDER BY store_path;

SELECT COALESCE(SUM(COALESCE(i.available_today, 0)), 0) AS total_available_today
FROM stores s
LEFT JOIN inventory i
  ON i.store_id = s.id
 AND i.sku = 'ADH-1OFQ65WN'
WHERE s.city = 'Vienna';
SQL
