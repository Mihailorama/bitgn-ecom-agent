SELECT p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind,
       MAX(CASE WHEN pp.key='adhesive_type' THEN pp.value_text END) AS adhesive_type,
       MAX(CASE WHEN pp.key='color_family' THEN pp.value_text END) AS color_family
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand='Bostik'
  AND p.series='Bostik Professional'
  AND p.model='BST 30G-CNL'
  AND pk.name='Adhesive and Glue'
GROUP BY p.sku, p.path, p.brand, p.series, p.model, pk.name
HAVING adhesive_type='mounting adhesive' AND color_family='Clear';
