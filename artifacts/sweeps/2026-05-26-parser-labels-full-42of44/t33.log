       i.available_today,
       SUM(i.available_today) OVER () AS total_available_today
FROM inventory i
JOIN stores s ON s.id = i.store_id
WHERE s.city = 'Graz'
  AND s.is_open = 1
  AND i.sku = 'MAC-1F7EUVFL'
  AND i.available_today > 0
ORDER BY s.path;
