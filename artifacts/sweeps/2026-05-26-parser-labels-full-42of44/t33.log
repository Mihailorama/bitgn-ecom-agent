[32mOUT[0m: /bin/sql <<'SQL'
WITH candidate_products AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name
  FROM products p
  WHERE lower(p.brand) = 'makita'
    AND (
      lower(p.name) LIKE '%workshop drill grinder and sander%'
      OR lower(p.series) LIKE '%workshop%'
      OR lower(p.model) LIKE '%ddf oie-yyp%'
      OR lower(p.series) LIKE '%ddf oie-yyp%'
    )
)
SELECT cp.sku, cp.path, cp.brand, cp.series, cp.model, cp.name,
       pp.key, pp.value_text, pp.value_number
FROM candidate_products cp
LEFT JOIN product_properties pp ON pp.sku = cp.sku
ORDER BY cp.sku, pp.key;
