SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN families f ON f.id = p.family_id
WHERE lower(p.brand) LIKE '%wago%'
  AND (
    lower(p.series) LIKE '%compact 222%'
    OR lower(f.series) LIKE '%compact 222%'
    OR lower(p.name) LIKE '%compact 222%'
  )
  AND (
    lower(p.model) LIKE '%3v7-gbq%'
    OR lower(f.model) LIKE '%3v7-gbq%'
    OR lower(p.name) LIKE '%3v7-gbq%'
  )
  AND (
    lower(pk.name) LIKE '%extension cable%'
    OR lower(p.name) LIKE '%extension cable%'
  )
ORDER BY p.sku;
