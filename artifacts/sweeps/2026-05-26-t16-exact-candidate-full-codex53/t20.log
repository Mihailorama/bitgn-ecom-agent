WITH graz_like AS (
  SELECT id, path, name, city
  FROM stores
  WHERE lower(city) LIKE '%graz%'
), bahco_candidates AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
         MAX(CASE WHEN pp.key='tool_type' THEN pp.value_text END) AS tool_type,
         MAX(CASE WHEN pp.key IN ('length_mm','length') THEN COALESCE(pp.value_number, CAST(pp.value_text AS REAL)) END) AS length_val
  FROM products p
  JOIN product_kinds pk ON pk.id = p.kind_id
  LEFT JOIN product_properties pp ON pp.sku = p.sku
  WHERE p.brand='Bahco'
    AND pk.name='Pliers and Wrenches'
    AND (p.series LIKE '%Heavy Duty%' OR p.model LIKE '%XSS-SSH%' OR p.name LIKE '%XSS-SSH%')
  GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
)
SELECT 'STORE' AS row_type, g.id, g.path, g.name, g.city,
       NULL AS sku, NULL AS product_path, NULL AS product_name, NULL AS tool_type, NULL AS length_val
FROM graz_like g
UNION ALL
SELECT 'PRODUCT' AS row_type, NULL, NULL, NULL, NULL,
       b.sku, b.path, b.name, b.tool_type, b.length_val
FROM bahco_candidates b
ORDER BY row_type, id, sku;
