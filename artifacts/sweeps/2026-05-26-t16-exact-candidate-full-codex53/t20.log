WITH graz_stores AS (
  SELECT id, path, name, city
  FROM stores
  WHERE city='Graz'
), candidate_products AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
         MAX(CASE WHEN pp.key='tool_type' THEN pp.value_text END) AS tool_type,
         MAX(CASE WHEN pp.key='length_mm' THEN COALESCE(pp.value_number, CAST(pp.value_text AS REAL)) END) AS length_mm
  FROM products p
  JOIN product_properties pp ON pp.sku = p.sku
  WHERE p.brand='Bahco'
    AND p.series='Heavy Duty S XSS-SSH'
    AND p.kind_id IN (SELECT id FROM product_kinds WHERE name='Pliers and Wrenches')
  GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
)
SELECT gs.id AS store_id, gs.path AS store_path, gs.name AS store_name, gs.city,
       cp.sku, cp.path AS product_path, cp.name AS product_name, cp.tool_type, cp.length_mm,
       COALESCE(i.available_today,0) AS available_today
FROM graz_stores gs
CROSS JOIN candidate_products cp
LEFT JOIN inventory i ON i.store_id = gs.id AND i.sku = cp.sku
WHERE cp.tool_type='water pump pliers' AND cp.length_mm=200
ORDER BY gs.id, cp.sku;
