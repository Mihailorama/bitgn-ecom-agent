WITH actor_store AS (
  SELECT e.store_id
  FROM employees e
  WHERE e.id = 'emp_026'
),
input_rows(row_id, brand, series, model, kind_name, req_qty) AS (
  VALUES
    ('ZjhCT','Bosch','Bench','IXO 3JP-JOU','Workshop Saw and Cutter',2),
    ('AX5RW','Wiha','VDE','VDE 13X-B49','Screwdriver and Hex Key Set',2),
    ('ZzGvd','Fischer','SX','SX 7UY-G03','Anchor and Wall Plug',5),
    ('5vKAA','Holzmann','Compact','D 327-RR0','Compressor and Dust Extractor',2),
    ('asAY5','Helios','Professional','Helios 29A-FTE','Metal and Concrete Paint',1)
),
required_props(row_id, key, value_text, value_number) AS (
  VALUES
    ('ZjhCT','machine_type','table saw',NULL),
    ('ZjhCT','voltage_v',NULL,400),
    ('AX5RW','tool_profile','pozidriv',NULL),
    ('ZzGvd','anchor_type','concrete anchor',NULL),
    ('ZzGvd','diameter_mm',NULL,5),
    ('5vKAA','machine_type','compressor',NULL),
    ('5vKAA','voltage_v',NULL,230),
    ('5vKAA','power_w',NULL,1500),
    ('5vKAA','power_w',NULL,3000),
    ('asAY5','product_type','metal paint',NULL),
    ('asAY5','color_family','Green',NULL),
    ('asAY5','color_family','white',NULL)
)
SELECT
  r.row_id,
  p.sku,
  p.path AS product_path,
  p.brand,
  p.series,
  p.model,
  k.name AS kind_name,
  pp.key,
  pp.value_text,
  pp.value_number,
  i.available_today,
  s.path AS store_path
FROM input_rows r
JOIN products p
  ON p.brand = r.brand
 AND p.series = r.series
 AND p.model = r.model
JOIN product_kinds k
  ON k.id = p.kind_id
 AND k.name = r.kind_name
LEFT JOIN product_properties pp
  ON pp.sku = p.sku
LEFT JOIN inventory i
  ON i.sku = p.sku
 AND i.store_id = (SELECT store_id FROM actor_store)
LEFT JOIN stores s
  ON s.id = (SELECT store_id FROM actor_store)
ORDER BY r.row_id, p.sku, pp.key;
