WITH actor_store AS (
  SELECT e.store_id
  FROM employees e
  WHERE e.id = 'emp_026'
),
input_rows(row_id, ord, brand, series, model, kind_name, req_qty) AS (
  VALUES
    ('ZjhCT',1,'Bosch','Bench','IXO 3JP-JOU','Workshop Saw and Cutter',2),
    ('AX5RW',2,'Wiha','VDE','VDE 13X-B49','Screwdriver and Hex Key Set',2),
    ('ZzGvd',3,'Fischer','SX','SX 7UY-G03','Anchor and Wall Plug',5),
    ('5vKAA',4,'Holzmann','Compact','D 327-RR0','Compressor and Dust Extractor',2),
    ('asAY5',5,'Helios','Professional','Helios 29A-FTE','Metal and Concrete Paint',1)
),
required_props(row_id, key, value_text, value_number) AS (
  VALUES
    ('ZjhCT','machine_type','table saw',NULL),
    ('ZjhCT','voltage_v',NULL,400),
    ('AX5RW','tool_profile','pozidriv',NULL),
    ('ZzGvd','anchor_type','concrete anchor',NULL),
    ('ZzGvd','diameter_mm',NULL,5),
    ('5vKAA','machine_type','compressor',NULL),
    ('5vKAA','voltage_v',NULL,230),
    ('5vKAA','power_w',NULL,1500),
    ('5vKAA','power_w',NULL,3000),
    ('asAY5','product_type','metal paint',NULL),
    ('asAY5','color_family','Green',NULL),
    ('asAY5','color_family','white',NULL)
),
base_candidates AS (
  SELECT r.row_id, r.ord, r.req_qty, p.sku
  FROM input_rows r
  JOIN products p
    ON p.brand = r.brand
   AND p.series = r.series
   AND p.model = r.model
  JOIN product_kinds k
    ON k.id = p.kind_id
   AND k.name = r.kind_name
),
matched_candidates AS (
  SELECT bc.row_id, bc.ord, bc.req_qty, bc.sku,
         COUNT(rp.key) AS needed,
         SUM(CASE WHEN pp.sku IS NOT NULL THEN 1 ELSE 0 END) AS matched
  FROM base_candidates bc
  JOIN required_props rp
    ON rp.row_id = bc.row_id
  LEFT JOIN product_properties pp
    ON pp.sku = bc.sku
   AND pp.key = rp.key
   AND (
        (rp.value_text IS NOT NULL AND lower(pp.value_text) = lower(rp.value_text))
        OR
        (rp.value_number IS NOT NULL AND pp.value_number = rp.value_number)
   )
  GROUP BY bc.row_id, bc.ord, bc.req_qty, bc.sku
),
exact_matches AS (
  SELECT mc.row_id, mc.ord, mc.req_qty, mc.sku
  FROM matched_candidates mc
  WHERE mc.needed = mc.matched
),
unique_exact AS (
  SELECT em.row_id, em.ord, em.req_qty,
         CASE WHEN COUNT(*) = 1 THEN MIN(em.sku) END AS sku
  FROM exact_matches em
  GROUP BY em.row_id, em.ord, em.req_qty
)
SELECT
  r.row_id,
  u.sku,
  CASE WHEN u.sku IS NOT NULL THEN COALESCE(i.available_today,0) END AS in_stock,
  CASE
    WHEN u.sku IS NOT NULL AND COALESCE(i.available_today,0) >= r.req_qty THEN 'true'
    ELSE 'false'
  END AS match
FROM input_rows r
LEFT JOIN unique_exact u
  ON u.row_id = r.row_id
LEFT JOIN inventory i
  ON i.store_id = (SELECT store_id FROM actor_store)
 AND i.sku = u.sku
ORDER BY r.ord;
