[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       MAX(CASE WHEN pp.key='tool_type' THEN pp.value_text END) AS tool_type,
       GROUP_CONCAT(CASE WHEN pp.key='power_source' THEN pp.value_text END, '|') AS power_sources
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand='Ryobi'
  AND (p.series='Battery RLM ZL5-CL8' OR p.model='RLM ZL5-CL8' OR p.name LIKE '%Trimmer and Blower%')
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
ORDER BY p.sku;
