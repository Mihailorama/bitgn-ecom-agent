[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, pk.name AS kind, p.brand, p.series, p.model,
       MAX(CASE WHEN pp.key='fitting_type' THEN pp.value_text END) AS fitting_type,
       MAX(CASE WHEN pp.key='diameter_mm' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS diameter_mm,
       MAX(CASE WHEN pp.key='connection_type' THEN pp.value_text END) AS connection_type,
       MAX(CASE WHEN pp.key='thread_type' THEN pp.value_text END) AS thread_type
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
JOIN product_properties pp ON pp.sku = p.sku
WHERE pk.name = 'Pipe Fitting'
  AND p.brand = 'Uponor'
  AND p.series = 'Uponor Press Fit Aqua'
  AND p.model = '35M-6XO'
GROUP BY p.sku, p.path, pk.name, p.brand, p.series, p.model
HAVING fitting_type = 'pipe clamp'
   AND diameter_mm IN ('12','12.0','12 mm')
   AND connection_type = 'threaded'
   AND thread_type = '3/4 inch';
