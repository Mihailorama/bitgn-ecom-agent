WITH target_product AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_properties pp
    ON pp.sku = p.sku
  WHERE p.brand = 'Fiskars'
    AND p.series = 'Compact X'
    AND p.model = '2Z7-4OD'
    AND p.kind_id IN (SELECT id FROM product_kinds WHERE name = 'Chainsaw')
    AND pp.key = 'power_source'
    AND pp.value_text = 'corded'
), graz_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Graz'
)
SELECT gs.path AS store_path,
       tp.path AS product_path,
       COALESCE(i.available_today, 0) AS available_today
FROM graz_stores gs
CROSS JOIN target_product tp
LEFT JOIN inventory i
  ON i.store_id = gs.id
 AND i.sku = tp.sku
ORDER BY gs.path;
