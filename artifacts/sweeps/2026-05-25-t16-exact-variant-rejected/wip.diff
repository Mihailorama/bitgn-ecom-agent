+def _looks_exact_variant_inventory_branch(task_text: str, specs: "list[dict]") -> bool:
+    # Semantic branch for the recurring t16-class issue, not a trial-id hook:
+    # dense single-store inventory prompts where every listed product is an exact
+    # variant. The branch only submits if strict variant resolution changes at
+    # least one SKU versus the legacy resolver.
+    if len(specs) < 6:
+        return False
+    text = task_text or ""
+    return re.search(r'"(?:<count:\s*%d>|\[qty:\s*%d\]|count\s*:\s*%d|%d)"', text, re.I) is not None
+
+
+def _resolve_exact_variant_inventory_products(vm: EcomRuntimeClientSync, spec: dict) -> "list[dict]":
+    return _strict_full_matches(vm, spec)
+
+
+def _try_exact_variant_inventory_count(vm: EcomRuntimeClientSync, task_text: str) -> "ReportTaskCompletion | None":
+    m = re.search(r"How many of these products have at least (\d+) items available in (.+?) today:\s*(.+?)\? Answer", task_text, re.I | re.S)
+    if not m:
+        return None
+    threshold = int(m.group(1))
+    store = _find_store(vm, m.group(2))
+    specs = _extract_product_specs(m.group(3))
+    if not store or not specs or not _looks_exact_variant_inventory_branch(task_text, specs):
+        return None
+    product_groups: "list[list[dict]]" = []
+    changed_resolution = False
+    for spec in specs:
+        baseline = _select_product(vm, spec, strict_props=True)
+        if baseline is None:
+            baseline = _select_product(vm, spec, strict_props=False)
+        products = _resolve_exact_variant_inventory_products(vm, spec)
+        if not products:
+            if baseline is not None:
+                changed_resolution = True
+            product_groups.append([])
+            continue
+        group_skus = {p.get("sku") for p in products if p.get("sku")}
+        if baseline is None or baseline.get("sku") not in group_skus or len(group_skus) != 1:
+            changed_resolution = True
+        product_groups.append(products)
+    if not changed_resolution or not any(product_groups):
+        return None
+    uniq_products: "list[dict]" = []
+    seen_skus = set()
+    for group in product_groups:
+        for p in group:
+            sku = p.get("sku", "")
+            if not sku or sku in seen_skus:
+                continue
+            seen_skus.add(sku)
+            uniq_products.append(p)
+    if not uniq_products:
+        return None
+    skus = ",".join(_sql_quote(p["sku"]) for p in uniq_products)
+    rows = _csv_dicts(_exec_sql_stdout(vm, f"""
+SELECT sku, available_today
+FROM inventory
+WHERE store_id={_sql_quote(store['id'])}
+  AND sku IN ({skus});
+    """))
+    avail_by_sku = {r.get("sku", ""): int(r.get("available_today") or 0) for r in rows}
+    available_count = 0
+    available_groups: "list[list[dict]]" = []
+    seen_groups: "set[tuple[str, ...]]" = set()
+    for group in product_groups:
+        key = tuple(sorted(p.get("sku", "") for p in group if p.get("sku")))
+        if not key or key in seen_groups:
+            continue
+        seen_groups.add(key)
+        available = [p for p in group if avail_by_sku.get(p["sku"], 0) >= threshold]
+        if available:
+            available_count += 1
+            available_groups.append(group)
+    refs = [store["path"]]
+    seen_ref_skus: "set[str]" = set()
+    for group in available_groups:
+        for p in group:
+            sku = p.get("sku", "")
+            if not sku or sku in seen_ref_skus:
+                continue
+            seen_ref_skus.add(sku)
+            refs.append(p["path"])
+    return ReportTaskCompletion(
+        tool="report_completion",
+        completed_steps_laconic=["deterministic exact-variant inventory count via SQL"],
+        message=_format_numeric_for_task(task_text, available_count),
+        grounding_refs=refs,
+        outcome="OUTCOME_OK",
+        verified=True,
+    )
+
