[32mOUT[0m: /bin/sql <<'SQL'
WITH graz_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Graz'
), target_product AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_kinds k ON k.id = p.kind_id
  JOIN product_properties pp1 ON pp1.sku = p.sku AND pp1.key = 'fitting_type' AND lower(pp1.value_text) = 'pipe fitting'
  JOIN product_properties pp2 ON pp2.sku = p.sku AND pp2.key = 'diameter_mm' AND (
    pp2.value_number = 15 OR pp2.value_text = '15'
  )
  JOIN product_properties pp3 ON pp3.sku = p.sku AND pp3.key = 'connection_type' AND lower(pp3.value_text) = 'threaded'
  WHERE p.brand = 'Viega'
    AND p.series = 'Viega Professional Sanpress 2OG-ENN'
    AND k.name = 'Pipe Fitting'
)
SELECT
  tp.sku,
  tp.path AS product_path,
  gs.id AS store_id,
  gs.path AS store_path,
  COALESCE(i.available_today, 0) AS store_available_today,
  SUM(COALESCE(i.available_today, 0)) OVER () AS total_available_today
FROM graz_stores gs
CROSS JOIN target_product tp
LEFT JOIN inventory i
  ON i.store_id = gs.id
 AND i.sku = tp.sku
ORDER BY gs.id;
SQL
sku,product_path,store_id,store_path,store_available_today,total_available_today
