WITH graz_stores AS (
  SELECT id, path, name
  FROM stores
  WHERE city = 'Graz'
), viega_candidates AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, k.name AS kind_name
  FROM products p
  JOIN product_kinds k ON k.id = p.kind_id
  WHERE lower(p.brand) = 'viega'
    AND (
      lower(p.series) LIKE '%professional sanpress 2og-enn%'
      OR lower(p.model) LIKE '%2og-enn%'
      OR lower(p.name) LIKE '%2og-enn%'
    )
    AND lower(k.name) LIKE '%pipe fitting%'
)
SELECT 'STORE' AS row_type, gs.id, gs.path, gs.name, NULL AS sku, NULL AS product_path, NULL AS prop_key, NULL AS value_text, NULL AS value_number
FROM graz_stores gs
UNION ALL
SELECT 'PRODUCT_PROP' AS row_type, NULL, NULL, NULL, vc.sku, vc.path, pp.key, pp.value_text, pp.value_number
FROM viega_candidates vc
JOIN product_properties pp ON pp.sku = vc.sku
WHERE pp.key IN ('fitting_type','diameter_mm','diameter','connection_type')
ORDER BY row_type, id, sku, prop_key;
