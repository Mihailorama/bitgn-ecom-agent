[32mOUT[0m: /bin/sql <<'SQL'
SELECT s.path AS store_path,
       COALESCE(i.available_today, 0) AS available_today,
       SUM(COALESCE(i.available_today, 0)) OVER () AS total_available_today
FROM stores s
LEFT JOIN inventory i
  ON i.store_id = s.id
 AND i.sku = 'ELC-2ZYFBLJH'
WHERE s.city = 'Graz'
ORDER BY s.path;
