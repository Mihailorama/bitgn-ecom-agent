[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku,
       p.path,
       p.brand,
       p.series,
       p.model,
       p.name
FROM products p
JOIN product_properties w ON w.sku = p.sku AND w.key = 'wattage_w'
JOIN product_properties l ON l.sku = p.sku AND l.key = 'lumen'
JOIN product_properties f ON f.sku = p.sku AND f.key = 'fitting'
WHERE p.brand = 'Philips'
  AND p.series = 'CorePro'
  AND p.model = 'CorePro 2Z4-WXU'
  AND (w.value_number = 10 OR w.value_text IN ('10','10 W'))
  AND (l.value_number = 806 OR l.value_text IN ('806','806 lm'))
  AND f.value_text = 'GU10';
