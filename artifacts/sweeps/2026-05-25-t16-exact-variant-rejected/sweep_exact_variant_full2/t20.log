Next step_1... Query SQL to uniquely identify the Philips LED Bulb variant with wattage 10 W, luminous flux 806 lm, fitting GU10 and capture its product path. (24830 ms)
  [[32msafe[0m] tool='exec' path='/bin/sql' args=[] stdin="SELECT p.sku,\n       p.path,\n       p.brand,\n       p.series,\n       p.model,\n       p.name,\n       MAX(CASE WHEN pp.key='wattage_w' THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS wattage,\n       MAX(CASE WHEN pp.key='luminous_flux_lm' THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS luminous_flux,\n       MAX(CASE WHEN pp.key='fitting' THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS fitting\nFROM products p\nJOIN product_properties pp ON pp.sku = p.sku\nWHERE p.brand = 'Philips'\n  AND (p.name LIKE '%LED Bulb%' OR p.model LIKE '%LED Bulb%' OR p.series LIKE '%CorePro%' OR p.model LIKE '%CorePro%')\nGROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name\nHAVING SUM(CASE WHEN pp.key='wattage_w' AND (pp.value_text='10' OR pp.value_text='10 W' OR pp.value_number=10) THEN 1 ELSE 0 END) > 0\n   AND SUM(CASE WHEN pp.key='luminous_flux_lm' AND (pp.value_text='806' OR pp.value_text='806 lm' OR pp.value_number=806) THEN 1 ELSE 0 END) > 0\n   AND SUM(CASE WHEN pp.key='fitting' AND pp.value_text='GU10' THEN 1 ELSE 0 END) > 0;"
[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku,
       p.path,
       p.brand,
       p.series,
       p.model,
       p.name,
       MAX(CASE WHEN pp.key='wattage_w' THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS wattage,
       MAX(CASE WHEN pp.key='luminous_flux_lm' THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS luminous_flux,
       MAX(CASE WHEN pp.key='fitting' THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS fitting
FROM products p
JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand = 'Philips'
  AND (p.name LIKE '%LED Bulb%' OR p.model LIKE '%LED Bulb%' OR p.series LIKE '%CorePro%' OR p.model LIKE '%CorePro%')
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
HAVING SUM(CASE WHEN pp.key='wattage_w' AND (pp.value_text='10' OR pp.value_text='10 W' OR pp.value_number=10) THEN 1 ELSE 0 END) > 0
   AND SUM(CASE WHEN pp.key='luminous_flux_lm' AND (pp.value_text='806' OR pp.value_text='806 lm' OR pp.value_number=806) THEN 1 ELSE 0 END) > 0
   AND SUM(CASE WHEN pp.key='fitting' AND pp.value_text='GU10' THEN 1 ELSE 0 END) > 0;
