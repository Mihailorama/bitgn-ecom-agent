SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind, pp.key, COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) AS value
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE LOWER(p.brand) LIKE '%varta%'
  AND (
    LOWER(p.series) LIKE '%workshop%'
    OR LOWER(p.model) LIKE '%30z-3d8%'
    OR LOWER(p.name) LIKE '%30z-3d8%'
    OR LOWER(p.name) LIKE '%charger%'
    OR LOWER(p.name) LIKE '%bulb%'
    OR LOWER(pk.name) LIKE '%charger%'
    OR LOWER(pk.name) LIKE '%bulb%'
  )
ORDER BY p.sku, pp.key;
