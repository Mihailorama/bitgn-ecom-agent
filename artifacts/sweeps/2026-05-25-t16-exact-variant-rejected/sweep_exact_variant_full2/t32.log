  [[32msafe[0m] tool='exec' path='/bin/sql' args=[] stdin="SELECT\n  p.sku,\n  p.path,\n  p.brand,\n  p.series,\n  p.model,\n  p.name,\n  pk.name AS kind,\n  MAX(CASE WHEN pp.key='product_type' THEN pp.value_text END) AS product_type,\n  MAX(CASE WHEN pp.key='voltage_v' THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS voltage_v,\n  MAX(CASE WHEN pp.key IN ('voice_control','supports_voice_control','voice_control_supported') THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS voice_control,\n  GROUP_CONCAT(CASE WHEN pp.key LIKE '%voice%' THEN pp.key || '=' || COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END, ';') AS voice_keys_seen\nFROM products p\nJOIN product_kinds pk ON pk.id = p.kind_id\nJOIN product_properties pp ON pp.sku = p.sku\nWHERE p.brand='Varta'\n  AND p.series='Workshop'\n  AND p.model='Silver 30Z-3D8'\nGROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name\nHAVING kind='Automotive Charger and Bulb'\n   AND MAX(CASE WHEN pp.key='product_type' THEN pp.value_text END)='battery charger'\n   AND MAX(CASE WHEN pp.key='voltage_v' THEN CAST(COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) AS TEXT) END)='12'\nORDER BY p.sku;"
[32mOUT[0m: /bin/sql <<'SQL'
SELECT
  p.sku,
  p.path,
  p.brand,
  p.series,
  p.model,
  p.name,
  pk.name AS kind,
  MAX(CASE WHEN pp.key='product_type' THEN pp.value_text END) AS product_type,
  MAX(CASE WHEN pp.key='voltage_v' THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS voltage_v,
  MAX(CASE WHEN pp.key IN ('voice_control','supports_voice_control','voice_control_supported') THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS voice_control,
  GROUP_CONCAT(CASE WHEN pp.key LIKE '%voice%' THEN pp.key || '=' || COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END, ';') AS voice_keys_seen
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand='Varta'
  AND p.series='Workshop'
  AND p.model='Silver 30Z-3D8'
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name
HAVING kind='Automotive Charger and Bulb'
   AND MAX(CASE WHEN pp.key='product_type' THEN pp.value_text END)='battery charger'
   AND MAX(CASE WHEN pp.key='voltage_v' THEN CAST(COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) AS TEXT) END)='12'
ORDER BY p.sku;
