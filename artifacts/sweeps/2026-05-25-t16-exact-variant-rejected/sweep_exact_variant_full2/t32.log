[32mOUT[0m: /bin/sql <<'SQL'
SELECT
  p.sku,
  p.path,
  p.brand,
  p.series,
  p.model,
  p.name,
  pk.name AS kind,
  MAX(CASE WHEN pp.key IN ('product_type','tool_type','type') THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS product_type,
  MAX(CASE WHEN pp.key IN ('voltage_v','voltage','voltage_volts') THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS voltage,
  MAX(CASE WHEN pp.key IN ('voice_control','supports_voice_control') THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS voice_control
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand = 'Varta'
  AND p.series = 'Varta Workshop Silver'
  AND (p.model = '30Z-3D8' OR p.name LIKE '%30Z-3D8%')
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name
ORDER BY p.sku;
