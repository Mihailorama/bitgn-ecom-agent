WITH graz_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Graz'
), target_products AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_properties pp_type ON pp_type.sku = p.sku AND pp_type.key = 'product_type' AND lower(pp_type.value_text) = 'battery pack'
  JOIN product_properties pp_voltage ON pp_voltage.sku = p.sku AND pp_voltage.key = 'voltage_v' AND pp_voltage.value_number = 12
  JOIN product_properties pp_current ON pp_current.sku = p.sku AND pp_current.key = 'current_a' AND pp_current.value_number = 6
  WHERE p.brand = 'Shell'
    AND p.series = 'Shell Professional Advance 1PO-W67'
    AND p.kind_id IN (SELECT id FROM product_kinds WHERE lower(name) = 'automotive charger and bulb')
)
SELECT gs.path AS store_path,
       tp.path AS product_path,
       COALESCE(i.available_today, 0) AS available_today
FROM graz_stores gs
CROSS JOIN target_products tp
LEFT JOIN inventory i ON i.store_id = gs.id AND i.sku = tp.sku
ORDER BY gs.path;
