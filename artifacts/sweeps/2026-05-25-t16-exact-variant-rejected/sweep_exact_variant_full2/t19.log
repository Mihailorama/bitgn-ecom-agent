  SELECT id, path
  FROM stores
  WHERE city = 'Graz'
), per_store AS (
  SELECT gs.path AS store_path,
         COALESCE(i.available_today, 0) AS available_today
  FROM graz_stores gs
  LEFT JOIN inventory i
    ON i.store_id = gs.id
   AND i.sku = 'AUT-1NIE0Z8B'
)
