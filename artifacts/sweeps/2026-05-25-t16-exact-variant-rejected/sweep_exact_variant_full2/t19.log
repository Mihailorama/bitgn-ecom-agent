WITH shell_candidates AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind_name
  FROM products p
  JOIN product_kinds pk ON pk.id = p.kind_id
  WHERE p.brand = 'Shell'
    AND (
      lower(p.series) LIKE '%1po-w67%'
      OR lower(p.model) LIKE '%1po-w67%'
      OR lower(p.name) LIKE '%1po-w67%'
      OR lower(p.name) LIKE '%automotive charger%'
      OR lower(p.name) LIKE '%bulb%'
      OR lower(pk.name) LIKE '%automotive charger%'
      OR lower(pk.name) LIKE '%bulb%'
    )
)
SELECT sc.sku,
       sc.path,
       sc.series,
       sc.model,
       sc.name,
       sc.kind_name,
       pp.key,
       pp.value_text,
       pp.value_number
FROM shell_candidates sc
LEFT JOIN product_properties pp ON pp.sku = sc.sku
ORDER BY sc.sku, pp.key;
