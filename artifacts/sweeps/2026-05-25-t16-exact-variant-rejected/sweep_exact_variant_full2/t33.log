SELECT s.path AS store_path,
       p.path AS product_path,
       p.sku,
       i.available_today,
       totals.total_available_today
FROM inventory i
JOIN stores s ON s.id = i.store_id
JOIN products p ON p.sku = i.sku
JOIN (
  SELECT SUM(i2.available_today) AS total_available_today
  FROM inventory i2
  JOIN stores s2 ON s2.id = i2.store_id
  WHERE s2.city = 'Graz'
    AND i2.sku = 'PNT-OYI3I497'
) totals
WHERE s.city = 'Graz'
  AND i.sku = 'PNT-OYI3I497'
ORDER BY s.path;
