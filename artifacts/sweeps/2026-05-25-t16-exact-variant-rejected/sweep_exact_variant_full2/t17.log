WITH target_product AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_properties pp ON pp.sku = p.sku
  JOIN product_kinds pk ON pk.id = p.kind_id
  WHERE p.brand = 'Ajax'
    AND p.series = 'Eco Classic'
    AND p.model = '25C-DXE'
    AND pk.name = 'Cleaning Liquid'
    AND pp.key = 'cleaner_type'
    AND pp.value_text = 'degreaser'
)
SELECT s.id AS store_id,
       s.path AS store_path,
       tp.sku,
       tp.path AS product_path,
       COALESCE(i.available_today, 0) AS available_today
FROM stores s
CROSS JOIN target_product tp
LEFT JOIN inventory i
  ON i.store_id = s.id
 AND i.sku = tp.sku
WHERE s.city = 'Vienna'
ORDER BY s.id;
