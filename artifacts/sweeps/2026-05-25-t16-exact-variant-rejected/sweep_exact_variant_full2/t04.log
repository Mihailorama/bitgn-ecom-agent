[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind, p.name,
       MAX(CASE WHEN pp.key IN ('cleaner_type','cleaner type') THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS cleaner_type,
       MAX(CASE WHEN pp.key IN ('volume_ml','volume','volume ml') THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS volume
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand = 'WD-40'
  AND p.series = 'WD-40 Fast Action Smart'
  AND p.model = '28R-HIP'
  AND pk.name = 'Automotive Cleaner'
GROUP BY p.sku, p.path, p.brand, p.series, p.model, pk.name, p.name
HAVING LOWER(cleaner_type) = 'fuel additive'
   AND (volume = '500' OR LOWER(volume) IN ('500 ml','500ml'));
