[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path,
       MAX(CASE WHEN pp.key IN ('machine_type','tool_type') THEN pp.value_text END) AS machine_type,
       MAX(CASE WHEN pp.key IN ('voltage_v','voltage') THEN COALESCE(pp.value_number, CAST(pp.value_text AS REAL)) END) AS voltage_v,
       MAX(CASE WHEN pp.key IN ('power_w','power') THEN COALESCE(pp.value_number, CAST(pp.value_text AS REAL)) END) AS power_w,
       MAX(CASE WHEN pp.key IN ('working_width_mm','width_mm') THEN COALESCE(pp.value_number, CAST(pp.value_text AS REAL)) END) AS working_width_mm
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand = 'Record Power'
  AND p.series = 'Professional'
  AND p.model = 'BS 4YQ-EUK'
  AND p.kind_id IN (SELECT id FROM product_kinds WHERE name = 'Workshop Saw and Cutter')
GROUP BY p.sku, p.path
ORDER BY p.sku;
