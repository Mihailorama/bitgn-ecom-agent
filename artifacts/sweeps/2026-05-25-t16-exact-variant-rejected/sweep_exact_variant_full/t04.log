SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pp.key, pp.value_text, pp.value_number
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand) = 'viega'
  AND (
    lower(p.name) LIKE '%drain trap and siphon%'
    OR lower(p.series) LIKE '%smartpress%'
    OR lower(p.model) LIKE '%38m-0yy%'
  )
  AND pp.key IN ('trap_type','diameter_mm','diameter_mm_nominal','diameter')
ORDER BY p.sku, pp.key;
