SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       MAX(CASE WHEN pp.key='fastener_type' THEN pp.value_text END) AS fastener_type,
       MAX(CASE WHEN pp.key='diameter_mm' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS diameter_mm
FROM products p
JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand = 'Heco'
  AND (p.series = 'Heco Zinc Plated' OR p.name LIKE '%Heco Zinc Plated%')
  AND (p.model = 'HECO 3DW-64B' OR p.name LIKE '%HECO 3DW-64B%')
  AND p.name LIKE '%Nut Bolt and Washer%'
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
HAVING MAX(CASE WHEN pp.key='fastener_type' THEN pp.value_text END) = 'bolt'
   AND MAX(CASE WHEN pp.key='diameter_mm' THEN COALESCE(pp.value_number, CAST(pp.value_text AS REAL)) END) = 10;
