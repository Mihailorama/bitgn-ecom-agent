SELECT p.sku, p.path AS product_path, s.path AS store_path,
       SUM(i.available_today) AS total_available_today
FROM inventory i
JOIN products p ON p.sku = i.sku
JOIN stores s ON s.id = i.store_id
WHERE i.sku = 'PWR-1CLZZQ34'
  AND s.is_open = 1
GROUP BY p.sku, p.path, s.path
ORDER BY s.path;
