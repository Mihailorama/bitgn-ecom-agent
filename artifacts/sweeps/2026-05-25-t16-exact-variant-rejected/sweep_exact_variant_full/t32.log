SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind, pp.key, pp.value_text, pp.value_number
FROM products p
LEFT JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand = 'Bosch'
  AND p.series = 'Industrial'
  AND p.model = 'GSR 2Q4-T05'
  AND (p.name = 'Workshop Saw and Cutter' OR pk.name = 'Workshop Saw and Cutter')
ORDER BY p.sku, pp.key;
