[32mOUT[0m: /bin/sql <<'SQL'
WITH target_product AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_properties pp_vol ON pp_vol.sku = p.sku AND pp_vol.key = 'volume_ml'
  JOIN product_properties pp_vis ON pp_vis.sku = p.sku AND pp_vis.key = 'viscosity'
  WHERE p.brand = 'Mobil'
    AND p.series = 'Delvac'
    AND p.model = 'Delvac 3D5-7XK'
    AND p.kind_id IN (SELECT id FROM product_kinds WHERE name = 'Engine Oil')
    AND (
      pp_vol.value_number = 4000
      OR pp_vol.value_text = '4000'
      OR pp_vol.value_text = '4000 ml'
    )
    AND pp_vis.value_text = '0W-20'
), graz_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Graz'
)
SELECT
  tp.path AS product_path,
  gs.path AS store_path,
  COALESCE(i.available_today, 0) AS store_available_today,
  SUM(COALESCE(i.available_today, 0)) OVER () AS total_available_today
FROM target_product tp
CROSS JOIN graz_stores gs
LEFT JOIN inventory i ON i.store_id = gs.id AND i.sku = tp.sku
ORDER BY gs.path;
