SELECT id, path, name, city, is_open FROM stores ORDER BY city, name;

SELECT s.id, s.path, s.name, s.city,
       SUM(CASE WHEN i.sku IN ('ADH-2ET6DODM','ELC-B54HCJ4L','AUT-EFU34IM8','STO-3DUY38Z9','SFE-3JK7H31T','AUT-2LHXWOM4') THEN 1 ELSE 0 END) AS matched_skus
FROM stores s
LEFT JOIN inventory i ON i.store_id = s.id
GROUP BY s.id, s.path, s.name, s.city
ORDER BY matched_skus DESC, s.city, s.name;
