   OR (pk.name='Adhesive and Glue' AND p.brand='Gorilla')
   OR (pk.name='LED Bulb' AND p.brand='Philips')
   OR (pk.name='Wiper Blade' AND p.brand='Sonax')
   OR (pk.name='Safety Eyewear' AND p.brand='3M')
