[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path,
       MAX(CASE WHEN pp.key='cleaning_type' THEN pp.value_text END) AS cleaning_type,
       MAX(CASE WHEN pp.key='pack_count' THEN pp.value_text END) AS pack_count,
       MAX(CASE WHEN pp.key='surface' THEN pp.value_text END) AS surface
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand='Vileda'
  AND p.series='Pro'
  AND p.model='Easy 1XB-2OF'
  AND p.name LIKE '%Cloth Mop and Wipe%'
GROUP BY p.sku, p.path
ORDER BY p.sku;
