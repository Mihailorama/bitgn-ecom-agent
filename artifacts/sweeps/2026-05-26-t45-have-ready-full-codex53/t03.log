[32mOUT[0m: /bin/sql <<'SQL'
SELECT s.path AS store_path,
       s.name AS store_name,
       s.city,
       i.sku,
       SUM(i.available_today) AS available_today
FROM inventory i
JOIN stores s ON s.id = i.store_id
WHERE i.sku = 'PWR-2PE6PW65'
GROUP BY s.path, s.name, s.city, i.sku
HAVING SUM(i.available_today) > 0
ORDER BY available_today DESC, s.name;
