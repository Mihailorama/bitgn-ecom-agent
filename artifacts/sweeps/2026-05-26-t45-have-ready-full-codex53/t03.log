SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, p.price_cents, p.price_currency,
       pp.key, pp.value_text, pp.value_number
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand) = 'dewalt'
  AND (
    lower(p.name) LIKE '%corded angle grinder%'
    OR lower(p.model) LIKE '%dcg 2bh-302%'
    OR lower(p.series) LIKE '%professional%'
    OR lower(p.series) LIKE '%dcg%'
  )
ORDER BY p.sku, pp.key;
