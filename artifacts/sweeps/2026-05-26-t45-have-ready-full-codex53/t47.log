WITH req(row_id, kind_name, brand, series, model) AS (
  VALUES
    ('4TsRh','Work Trousers','Engelbert Strauss','Classic','e.s. 37H-N9K'),
    ('2prnj','Compressor and Dust Extractor','Holzmann','Compact','D 327-RR0'),
    ('MNQUn','Metal and Concrete Paint','Helios','Professional','Helios 29A-FTE'),
    ('KZakk','Cordless Drill Driver','Metabo','Brushless','BS 1OW-IK5'),
    ('UrqhG','Anchor and Wall Plug','Fischer','SX','SX 7UY-G03')
),
actor_store AS (
  SELECT e.id AS employee_id, e.store_id, s.path AS store_path
  FROM employees e
  JOIN stores s ON s.id = e.store_id
  WHERE e.id = 'emp_006'
)
SELECT
  r.row_id,
  a.store_id,
  a.store_path,
  p.sku,
  p.path AS product_path,
  pk.name AS kind_name,
  p.brand,
  p.series,
  p.model,
  p.name AS product_name,
  pp.key,
  pp.value_text,
  pp.value_number
FROM req r
JOIN products p
  ON p.brand = r.brand
 AND p.series = r.series
 AND p.model = r.model
JOIN product_kinds pk
  ON pk.id = p.kind_id
 AND pk.name = r.kind_name
LEFT JOIN product_properties pp
  ON pp.sku = p.sku
 AND pp.key IN (
   'color_family','machine_type','voltage_v','voltage','power_w','power',
   'product_type','battery_platform','kit_contents','anchor_type','diameter_mm'
 )
CROSS JOIN actor_store a
ORDER BY r.row_id, p.sku, pp.key;
