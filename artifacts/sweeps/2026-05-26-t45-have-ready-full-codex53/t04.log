SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pp.key, pp.value_text, pp.value_number
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand) = 'heco'
  AND (
    lower(p.series) LIKE '%heco unix%'
    OR lower(p.model) LIKE '%np7-dbm%'
    OR lower(p.name) LIKE '%np7-dbm%'
    OR lower(p.name) LIKE '%anchor and wall plug%'
  )
ORDER BY p.sku, pp.key;
