  [[32msafe[0m] tool='exec' path='/bin/sql' args=[] stdin="SELECT p.sku, p.path\nFROM products p\nJOIN product_properties a ON a.sku = p.sku AND a.key='anchor_type' AND lower(a.value_text)='wall plug'\nJOIN product_properties d ON d.sku = p.sku AND d.key='diameter_mm' AND d.value_number=5\nJOIN product_properties l ON l.sku = p.sku AND l.key='length_mm' AND l.value_number=40\nJOIN product_properties pc ON pc.sku = p.sku AND pc.key='pack_count' AND pc.value_number=50\nWHERE lower(p.brand)='heco'\n  AND lower(p.series)='unix'\n  AND lower(p.model)='heco np7-dbm'\n  AND lower(p.name) LIKE '%anchor and wall plug%'\nORDER BY p.sku;"
[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path
FROM products p
JOIN product_properties a ON a.sku = p.sku AND a.key='anchor_type' AND lower(a.value_text)='wall plug'
JOIN product_properties d ON d.sku = p.sku AND d.key='diameter_mm' AND d.value_number=5
JOIN product_properties l ON l.sku = p.sku AND l.key='length_mm' AND l.value_number=40
JOIN product_properties pc ON pc.sku = p.sku AND pc.key='pack_count' AND pc.value_number=50
WHERE lower(p.brand)='heco'
  AND lower(p.series)='unix'
  AND lower(p.model)='heco np7-dbm'
  AND lower(p.name) LIKE '%anchor and wall plug%'
ORDER BY p.sku;
