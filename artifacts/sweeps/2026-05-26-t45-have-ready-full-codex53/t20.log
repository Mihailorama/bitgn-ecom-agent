SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       pp1.value_text AS cleaner_type,
       COALESCE(pp2.value_number, CAST(pp2.value_text AS REAL)) AS volume_ml
FROM products p
JOIN product_properties pp1
  ON pp1.sku = p.sku AND pp1.key IN ('cleaner_type','tool_type')
JOIN product_properties pp2
  ON pp2.sku = p.sku AND pp2.key IN ('volume_ml','volume')
WHERE p.brand = 'Liqui Moly'
  AND (p.series = 'All Season Top Tec X52-ZUS' OR p.model = 'All Season Top Tec X52-ZUS' OR p.name LIKE '%All Season Top Tec X52-ZUS%')
  AND (p.name LIKE '%Automotive Cleaner%' OR p.model LIKE '%Automotive Cleaner%')
  AND lower(pp1.value_text) = 'interior cleaner'
  AND COALESCE(pp2.value_number, CAST(pp2.value_text AS REAL)) = 1000
ORDER BY p.sku;
