[32mOUT[0m: /bin/sql <<'SQL'
SELECT s.path AS store_path,
       i.available_today,
       totals.total_available_today,
       p.path AS product_path
FROM stores s
JOIN inventory i ON i.store_id = s.id
JOIN products p ON p.sku = i.sku
JOIN (
  SELECT SUM(i2.available_today) AS total_available_today
  FROM stores s2
  JOIN inventory i2 ON i2.store_id = s2.id
  WHERE s2.city='Vienna' AND i2.sku='WRK-1WYIUH0B'
) totals
WHERE s.city='Vienna' AND i.sku='WRK-1WYIUH0B'
ORDER BY s.path;
SQL
store_path,available_today,total_available_today,product_path
