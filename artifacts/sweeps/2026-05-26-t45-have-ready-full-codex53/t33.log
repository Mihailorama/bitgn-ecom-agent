[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind,
       pp.key, pp.value_text
FROM products p
LEFT JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand='Carhartt'
  AND (p.name LIKE '%Work Trousers%' OR p.series LIKE '%Work Trousers%' OR p.model LIKE '%Work Trousers%' OR pk.name LIKE '%Work Trousers%')
  AND (p.name LIKE '%3EY-11K%' OR p.series LIKE '%3EY-11K%' OR p.model LIKE '%3EY-11K%')
ORDER BY p.sku, pp.key;
