[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       MAX(CASE WHEN pp.key='color_family' THEN pp.value_text END) AS color_family,
       MAX(CASE WHEN pp.key='size' THEN pp.value_text END) AS size
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand='Carhartt'
  AND (p.series='Carhartt Stretch Rugged 3EY-11K' OR p.model='Carhartt Stretch Rugged 3EY-11K' OR p.name LIKE '%Carhartt Stretch Rugged 3EY-11K%')
  AND (p.name LIKE '%Work Trousers%' OR p.model LIKE '%Work Trousers%' OR p.series LIKE '%Work Trousers%')
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
HAVING color_family='Yellow' AND size='XS';
