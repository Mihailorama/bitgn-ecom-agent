[32mOUT[0m: /bin/sql <<'SQL'
WITH target_product AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_properties vml
    ON vml.sku = p.sku
   AND vml.key IN ('volume_ml','volume')
   AND (
     vml.value_number = 5000
     OR vml.value_text IN ('5000','5000 ml','5000ml')
   )
  JOIN product_properties vis
    ON vis.sku = p.sku
   AND vis.key IN ('viscosity','viscosity_grade')
   AND vis.value_text = '10W-40'
  WHERE p.brand = 'Mobil'
    AND p.series = 'All Season Super'
    AND p.model = '1ZE-TCR'
    AND p.kind_id IN (
      SELECT id FROM product_kinds WHERE name = 'Engine Oil'
    )
), vienna_open_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Vienna' AND is_open = 1
)
SELECT
  tp.sku,
  tp.path AS product_path,
  s.id AS store_id,
  s.path AS store_path,
  i.available_today
FROM target_product tp
JOIN inventory i ON i.sku = tp.sku
JOIN vienna_open_stores s ON s.id = i.store_id
ORDER BY s.id;
SQL
sku,product_path,store_id,store_path,available_today
