SELECT p.sku,
       p.path,
       p.brand,
       p.series,
       p.model,
       p.name,
       k.name AS kind,
       pp.key,
       pp.value_text,
       pp.value_number
FROM products p
JOIN product_kinds k ON k.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand) = 'ryobi'
  AND (
    lower(p.series) LIKE '%max power%'
    OR lower(p.name) LIKE '%max power%'
  )
  AND (
    lower(p.model) LIKE '%rcs 3fx-qdi%'
    OR lower(p.name) LIKE '%rcs 3fx-qdi%'
  )
  AND (
    lower(k.name) LIKE '%cordless%'
    OR lower(k.name) LIKE '%saw%'
    OR lower(k.name) LIKE '%sander%'
  )
ORDER BY p.sku, pp.key;
