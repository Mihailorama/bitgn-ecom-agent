[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       w.value_text AS wattage_text, w.value_number AS wattage_number
FROM products p
JOIN product_properties w
  ON w.sku = p.sku
 AND w.key = 'wattage_w'
WHERE lower(p.brand) = 'osram'
  AND lower(p.series) = 'warm'
  AND lower(p.model) = 'classic 2nl-z7i'
  AND lower(p.name) LIKE '%led bulb%'
  AND (w.value_text = '4' OR w.value_number = 4)
ORDER BY p.sku;
