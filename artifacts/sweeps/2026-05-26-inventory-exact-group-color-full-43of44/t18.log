WITH target_product AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_properties pp_type ON pp_type.sku = p.sku AND pp_type.key = 'sealant_type' AND lower(pp_type.value_text) = 'hybrid sealant'
  JOIN product_properties pp_color ON pp_color.sku = p.sku AND pp_color.key = 'color_family' AND lower(pp_color.value_text) = 'gray'
  JOIN product_properties pp_vol ON pp_vol.sku = p.sku AND pp_vol.key = 'volume_ml' AND COALESCE(pp_vol.value_number, CAST(pp_vol.value_text AS REAL)) = 300
  WHERE lower(p.brand) = 'sika'
    AND lower(p.series) = 'sika professional'
    AND lower(p.model) = 'sika 28t-uv8'
    AND lower(p.kind_id) IN (SELECT id FROM product_kinds WHERE lower(name) = 'sealant')
), vienna_stores AS (
  SELECT id, path
  FROM stores
  WHERE lower(city) = 'vienna'
)
SELECT tp.sku, tp.path AS product_path, vs.id AS store_id, vs.path AS store_path,
       COALESCE(i.available_today, 0) AS available_today,
       SUM(COALESCE(i.available_today, 0)) OVER () AS total_available_today
FROM vienna_stores vs
CROSS JOIN target_product tp
LEFT JOIN inventory i ON i.store_id = vs.id AND i.sku = tp.sku
ORDER BY vs.id;
