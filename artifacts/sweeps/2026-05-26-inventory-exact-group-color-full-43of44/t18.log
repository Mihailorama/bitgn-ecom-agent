WITH candidates AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind_name
  FROM products p
  JOIN product_kinds pk ON pk.id = p.kind_id
  WHERE lower(p.brand) = 'sika'
    AND lower(pk.name) = 'sealant'
    AND (
      lower(p.model) LIKE '%28t-uv8%'
      OR lower(p.series) LIKE '%28t-uv8%'
      OR lower(p.name) LIKE '%28t-uv8%'
      OR lower(p.model) LIKE '%28t uv8%'
      OR lower(p.series) LIKE '%28t uv8%'
      OR lower(p.name) LIKE '%28t uv8%'
    )
)
SELECT c.sku, c.path AS product_path, c.brand, c.series, c.model, c.name, c.kind_name,
       pp.key, pp.value_text, pp.value_number
FROM candidates c
LEFT JOIN product_properties pp ON pp.sku = c.sku
ORDER BY c.sku, pp.key;
