[32mOUT[0m: /bin/sql <<'SQL'
SELECT s.path AS store_path,
       i.available_today,
       totals.total_available
FROM stores s
JOIN inventory i ON i.store_id = s.id
JOIN (
  SELECT SUM(i2.available_today) AS total_available
  FROM stores s2
  JOIN inventory i2 ON i2.store_id = s2.id
  WHERE s2.city = 'Graz'
    AND s2.is_open = 1
    AND i2.sku = 'PNT-2SI316MV'
) totals
WHERE s.city = 'Graz'
  AND s.is_open = 1
  AND i.sku = 'PNT-2SI316MV'
ORDER BY s.path;
