[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku,
       p.path,
       p.brand,
       p.series,
       p.model,
       p.name,
       MAX(CASE WHEN pp.key='cleaning_type' THEN pp.value_text END) AS cleaning_type,
       MAX(CASE WHEN pp.key='pack_count' THEN pp.value_text END) AS pack_count
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand = 'Leifheit'
  AND (p.series LIKE '%Fresh Profi NBC-KFA%' OR p.name LIKE '%Fresh Profi NBC-KFA%')
  AND p.name LIKE '%Cloth Mop and Wipe%'
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
HAVING MAX(CASE WHEN pp.key='cleaning_type' THEN pp.value_text END) = 'mop system'
   AND MAX(CASE WHEN pp.key='pack_count' THEN pp.value_text END) = '100 pcs';
