[32mOUT[0m: /bin/sql <<'SQL'
WITH target AS (
  SELECT p.sku, p.path AS product_path
  FROM products p
  JOIN product_kinds pk ON pk.id = p.kind_id
  JOIN product_properties pp_ft ON pp_ft.sku = p.sku AND pp_ft.key = 'fitting_type' AND lower(pp_ft.value_text) = 'compression coupler'
  JOIN product_properties pp_d ON pp_d.sku = p.sku AND pp_d.key = 'diameter_mm' AND COALESCE(pp_d.value_number, CAST(pp_d.value_text AS REAL)) = 20
  WHERE lower(p.brand) = 'pipelife'
    AND lower(p.series) = 'radopress'
    AND lower(p.model) = 'pipe y6x-7gk'
    AND lower(pk.name) = 'pipe fitting'
), graz_stores AS (
  SELECT id, path
  FROM stores
  WHERE lower(city) = 'graz'
)
SELECT t.sku,
       t.product_path,
       gs.id AS store_id,
       gs.path AS store_path,
       COALESCE(i.available_today, 0) AS available_today,
       SUM(COALESCE(i.available_today, 0)) OVER () AS total_available_today
FROM target t
CROSS JOIN graz_stores gs
LEFT JOIN inventory i ON i.store_id = gs.id AND i.sku = t.sku
ORDER BY gs.id;
