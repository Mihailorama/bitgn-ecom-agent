[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path AS product_path, kc.value_text AS kit_contents, s.path AS store_path, i.available_today
FROM products p
JOIN product_properties kc ON kc.sku = p.sku AND kc.key='kit_contents'
JOIN inventory i ON i.sku = p.sku
JOIN stores s ON s.id = i.store_id
WHERE lower(p.brand)='milwaukee'
  AND lower(p.name) LIKE '%cordless drill driver%'
  AND lower(kc.value_text) IN ('bare tool','two battery kit','big pack kit')
  AND s.is_open=1
  AND i.available_today>0
ORDER BY kc.value_text, p.sku, s.path;
