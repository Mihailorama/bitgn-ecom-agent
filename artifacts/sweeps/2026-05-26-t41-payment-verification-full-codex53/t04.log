  [[32msafe[0m] tool='exec' path='/bin/sql' args=[] stdin="SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pp.key, pp.value_text, pp.value_number\nFROM products p\nLEFT JOIN product_properties pp ON pp.sku = p.sku\nWHERE lower(p.brand)='milwaukee'\n  AND (\n    lower(p.name) LIKE '%impact driver%'\n    OR lower(p.name) LIKE '%impact%'\n    OR lower(p.model) LIKE '%fid%'\n    OR lower(p.series) LIKE '%fid%'\n    OR EXISTS (\n      SELECT 1 FROM product_properties pp2\n      WHERE pp2.sku=p.sku\n        AND (\n          lower(pp2.value_text) LIKE '%impact driver%'\n          OR lower(pp2.value_text) LIKE '%bare tool%'\n          OR lower(pp2.value_text) LIKE '%starter kit%'\n          OR lower(pp2.value_text) LIKE '%two battery kit%'\n          OR lower(pp2.value_text) LIKE '%big pack%'\n        )\n    )\n  )\nORDER BY p.sku, pp.key;"
[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pp.key, pp.value_text, pp.value_number
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand)='milwaukee'
  AND (
    lower(p.name) LIKE '%impact driver%'
    OR lower(p.name) LIKE '%impact%'
    OR lower(p.model) LIKE '%fid%'
    OR lower(p.series) LIKE '%fid%'
    OR EXISTS (
      SELECT 1 FROM product_properties pp2
      WHERE pp2.sku=p.sku
        AND (
          lower(pp2.value_text) LIKE '%impact driver%'
          OR lower(pp2.value_text) LIKE '%bare tool%'
          OR lower(pp2.value_text) LIKE '%starter kit%'
          OR lower(pp2.value_text) LIKE '%two battery kit%'
          OR lower(pp2.value_text) LIKE '%big pack%'
        )
    )
  )
ORDER BY p.sku, pp.key;
