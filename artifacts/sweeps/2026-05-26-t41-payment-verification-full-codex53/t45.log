WITH req(item,brand,series,model,kind_name,k1,v1,k2,v2,k3,v3) AS (
  VALUES
    ('sealant_sika','Sika','Professional','Sika 28T-UV8','Sealant','sealant_type','hybrid sealant','color_family','Gray','volume_ml','280'),
    ('tool_bag_festool','Festool','Modular','CTL XPW-76I','Tool Box and Bag','storage_type','tool bag','color_family','Black',NULL,NULL),
    ('measuring_bahco','Bahco','Workshop','BAH 3VZ-SPH','Hammer Measuring and Cutting Tool','tool_type','measuring tape',NULL,NULL,NULL,NULL),
    ('saw_bosch','Bosch','Bench','IXO 3JP-JOU','Workshop Saw and Cutter','machine_type','table saw','voltage_v','400',NULL,NULL),
    ('eyewear_3m','3M','Ventilated','SecureFit 2CE-B35','Safety Eyewear','lens_color','Clear','size','XL',NULL,NULL),
    ('valve_geberit','Geberit','Mapress','Silent IC5-GU6','Valve and Connector','connector_type','ball valve',NULL,NULL,NULL,NULL)
)
SELECT
  r.item,
  p.sku,
  p.path,
  p.brand,
  p.series,
  p.model,
  k.name AS kind,
  pp1.key AS k1, pp1.value_text AS v1,
  pp2.key AS k2, pp2.value_text AS v2,
  pp3.key AS k3, pp3.value_text AS v3
FROM req r
JOIN products p
  ON lower(p.brand)=lower(r.brand)
 AND lower(p.series)=lower(r.series)
 AND lower(p.model)=lower(r.model)
JOIN product_kinds k
  ON k.id=p.kind_id
 AND lower(k.name)=lower(r.kind_name)
JOIN product_properties pp1
  ON pp1.sku=p.sku AND lower(pp1.key)=lower(r.k1) AND lower(pp1.value_text)=lower(r.v1)
LEFT JOIN product_properties pp2
  ON pp2.sku=p.sku AND r.k2 IS NOT NULL AND lower(pp2.key)=lower(r.k2) AND lower(pp2.value_text)=lower(r.v2)
LEFT JOIN product_properties pp3
  ON pp3.sku=p.sku AND r.k3 IS NOT NULL AND lower(pp3.key)=lower(r.k3) AND lower(pp3.value_text)=lower(r.v3)
WHERE (r.k2 IS NULL OR pp2.sku IS NOT NULL)
  AND (r.k3 IS NULL OR pp3.sku IS NOT NULL)
ORDER BY r.item, p.sku;
