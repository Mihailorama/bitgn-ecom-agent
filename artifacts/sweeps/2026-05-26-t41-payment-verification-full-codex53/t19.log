[32mOUT[0m: /bin/sql <<'SQL'
WITH target_product AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_kinds k ON k.id = p.kind_id
  JOIN product_properties pp_anchor ON pp_anchor.sku = p.sku
  JOIN product_properties pp_diam ON pp_diam.sku = p.sku
  WHERE p.brand = 'Rawlplug'
    AND p.series = 'Rawlplug Pro Pack UNO 3FA-C1B'
    AND k.name = 'Anchor and Wall Plug'
    AND pp_anchor.key = 'anchor_type'
    AND pp_anchor.value_text = 'frame fixing'
    AND pp_diam.key = 'diameter_mm'
    AND (pp_diam.value_number = 10 OR pp_diam.value_text = '10')
), vienna_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Vienna'
)
SELECT
  vs.id AS store_id,
  vs.path AS store_path,
  tp.sku,
  tp.path AS product_path,
  COALESCE(i.available_today, 0) AS available_today
FROM vienna_stores vs
CROSS JOIN target_product tp
LEFT JOIN inventory i
  ON i.store_id = vs.id AND i.sku = tp.sku
ORDER BY vs.id;
