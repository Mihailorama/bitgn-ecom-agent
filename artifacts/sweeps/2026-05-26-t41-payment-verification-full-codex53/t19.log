         k.name AS kind_name, f.series AS family_series, f.model AS family_model
  FROM products p
  JOIN product_kinds k ON k.id = p.kind_id
  JOIN families f ON f.id = p.family_id
  JOIN product_properties a ON a.sku = p.sku AND a.key = 'anchor_type' AND a.value_text = 'frame fixing'
  JOIN product_properties d ON d.sku = p.sku AND d.key = 'diameter_mm' AND (d.value_number = 10 OR d.value_text = '10')
  WHERE p.brand = 'Rawlplug'
    AND k.name = 'Anchor and Wall Plug'
)
