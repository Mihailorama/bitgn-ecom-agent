SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pp.key, pp.value_text, pp.value_number
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand) = 'stihl'
  AND (
    lower(p.series) LIKE '%ak system hsa duw-0vn%'
    OR lower(p.model) LIKE '%ak system hsa duw-0vn%'
    OR lower(p.name) LIKE '%ak system hsa duw-0vn%'
    OR lower(p.name) LIKE '%chainsaw%'
  )
ORDER BY p.sku, pp.key;
