WITH target_product AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_properties pp1 ON pp1.sku = p.sku AND pp1.key = 'cleaner_type' AND lower(pp1.value_text) = 'degreaser'
  JOIN product_properties pp2 ON pp2.sku = p.sku AND pp2.key = 'volume_ml' AND CAST(pp2.value_number AS INTEGER) = 500
  JOIN product_properties pp3 ON pp3.sku = p.sku AND pp3.key = 'surface' AND lower(pp3.value_text) = 'multi surface'
  WHERE lower(p.brand) = 'ajax'
    AND lower(p.series) = 'heavy duty'
    AND lower(p.model) = 'aj 24k-8zc'
    AND lower(p.name) = 'cleaning liquid'
), vienna_stores AS (
  SELECT id, path, name
  FROM stores
  WHERE lower(city) = 'vienna'
)
SELECT vs.path AS store_path,
       vs.name AS store_name,
       tp.path AS product_path,
       tp.sku,
       COALESCE(i.available_today, 0) AS available_today
FROM vienna_stores vs
CROSS JOIN target_product tp
LEFT JOIN inventory i
  ON i.store_id = vs.id
 AND i.sku = tp.sku
ORDER BY vs.name;
SQL
