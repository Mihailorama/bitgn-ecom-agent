[32mOUT[0m: /bin/sql <<'SQL'
WITH vienna_stores AS (
  SELECT id, path, name
  FROM stores
  WHERE lower(city) = 'vienna'
), target_products AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_properties ct ON ct.sku = p.sku AND ct.key = 'cleaner_type' AND lower(ct.value_text) = 'degreaser'
  JOIN product_properties vm ON vm.sku = p.sku AND vm.key = 'volume_ml' AND CAST(vm.value_number AS INTEGER) = 500
  JOIN product_properties sf ON sf.sku = p.sku AND sf.key = 'surface' AND lower(sf.value_text) = 'multi surface'
  WHERE lower(p.brand) = 'ajax'
)
SELECT vs.path AS store_path,
       vs.name AS store_name,
       tp.path AS product_path,
       tp.sku,
       COALESCE(i.available_today, 0) AS available_today
FROM vienna_stores vs
LEFT JOIN target_products tp ON 1=1
LEFT JOIN inventory i ON i.store_id = vs.id AND i.sku = tp.sku
ORDER BY vs.name, tp.sku;
