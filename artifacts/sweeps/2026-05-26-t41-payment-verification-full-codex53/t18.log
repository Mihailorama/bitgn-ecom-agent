[32mOUT[0m: /bin/sql <<'SQL'
WITH candidate_products AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, k.name AS kind_name
  FROM products p
  JOIN product_kinds k ON k.id = p.kind_id
  WHERE p.brand = 'Bosch'
    AND k.name = 'Workshop Saw and Cutter'
    AND (
      lower(p.series) LIKE '%ixo%'
      OR lower(p.model) LIKE '%3jp-jou%'
      OR lower(p.name) LIKE '%workshop saw and cutter%'
    )
)
SELECT
  cp.sku,
  cp.path AS product_path,
  cp.brand,
  cp.series,
  cp.model,
  cp.name,
  pp.key AS property_key,
  COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) AS property_value
FROM candidate_products cp
LEFT JOIN product_properties pp ON pp.sku = cp.sku
ORDER BY cp.path, pp.key;
