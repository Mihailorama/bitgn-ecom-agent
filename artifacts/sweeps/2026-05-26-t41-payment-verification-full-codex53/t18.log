WITH target_product AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_kinds k ON k.id = p.kind_id
  JOIN product_properties pp_machine ON pp_machine.sku = p.sku
    AND pp_machine.key = 'machine_type' AND lower(pp_machine.value_text) = 'table saw'
  JOIN product_properties pp_voltage ON pp_voltage.sku = p.sku
    AND pp_voltage.key = 'voltage' AND (
      pp_voltage.value_text = '230 V' OR pp_voltage.value_text = '230V' OR pp_voltage.value_number = 230
    )
  WHERE p.brand = 'Bosch'
    AND p.series = 'Bosch Bench IXO 3JP-JOU'
    AND k.name = 'Workshop Saw and Cutter'
    AND p.name = 'Workshop Saw and Cutter'
), graz_stores AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Graz'
)
SELECT
  tp.sku,
  tp.path AS product_path,
  gs.path AS store_path,
  COALESCE(i.available_today, 0) AS store_available_today,
  SUM(COALESCE(i.available_today, 0)) OVER () AS total_available_today
FROM graz_stores gs
CROSS JOIN target_product tp
LEFT JOIN inventory i
  ON i.store_id = gs.id AND i.sku = tp.sku
ORDER BY gs.path;
