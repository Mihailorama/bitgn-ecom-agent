WITH graz_store_candidates AS (
  SELECT id, path, name, city
  FROM stores
  WHERE lower(city) LIKE '%graz%'
), product_candidates AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, k.name AS kind_name
  FROM products p
  JOIN product_kinds k ON k.id = p.kind_id
  WHERE p.brand = 'Bosch'
    AND p.series = 'Bosch Bench IXO 3JP-JOU'
    AND k.name = 'Workshop Saw and Cutter'
    AND p.name = 'Workshop Saw and Cutter'
)
SELECT 'STORE' AS row_type, g.id, g.path, g.name, g.city, NULL AS sku, NULL AS prop_key, NULL AS prop_value
FROM graz_store_candidates g
UNION ALL
SELECT 'PRODUCT' AS row_type, NULL AS id, pc.path, pc.name, NULL AS city, pc.sku, pp.key AS prop_key, COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) AS prop_value
FROM product_candidates pc
LEFT JOIN product_properties pp ON pp.sku = pc.sku
