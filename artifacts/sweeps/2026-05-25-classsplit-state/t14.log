WITH s AS (
  SELECT id, path, name, city
  FROM stores
  WHERE lower(city) LIKE '%brno%' OR lower(name) LIKE '%veveri%'
), k AS (
  SELECT id, name FROM product_kinds
  WHERE name IN ('Cordless Drill Driver','Anchor and Wall Plug','Work Jacket','Pliers and Wrenches','Engine Oil')
)
SELECT 'STORE' AS section, s.id, s.path, s.name, s.city, NULL AS sku, NULL AS brand, NULL AS series, NULL AS model, NULL AS kind, NULL AS prop_key, NULL AS prop_val
FROM s
UNION ALL
SELECT 'PRODUCT' AS section, NULL, p.path, NULL, NULL, p.sku, p.brand, p.series, p.model, pk.name, pp.key, COALESCE(pp.value_text, CAST(pp.value_number AS TEXT))
FROM products p
JOIN k pk ON pk.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand IN ('Metabo','Fischer','Mascot','Bahco','Mobil')
ORDER BY section, id, sku, prop_key;
