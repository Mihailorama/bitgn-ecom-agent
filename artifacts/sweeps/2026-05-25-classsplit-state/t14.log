WITH target_store AS (
  SELECT id, path FROM stores WHERE id = 'store_brno_veveri'
), requested(item_key, sku) AS (
  SELECT 'drill', p.sku
  FROM products p
  JOIN product_kinds k ON k.id=p.kind_id
  WHERE p.brand='Metabo' AND p.series='Brushless' AND p.model='BS 1OW-IK5' AND k.name='Cordless Drill Driver'
    AND EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key='voltage_v' AND pp.value_number=18)
    AND EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key='battery_platform' AND lower(pp.value_text)='18v-system')
    AND EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key='kit_contents' AND lower(pp.value_text)='case')
  UNION ALL
  SELECT 'fischer6', p.sku
  FROM products p
  JOIN product_kinds k ON k.id=p.kind_id
  WHERE p.brand='Fischer' AND p.series='SX' AND p.model='SX 7UY-G03' AND k.name='Anchor and Wall Plug'
    AND EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key='anchor_type' AND lower(pp.value_text)='concrete anchor')
    AND EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key='diameter_mm' AND pp.value_number=6)
  UNION ALL
  SELECT 'jacket', p.sku
  FROM products p
  JOIN product_kinds k ON k.id=p.kind_id
  WHERE p.brand='Mascot' AND p.series='Advanced' AND p.model='ACC 35W-IIS' AND k.name='Work Jacket'
    AND EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key='color_family' AND lower(pp.value_text)='black')
  UNION ALL
  SELECT 'bahco', p.sku
  FROM products p
  JOIN product_kinds k ON k.id=p.kind_id
  WHERE p.brand='Bahco' AND p.series='Comfort Grip' AND p.model='BE 1ZR-PGS' AND k.name='Pliers and Wrenches'
    AND EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key='tool_type' AND lower(pp.value_text)='side cutter')
    AND EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key='length_mm' AND pp.value_number=300)
  UNION ALL
  SELECT 'fischer5', p.sku
  FROM products p
  JOIN product_kinds k ON k.id=p.kind_id
  WHERE p.brand='Fischer' AND p.series='SX' AND p.model='SX 7UY-G03' AND k.name='Anchor and Wall Plug'
    AND EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key='anchor_type' AND lower(pp.value_text)='concrete anchor')
    AND EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key='diameter_mm' AND pp.value_number=5)
  UNION ALL
  SELECT 'oil', p.sku
  FROM products p
  JOIN product_kinds k ON k.id=p.kind_id
  WHERE p.brand='Mobil' AND p.series='All Season' AND p.model='Super 1ZE-TCR' AND k.name='Engine Oil'
    AND EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key='volume_ml' AND pp.value_number=5000)
    AND EXISTS (SELECT 1 FROM product_properties pp WHERE pp.sku=p.sku AND pp.key='viscosity' AND pp.value_text='15W-40')
)
SELECT COUNT(*) AS cnt
FROM requested r
JOIN target_store ts
JOIN inventory i ON i.store_id=ts.id AND i.sku=r.sku
WHERE i.available_today >= 2;
