WITH target_store AS (
  SELECT id, path, name, city
  FROM stores
  WHERE lower(city) LIKE '%brno%' AND lower(name) LIKE '%veveri%'
), requested AS (
  SELECT 'drill' AS item_key, 'Metabo' AS brand, 'Metabo Brushless' AS series, 'BS 1OW-IK5' AS model, 'Cordless Drill Driver' AS kind
  UNION ALL SELECT 'fischer6','Fischer','Fischer SX','SX 7UY-G03','Anchor and Wall Plug'
  UNION ALL SELECT 'jacket','Mascot','Mascot Advanced','ACC 35W-IIS','Work Jacket'
  UNION ALL SELECT 'bahco','Bahco','Bahco Comfort Grip','BE 1ZR-PGS','Pliers and Wrenches'
  UNION ALL SELECT 'fischer5','Fischer','Fischer SX','SX 7UY-G03','Anchor and Wall Plug'
  UNION ALL SELECT 'oil','Mobil','Mobil All Season','Super 1ZE-TCR','Engine Oil'
)
SELECT r.item_key, p.sku, p.path AS product_path, p.brand, p.series, p.model, pk.name AS kind, pp.key, pp.value_text, pp.value_number,
       ts.id AS store_id, ts.path AS store_path, i.available_today
FROM requested r
JOIN products p ON p.brand=r.brand AND p.series=r.series AND p.model=r.model
JOIN product_kinds pk ON pk.id=p.kind_id AND pk.name=r.kind
JOIN target_store ts
LEFT JOIN product_properties pp ON pp.sku=p.sku
LEFT JOIN inventory i ON i.store_id=ts.id AND i.sku=p.sku
ORDER BY r.item_key, p.sku, pp.key;
