SELECT id, path, name, city, is_open
FROM stores
WHERE lower(city) LIKE '%innsbruck%'
   OR lower(name) LIKE '%innsbruck%'
   OR lower(name) LIKE '%central%'
ORDER BY city, name;

SELECT DISTINCT brand, series, model, name
FROM products
WHERE brand IN ('Festool','Ajax','Heco')
   OR lower(model) IN ('sys 3jj-9lm','25c-dxe','gtu-ypj')
ORDER BY brand, series, model, name;

SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pp.key, pp.value_text, pp.value_number
FROM products p
JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand IN ('Festool','Ajax','Heco')
  AND (
    lower(p.model) LIKE '%3jj-9lm%'
    OR lower(p.model) LIKE '%25c-dxe%'
    OR lower(p.model) LIKE '%gtu-ypj%'
    OR lower(p.name) LIKE '%tool box%'
    OR lower(p.name) LIKE '%cleaning liquid%'
    OR lower(p.name) LIKE '%wood and drywall screw%'
  )
ORDER BY p.brand, p.series, p.model, p.sku, pp.key;
