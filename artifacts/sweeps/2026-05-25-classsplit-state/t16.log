WITH req AS (
  SELECT 'Michelin' brand, 'Premium' series, 'Stealth 1T0-N2Q' model, 'Wiper Blade' kind,
         'length_mm' k1, '550' v1, 'adapter_type' k2, 'hook' v2, NULL k3, NULL v3, NULL k4, NULL v4
  UNION ALL SELECT 'Varta','Workshop','Silver 2KH-QZR','Automotive Charger and Bulb',
         'product_type','jump starter','voltage_v','24','current_a','10','vehicle_type','van'
  UNION ALL SELECT 'Dresselhaus','Outdoor','DRE 2A1-OSK','Wood and Drywall Screw',
         'screw_type','wood screw','diameter_mm','3','length_mm','40',NULL,NULL
  UNION ALL SELECT 'Legrand','Plexo','Plexo 2XT-4EJ','Wiring Device',
         'device_type','junction box','color_family','White',NULL,NULL,NULL,NULL
  UNION ALL SELECT 'Ajax','Concentrate','Classic GCE-IRA','Cleaning Liquid',
         'cleaner_type','interior cleaner','volume_ml','1000',NULL,NULL,NULL,NULL
  UNION ALL SELECT 'Viega','Professional','Sanpress 1NX-HRW','Pipe Fitting',
         'fitting_type','seal ring','diameter_mm','12','connection_type','push fit',NULL,NULL
), matched AS (
  SELECT r.brand, r.series, r.model, r.kind, p.sku, p.path
  FROM req r
  JOIN products p ON p.brand=r.brand AND p.series=r.series AND p.model=r.model
  JOIN product_kinds pk ON pk.id=p.kind_id AND pk.name=r.kind
  WHERE EXISTS (
    SELECT 1 FROM product_properties pp
    WHERE pp.sku=p.sku AND pp.key=r.k1
      AND LOWER(COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)))=LOWER(r.v1)
  )
    AND EXISTS (
    SELECT 1 FROM product_properties pp
    WHERE pp.sku=p.sku AND pp.key=r.k2
      AND LOWER(COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)))=LOWER(r.v2)
  )
    AND (r.k3 IS NULL OR EXISTS (
      SELECT 1 FROM product_properties pp
      WHERE pp.sku=p.sku AND pp.key=r.k3
        AND LOWER(COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)))=LOWER(r.v3)
    ))
    AND (r.k4 IS NULL OR EXISTS (
      SELECT 1 FROM product_properties pp
      WHERE pp.sku=p.sku AND pp.key=r.k4
        AND LOWER(COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)))=LOWER(r.v4)
    ))
)
SELECT m.brand, m.series, m.model, m.kind, m.sku, m.path, i.available_today
FROM matched m
LEFT JOIN inventory i ON i.sku=m.sku AND i.store_id='store_graz_jakomini'
ORDER BY m.brand, m.sku;
