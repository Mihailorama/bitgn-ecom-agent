         'length_mm' AS k1, '550' AS v1, 'adapter_type' AS k2, 'hook' AS v2, NULL AS k3, NULL AS v3, NULL AS k4, NULL AS v4
  UNION ALL
  SELECT 'Varta','Workshop Silver 2KH-QZR','Automotive Charger and Bulb',
         'product_type','jump starter','voltage_v','24','current_a','10','vehicle_type','van'
  UNION ALL
  SELECT 'Dresselhaus','Outdoor DRE 2A1-OSK','Wood and Drywall Screw',
         'screw_type','wood screw','diameter_mm','3','length_mm','40',NULL,NULL
  UNION ALL
  SELECT 'Legrand','Plexo Plexo 2XT-4EJ','Wiring Device',
         'device_type','junction box','color_family','White',NULL,NULL,NULL,NULL
  UNION ALL
  SELECT 'Ajax','Concentrate Classic GCE-IRA','Cleaning Liquid',
         'cleaner_type','interior cleaner','volume_ml','1000',NULL,NULL,NULL,NULL
  UNION ALL
  SELECT 'Viega','Professional Sanpress 1NX-HRW','Pipe Fitting',
         'fitting_type','seal ring','diameter_mm','12','connection_type','push fit',NULL,NULL
)
SELECT r.brand, r.line_token, r.kind, p.sku, p.path, i.available_today
FROM req r
JOIN products p
