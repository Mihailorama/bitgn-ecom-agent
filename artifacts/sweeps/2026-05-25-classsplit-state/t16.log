WITH req AS (
  SELECT 'Michelin' AS brand, 'Premium Stealth' AS series, '1T0-N2Q' AS model, 'Wiper Blade' AS kind, 'length_mm' AS k1, '550' AS v1, 'adapter_type' AS k2, 'hook' AS v2, NULL AS k3, NULL AS v3
  UNION ALL SELECT 'Varta','Workshop Silver','2KH-QZR','Automotive Charger and Bulb','product_type','jump starter','voltage_v','24','current_a','10'
  UNION ALL SELECT 'Dresselhaus','Outdoor DRE','2A1-OSK','Wood and Drywall Screw','screw_type','wood screw','diameter_mm','3','length_mm','40'
  UNION ALL SELECT 'Legrand','Plexo Plexo','2XT-4EJ','Wiring Device','device_type','junction box','color_family','White',NULL,NULL
  UNION ALL SELECT 'Ajax','Concentrate Classic','GCE-IRA','Cleaning Liquid','cleaner_type','interior cleaner','volume_ml','1000',NULL,NULL
  UNION ALL SELECT 'Viega','Professional Sanpress','1NX-HRW','Pipe Fitting','fitting_type','seal ring','diameter_mm','12','connection_type','push fit'
)
SELECT r.brand, r.series, r.model, r.kind, p.sku, p.path,
       GROUP_CONCAT(pp.key || '=' || COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)), ';') AS matched_props
FROM req r
JOIN products p
  ON p.brand=r.brand AND p.series=r.series AND p.model=r.model AND p.name=r.kind
JOIN product_properties pp
  ON pp.sku=p.sku
WHERE (pp.key=r.k1 AND LOWER(pp.value_text)=LOWER(r.v1))
   OR (pp.key=r.k2 AND LOWER(pp.value_text)=LOWER(r.v2))
   OR (r.k3 IS NOT NULL AND pp.key=r.k3 AND LOWER(pp.value_text)=LOWER(r.v3))
GROUP BY r.brand, r.series, r.model, r.kind, p.sku, p.path
HAVING SUM(CASE WHEN pp.key=r.k1 AND LOWER(pp.value_text)=LOWER(r.v1) THEN 1 ELSE 0 END) > 0
   AND SUM(CASE WHEN pp.key=r.k2 AND LOWER(pp.value_text)=LOWER(r.v2) THEN 1 ELSE 0 END) > 0
   AND (r.k3 IS NULL OR SUM(CASE WHEN pp.key=r.k3 AND LOWER(pp.value_text)=LOWER(r.v3) THEN 1 ELSE 0 END) > 0)
ORDER BY r.brand, r.series, r.model, p.sku;
