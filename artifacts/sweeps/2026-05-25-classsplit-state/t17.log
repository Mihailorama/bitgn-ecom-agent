SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind, p.properties
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
WHERE pk.name = 'Wood and Drywall Screw'
  AND (
    p.brand LIKE '%Heco%'
    OR p.series LIKE '%Heco%' OR p.series LIKE '%TopFix%' OR p.series LIKE '%GTU%' OR p.series LIKE '%YPJ%'
    OR p.model LIKE '%Heco%' OR p.model LIKE '%TopFix%' OR p.model LIKE '%GTU%' OR p.model LIKE '%YPJ%'
    OR p.name  LIKE '%Heco%' OR p.name  LIKE '%TopFix%' OR p.name  LIKE '%GTU%' OR p.name  LIKE '%YPJ%'
    OR p.properties LIKE '%wood%' OR p.properties LIKE '%diameter%' OR p.properties LIKE '%6%'
  )
ORDER BY p.brand, p.series, p.model, p.sku;

SELECT pp.sku, pp.key, pp.value_text, pp.value_number
FROM product_properties pp
WHERE pp.sku IN (
  SELECT p.sku
  FROM products p
  JOIN product_kinds pk ON pk.id = p.kind_id
  WHERE pk.name = 'Wood and Drywall Screw'
)
  AND (
    pp.value_text LIKE '%Heco%' OR pp.value_text LIKE '%TopFix%' OR pp.value_text LIKE '%wood%'
    OR pp.key LIKE '%diameter%' OR pp.key LIKE '%screw%' OR pp.value_number = 6
  )
ORDER BY pp.sku, pp.key;

SELECT id, path FROM stores WHERE city='Vienna' ORDER BY id;
