[32mOUT[0m: /bin/sql <<'SQL'
WITH vienna AS (
  SELECT id, path
  FROM stores
  WHERE city = 'Vienna'
), target AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_kinds pk ON pk.id = p.kind_id
  JOIN product_properties pp_type ON pp_type.sku = p.sku
  JOIN product_properties pp_diam ON pp_diam.sku = p.sku
  WHERE pk.name = 'Wood and Drywall Screw'
    AND p.brand = 'Heco'
    AND p.series = 'Zinc Plated'
    AND p.model = 'TopFix GTU-YPJ'
    AND pp_type.key IN ('screw_type','screw kind','type')
    AND lower(pp_type.value_text) = 'wood screw'
    AND pp_diam.key IN ('diameter_mm','diameter')
    AND (pp_diam.value_number = 6 OR pp_diam.value_text = '6')
)
SELECT t.sku,
       t.path AS product_path,
       (SELECT GROUP_CONCAT(v.path, '|') FROM vienna v) AS vienna_store_paths,
       SUM(COALESCE(i.available_today,0)) AS total_available_today
FROM target t
CROSS JOIN vienna v
LEFT JOIN inventory i ON i.store_id = v.id AND i.sku = t.sku
GROUP BY t.sku, t.path;
