)
AND (
  p.name LIKE '%Wood Stain and Deck Oil%'
  OR p.model LIKE '%Wood Stain and Deck Oil%'
  OR p.series LIKE '%Wood Stain and Deck Oil%'
)
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
HAVING product_type='primer' AND color_family='Brown'
ORDER BY p.sku;
