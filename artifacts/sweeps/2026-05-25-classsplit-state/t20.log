Next step_3... Run a focused SQL query for Bondex + series Classic 28S-4UT + product_type primer + color_family brown to resolve unique SKU/path. (15717 ms)
  [[32msafe[0m] tool='exec' path='/bin/sql' args=[] stdin="SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,\n       MAX(CASE WHEN pp.key='product_type' THEN pp.value_text END) AS product_type,\n       MAX(CASE WHEN pp.key='color_family' THEN pp.value_text END) AS color_family\nFROM products p\nJOIN product_properties pp ON pp.sku = p.sku\nWHERE p.brand='Bondex'\n  AND p.series='Classic 28S-4UT'\nGROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name\nHAVING product_type='primer' AND color_family='brown'\nORDER BY p.sku;"
[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       MAX(CASE WHEN pp.key='product_type' THEN pp.value_text END) AS product_type,
       MAX(CASE WHEN pp.key='color_family' THEN pp.value_text END) AS color_family
FROM products p
JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand='Bondex'
  AND p.series='Classic 28S-4UT'
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
HAVING product_type='primer' AND color_family='brown'
ORDER BY p.sku;
