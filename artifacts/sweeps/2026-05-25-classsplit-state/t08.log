  [[32msafe[0m] tool='exec' path='/bin/sql' args=[] stdin="SELECT p.sku, p.path,\n       MAX(CASE WHEN pp.key='storage_type' THEN lower(pp.value_text) END) AS storage_type,\n       MAX(CASE WHEN pp.key='color_family' THEN lower(pp.value_text) END) AS color_family,\n       MAX(CASE WHEN pp.key='volume_l' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS volume_l,\n       CASE WHEN\n         MAX(CASE WHEN pp.key='storage_type' THEN lower(pp.value_text) END)='tool box'\n         AND MAX(CASE WHEN pp.key='color_family' THEN lower(pp.value_text) END)='black'\n         AND MAX(CASE WHEN pp.key='volume_l' THEN CAST(pp.value_number AS INTEGER) END)=18\n       THEN 1 ELSE 0 END AS is_exact_claim\nFROM products p\nJOIN product_properties pp ON pp.sku = p.sku\nWHERE lower(p.brand)='keter'\n  AND lower(p.series)='compact'\n  AND lower(p.model)='ket swg-h1w'\nGROUP BY p.sku, p.path\nORDER BY p.sku;"
[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path,
       MAX(CASE WHEN pp.key='storage_type' THEN lower(pp.value_text) END) AS storage_type,
       MAX(CASE WHEN pp.key='color_family' THEN lower(pp.value_text) END) AS color_family,
       MAX(CASE WHEN pp.key='volume_l' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS volume_l,
       CASE WHEN
         MAX(CASE WHEN pp.key='storage_type' THEN lower(pp.value_text) END)='tool box'
         AND MAX(CASE WHEN pp.key='color_family' THEN lower(pp.value_text) END)='black'
         AND MAX(CASE WHEN pp.key='volume_l' THEN CAST(pp.value_number AS INTEGER) END)=18
       THEN 1 ELSE 0 END AS is_exact_claim
FROM products p
JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand)='keter'
  AND lower(p.series)='compact'
  AND lower(p.model)='ket swg-h1w'
GROUP BY p.sku, p.path
ORDER BY p.sku;
