SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pp.key, pp.value_text, pp.value_number
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand) = 'keter'
  AND (
    lower(p.series) LIKE '%compact%'
    OR lower(p.model) LIKE '%ket swg-h1w%'
    OR lower(p.name) LIKE '%tool box and bag%'
    OR lower(p.name) LIKE '%keter compact ket swg-h1w%'
  )
ORDER BY p.sku, pp.key;
