SELECT p.sku, p.path,
       MAX(CASE WHEN pp.key='cleaner_type' THEN pp.value_text END) AS cleaner_type,
       MAX(CASE WHEN pp.key='surface' THEN pp.value_text END) AS surface
FROM products p
JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand)='karcher'
  AND lower(p.series)='workshop'
  AND lower(p.model)='wd 2c4-u0u'
  AND lower(p.name) LIKE '%cleaning liquid%'
GROUP BY p.sku, p.path
ORDER BY p.sku;
