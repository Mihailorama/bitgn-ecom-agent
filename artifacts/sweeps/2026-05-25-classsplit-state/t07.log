SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pp.key, pp.value_text
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand) = 'karcher'
  AND (
    lower(p.series) LIKE '%workshop%'
    OR lower(p.model) LIKE '%wd 2c4-u0u%'
    OR lower(p.name) LIKE '%cleaning liquid%'
  )
ORDER BY p.sku, pp.key;
