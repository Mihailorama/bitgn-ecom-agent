[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.path AS product_path,
       s.path AS store_path,
       i.available_today,
       totals.total_available_today
FROM inventory i
JOIN stores s ON s.id = i.store_id
JOIN products p ON p.sku = i.sku
JOIN (
  SELECT SUM(i2.available_today) AS total_available_today
  FROM inventory i2
  JOIN stores s2 ON s2.id = i2.store_id
  WHERE s2.city='Vienna' AND i2.sku='ELC-32HZWSG4'
) totals
WHERE s.city='Vienna'
  AND i.sku='ELC-32HZWSG4'
  AND i.available_today > 0
ORDER BY s.path;
