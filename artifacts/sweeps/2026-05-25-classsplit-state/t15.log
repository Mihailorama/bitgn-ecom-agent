[32mOUT[0m: /bin/sql <<'SQL'
WITH wanted AS (
  SELECT 'item1' AS item, '3M' AS brand, 'SecureFit Aura' AS series_hint, 'TUM-I54' AS model_hint UNION ALL
  SELECT 'item2','Wavin','Professional Tigris','31G-M1A' UNION ALL
  SELECT 'item3','Liqui Moly','Workshop Top Tec','LMI-I9R' UNION ALL
  SELECT 'item6','Karcher','WD SC','1PM-1UM'
)
SELECT w.item, p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind,
       pp.key, pp.value_text, pp.value_number
FROM wanted w
JOIN products p
  ON lower(p.brand)=lower(w.brand)
JOIN product_kinds pk
  ON pk.id=p.kind_id
LEFT JOIN product_properties pp
  ON pp.sku=p.sku
WHERE lower(p.series) LIKE '%' || lower(substr(w.series_hint,1,4)) || '%'
   OR lower(p.model) LIKE '%' || lower(substr(w.model_hint,1,3)) || '%'
   OR lower(p.name)  LIKE '%' || lower(substr(w.model_hint,1,3)) || '%'
ORDER BY w.item, p.series, p.model, p.sku, pp.key;
