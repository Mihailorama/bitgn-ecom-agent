WITH target_store AS (
  SELECT id FROM stores WHERE id='store_bratislava_stare_mesto'
), base AS (
  SELECT 'item1' AS item, p.sku, p.path
  FROM products p JOIN product_kinds k ON k.id=p.kind_id
  WHERE k.name='Safety Eyewear' AND p.brand='3M' AND p.series='SecureFit' AND p.model='Aura TUM-I54'
  UNION ALL
  SELECT 'item2', p.sku, p.path
  FROM products p JOIN product_kinds k ON k.id=p.kind_id
  WHERE k.name='Drain Trap and Siphon' AND p.brand='Wavin' AND p.series='Professional' AND p.model='Tigris 31G-M1A'
  UNION ALL
  SELECT 'item3', p.sku, p.path
  FROM products p JOIN product_kinds k ON k.id=p.kind_id
  WHERE k.name='Automotive Cleaner' AND p.brand='Liqui Moly' AND p.series='Workshop' AND p.model='Top Tec LMI-I9R'
  UNION ALL
  SELECT 'item4', p.sku, p.path
  FROM products p JOIN product_kinds k ON k.id=p.kind_id
  WHERE k.name='Workshop Saw and Cutter' AND p.brand='Bosch' AND p.series='Precision' AND p.model='PKS 3Q6-CLK'
  UNION ALL
  SELECT 'item5', p.sku, p.path
  FROM products p JOIN product_kinds k ON k.id=p.kind_id
  WHERE k.name='Extension Cable' AND p.brand='Hager' AND p.series='Workshop' AND p.model='HAG 1RH-81U'
  UNION ALL
  SELECT 'item6', p.sku, p.path
  FROM products p JOIN product_kinds k ON k.id=p.kind_id
  WHERE k.name='Cleaning Liquid' AND p.brand='Karcher' AND (
    (p.series='WD' AND p.model='SC 1PM-1UM') OR
    (p.series='WD SC' AND p.model='1PM-1UM') OR
    (p.series='WD SC' AND p.model='SC 1PM-1UM')
  )
), props AS (
  SELECT b.item, b.sku, b.path,
         MAX(CASE WHEN pp.key='lens_color' AND lower(pp.value_text)='clear' THEN 1 ELSE 0 END) AS p1,
         MAX(CASE WHEN pp.key='size' AND lower(pp.value_text)='one size' THEN 1 ELSE 0 END) AS p2,
         MAX(CASE WHEN pp.key='coating' AND lower(pp.value_text)='anti fog' THEN 1 ELSE 0 END) AS p3,
         MAX(CASE WHEN pp.key='trap_type' AND lower(pp.value_text)='drain trap' THEN 1 ELSE 0 END) AS p4,
         MAX(CASE WHEN pp.key='diameter_mm' AND pp.value_number=32 THEN 1 ELSE 0 END) AS p5,
         MAX(CASE WHEN pp.key='cleaner_type' AND lower(pp.value_text)='brake cleaner' THEN 1 ELSE 0 END) AS p6,
         MAX(CASE WHEN pp.key='volume_ml' AND pp.value_number=4000 THEN 1 ELSE 0 END) AS p7,
         MAX(CASE WHEN pp.key='vehicle_type' AND lower(pp.value_text)='truck' THEN 1 ELSE 0 END) AS p8,
         MAX(CASE WHEN pp.key='machine_type' AND lower(pp.value_text)='scroll saw' THEN 1 ELSE 0 END) AS p9,
         MAX(CASE WHEN pp.key='color_family' AND lower(pp.value_text)='black' THEN 1 ELSE 0 END) AS p10,
         MAX(CASE WHEN pp.key='length_m' AND pp.value_number=50 THEN 1 ELSE 0 END) AS p11,
         MAX(CASE WHEN pp.key='cleaner_type' AND lower(pp.value_text)='multi surface cleaner' THEN 1 ELSE 0 END) AS p12,
         MAX(CASE WHEN pp.key='volume_ml' AND pp.value_number=250 THEN 1 ELSE 0 END) AS p13,
         MAX(CASE WHEN pp.key='surface' AND lower(pp.value_text)='glass' THEN 1 ELSE 0 END) AS p14
  FROM base b
  LEFT JOIN product_properties pp ON pp.sku=b.sku
  GROUP BY b.item, b.sku, b.path
), exact AS (
  SELECT * FROM props
  WHERE (item='item1' AND p1=1 AND p2=1 AND p3=1)
     OR (item='item2' AND p4=1 AND p5=1)
     OR (item='item3' AND p6=1 AND p7=1 AND p8=1)
     OR (item='item4' AND p9=1)
     OR (item='item5' AND p10=1 AND p11=1)
     OR (item='item6' AND p12=1 AND p13=1 AND p14=1)
)
SELECT e.item, e.sku, e.path, COALESCE(i.available_today,0) AS available_today
FROM exact e
LEFT JOIN inventory i ON i.sku=e.sku AND i.store_id=(SELECT id FROM target_store)
ORDER BY e.item, e.sku;
