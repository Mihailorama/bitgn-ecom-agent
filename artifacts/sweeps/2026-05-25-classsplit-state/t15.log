WITH targets AS (
  SELECT 'item1' AS item, 'Safety Eyewear' AS kind, '3M' AS brand, 'SecureFit Aura' AS series, 'TUM-I54' AS model UNION ALL
  SELECT 'item2','Drain Trap and Siphon','Wavin','Professional Tigris','31G-M1A' UNION ALL
  SELECT 'item3','Automotive Cleaner','Liqui Moly','Workshop Top Tec','LMI-I9R' UNION ALL
  SELECT 'item4','Workshop Saw and Cutter','Bosch','Precision','PKS 3Q6-CLK' UNION ALL
  SELECT 'item5','Extension Cable','Hager','Workshop','HAG 1RH-81U' UNION ALL
  SELECT 'item6','Cleaning Liquid','Karcher','WD SC','1PM-1UM'
)
SELECT t.item, p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind,
       pp.key, pp.value_text, pp.value_number
FROM targets t
JOIN products p
  ON p.brand=t.brand AND p.series=t.series AND p.model=t.model
JOIN product_kinds pk
  ON pk.id=p.kind_id AND pk.name=t.kind
LEFT JOIN product_properties pp
  ON pp.sku=p.sku
WHERE (
    t.item='item1' AND (
      (pp.key='lens_color' AND lower(pp.value_text)='clear') OR
      (pp.key='size' AND lower(pp.value_text)='one size') OR
      (pp.key='coating' AND lower(pp.value_text)='anti fog')
    )
  ) OR (
    t.item='item2' AND (
      (pp.key='trap_type' AND lower(pp.value_text)='drain trap') OR
      (pp.key='diameter_mm' AND (pp.value_number=32 OR lower(pp.value_text)='32'))
    )
  ) OR (
    t.item='item3' AND (
      (pp.key='cleaner_type' AND lower(pp.value_text)='brake cleaner') OR
      (pp.key='volume_ml' AND (pp.value_number=4000 OR lower(pp.value_text)='4000')) OR
      (pp.key='vehicle_type' AND lower(pp.value_text)='truck')
    )
  ) OR (
    t.item='item4' AND (
      pp.key='machine_type' AND lower(pp.value_text)='scroll saw'
    )
  ) OR (
    t.item='item5' AND (
      (pp.key='color_family' AND lower(pp.value_text)='black') OR
      (pp.key='length_m' AND (pp.value_number=50 OR lower(pp.value_text)='50'))
    )
  ) OR (
    t.item='item6' AND (
      (pp.key='cleaner_type' AND lower(pp.value_text)='multi surface cleaner') OR
      (pp.key='volume_ml' AND (pp.value_number=250 OR lower(pp.value_text)='250')) OR
      (pp.key='surface' AND lower(pp.value_text)='glass')
    )
  )
ORDER BY t.item, p.sku, pp.key;
