[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
JOIN product_properties pp_fit ON pp_fit.sku = p.sku AND pp_fit.key = 'fitting' AND pp_fit.value_text = 'E14'
JOIN product_properties pp_w ON pp_w.sku = p.sku AND pp_w.key = 'wattage_w' AND pp_w.value_number = 10
JOIN product_properties pp_l ON pp_l.sku = p.sku AND pp_l.key = 'lumen' AND pp_l.value_number = 806
WHERE p.brand = 'Osram'
  AND p.series = 'Warm'
  AND p.model = 'Classic 2NL-Z7I'
  AND pk.name = 'LED Bulb'
ORDER BY p.sku;
