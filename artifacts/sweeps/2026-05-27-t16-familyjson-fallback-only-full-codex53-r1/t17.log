[32mOUT[0m: /bin/sql <<'SQL'
SELECT s.path AS store_path,
       COALESCE(i.available_today, 0) AS store_available,
       totals.total_available_today
FROM stores s
LEFT JOIN inventory i
  ON i.store_id = s.id
 AND i.sku = 'FST-1KPF96UD'
CROSS JOIN (
  SELECT COALESCE(SUM(COALESCE(i2.available_today,0)),0) AS total_available_today
  FROM stores s2
  LEFT JOIN inventory i2
    ON i2.store_id = s2.id
   AND i2.sku = 'FST-1KPF96UD'
  WHERE LOWER(s2.city) = 'vienna'
) totals
WHERE LOWER(s.city) = 'vienna'
ORDER BY s.path;
