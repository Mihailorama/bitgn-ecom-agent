    lower(p.series) LIKE '%heco 3dw-64b%'
    OR lower(p.model) LIKE '%heco 3dw-64b%'
    OR lower(p.name)  LIKE '%heco 3dw-64b%'
    OR lower(p.name)  LIKE '%nut bolt and washer%'
  )
ORDER BY p.sku, pp.key;
