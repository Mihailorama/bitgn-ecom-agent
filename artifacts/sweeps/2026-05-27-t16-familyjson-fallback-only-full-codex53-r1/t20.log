[32mOUT[0m: /bin/sql <<'SQL'
WITH target_product AS (
  SELECT DISTINCT p.sku, p.path
  FROM products p
  JOIN product_kinds pk ON pk.id = p.kind_id
  JOIN product_properties pp_ct ON pp_ct.sku = p.sku AND pp_ct.key = 'connector_type'
  JOIN product_properties pp_d ON pp_d.sku = p.sku AND pp_d.key = 'diameter_mm'
  WHERE p.brand = 'Viega'
    AND p.series = 'Flexible'
    AND p.model = 'Profipress 1M1-Z71'
    AND pk.name = 'Valve and Connector'
    AND pp_ct.value_text = 'thread adapter'
    AND COALESCE(pp_d.value_number, CAST(pp_d.value_text AS REAL)) = 15
)
SELECT s.path AS store_path,
       tp.path AS product_path,
       COALESCE(i.available_today, 0) AS store_available_today,
       SUM(COALESCE(i.available_today, 0)) OVER () AS total_available_today
FROM stores s
CROSS JOIN target_product tp
LEFT JOIN inventory i
  ON i.store_id = s.id
 AND i.sku = tp.sku
WHERE s.city = 'Graz'
ORDER BY s.path;
