  [[32msafe[0m] tool='exec' path='/bin/sql' args=[] stdin="SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,\n       pp1.value_text AS connector_type,\n       COALESCE(pp2.value_number, CAST(pp2.value_text AS REAL)) AS diameter_mm\nFROM products p\nJOIN product_properties pp1 ON pp1.sku = p.sku AND pp1.key = 'connector_type'\nJOIN product_properties pp2 ON pp2.sku = p.sku AND pp2.key = 'diameter_mm'\nWHERE p.brand = 'Viega'\n  AND p.series = 'Viega Flexible Profipress 1M1-Z71'\n  AND p.kind_id IN (SELECT id FROM product_kinds WHERE name = 'Valve and Connector')\n  AND pp1.value_text = 'thread adapter'\n  AND COALESCE(pp2.value_number, CAST(pp2.value_text AS REAL)) = 15;"
