WITH base AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind_name
  FROM products p
  JOIN product_kinds pk ON pk.id = p.kind_id
  WHERE (p.brand='Makita' AND p.series='Workshop' AND p.model='DDF OIE-YYP' AND pk.name='Workshop Drill Grinder and Sander')
     OR (p.brand='Festool' AND p.series='Modular' AND p.model='CTL XPW-76I' AND pk.name='Tool Box and Bag')
     OR (p.brand='Bosch' AND p.series='Bench' AND p.model='IXO 3JP-JOU' AND pk.name='Workshop Saw and Cutter')
     OR (p.brand='Dresselhaus' AND p.series='Outdoor Pro' AND p.model='1VG-P5G' AND pk.name='Wood and Drywall Screw')
     OR (p.brand='Sonax' AND p.series='Workshop' AND p.model='XTREME 218-FC5' AND pk.name='Automotive Cleaner')
)
SELECT b.sku, b.path, b.brand, b.series, b.model, b.kind_name, pp.key, pp.value_text, pp.value_number
FROM base b
LEFT JOIN product_properties pp ON pp.sku = b.sku
ORDER BY b.brand, b.series, b.model, b.kind_name, b.sku, pp.key;
