WITH req(row_id, req_qty, sku) AS (
  VALUES
    ('2ZEYi', 1, 'MAC-2JV5BGPP'),
    ('biEPm', 9, 'STO-2ZMSZF6Z'),
    ('aeV7B', 3, 'MAC-AXMHXNVG'),
    ('VWpDG', 3, 'AUT-2LHXWOM4')
), inv AS (
  SELECT r.row_id, r.req_qty, r.sku, COALESCE(i.available_today, 0) AS in_stock
  FROM req r
  LEFT JOIN inventory i
    ON i.store_id = 'store_bratislava_stare_mesto'
   AND i.sku = r.sku
), dresselhaus_match AS (
  SELECT p.sku, p.path
  FROM products p
  JOIN product_kinds pk ON pk.id = p.kind_id
  JOIN product_properties pp1 ON pp1.sku = p.sku AND pp1.key = 'screw_type' AND pp1.value_text = 'wood screw'
  JOIN product_properties pp2 ON pp2.sku = p.sku AND pp2.key = 'diameter_mm' AND COALESCE(pp2.value_number, -1) = 8
  JOIN product_properties pp3 ON pp3.sku = p.sku AND pp3.key = 'pack_count' AND COALESCE(pp3.value_number, -1) = 50
  WHERE p.brand = 'Dresselhaus'
    AND p.series = 'Outdoor Pro'
    AND p.model = '1VG-P5G'
    AND pk.name = 'Wood and Drywall Screw'
)
SELECT 'inventory' AS section, row_id, sku, in_stock, req_qty, CASE WHEN in_stock >= req_qty THEN 1 ELSE 0 END AS enough_qty, NULL AS path
FROM inv
UNION ALL
SELECT 'dresselhaus_match' AS section, NULL, sku, NULL, NULL, NULL, path
FROM dresselhaus_match
ORDER BY section, row_id;
