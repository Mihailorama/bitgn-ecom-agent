LEFT JOIN inventory i ON i.sku = p.sku
LEFT JOIN stores s ON s.id = i.store_id
WHERE p.brand = 'Fischer'
  AND p.series = 'Fischer SX'
  AND p.model = 'SX 7UY-G03'
  AND pp_anchor.value_text = 'concrete anchor'
  AND pp_diam.value_number = 6
ORDER BY p.sku, s.city;
