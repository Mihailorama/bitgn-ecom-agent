WITH target_store AS (
  SELECT id, path, name, city
  FROM stores
  WHERE city='Vienna' AND name LIKE '%Praterstern%'
), candidates AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind_name
  FROM products p
  JOIN product_kinds pk ON pk.id = p.kind_id
  WHERE
    (p.brand='Holzmann' AND p.series='Compact' AND p.model='D 327-RR0' AND pk.name='Compressor and Dust Extractor') OR
    (p.brand='Schneider Electric' AND p.series='Heavy Duty' AND p.model='Merten 214-ZHY' AND pk.name='Extension Cable') OR
    (p.brand='Geberit' AND p.series='Mapress Silent' AND p.model='IC5-GU6' AND pk.name='Valve and Connector') OR
    (p.brand='Keter' AND p.series='Deep Stack' AND p.model='2OO-VJU' AND pk.name='Storage Bin and Organizer') OR
    (p.brand='Raaco' AND p.series='Professional' AND p.model='CarryLite 3CS-7A9' AND pk.name='Shelving and Cabinet')
)
SELECT
  ts.id AS store_id,
  ts.path AS store_path,
  ts.name AS store_name,
  ts.city,
  c.sku,
  c.path AS product_path,
  c.brand,
  c.series,
  c.model,
  c.kind_name,
  pp.key,
  pp.value_text,
  pp.value_number,
  i.available_today
FROM target_store ts
JOIN inventory i ON i.store_id = ts.id
JOIN candidates c ON c.sku = i.sku
LEFT JOIN product_properties pp ON pp.sku = c.sku
ORDER BY c.brand, c.series, c.model, c.kind_name, c.sku, pp.key;
