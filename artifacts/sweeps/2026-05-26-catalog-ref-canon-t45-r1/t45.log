WITH target_store AS (
  SELECT id, path FROM stores
  WHERE city='Vienna' AND name='PowerTool Vienna Praterstern'
), requested(item_key, brand, series, model, kind_name, p1k, p1v, p2k, p2v, p3k, p3v) AS (
  VALUES
    ('holzmann_comp_1500_230','Holzmann','Compact','D 327-RR0','Compressor and Dust Extractor','machine_type','compressor','voltage_v','230','power_w','1500'),
    ('schneider_gray','Schneider Electric','Heavy Duty','Merten 214-ZHY','Extension Cable','color_family','gray',NULL,NULL,NULL,NULL),
    ('geberit_ball_valve','Geberit','Mapress Silent','IC5-GU6','Valve and Connector','connector_type','ball valve',NULL,NULL,NULL,NULL),
    ('keter_storage_bin','Keter','Deep Stack','2OO-VJU','Storage Bin and Organizer','storage_type','storage bin',NULL,NULL,NULL,NULL),
    ('schneider_white_len5','Schneider Electric','Heavy Duty','Merten 214-ZHY','Extension Cable','color_family','white','length_m','5',NULL,NULL),
    ('raaco_stacking_box','Raaco','Professional','CarryLite 3CS-7A9','Shelving and Cabinet','storage_type','stacking box',NULL,NULL,NULL,NULL)
), matched AS (
  SELECT r.item_key, p.sku, p.path AS product_path
  FROM requested r
  JOIN products p
    ON p.brand=r.brand AND p.series=r.series AND p.model=r.model
  JOIN product_kinds pk
    ON pk.id=p.kind_id AND pk.name=r.kind_name
  JOIN product_properties pp1
    ON pp1.sku=p.sku AND pp1.key=r.p1k AND lower(pp1.value_text)=lower(r.p1v)
  LEFT JOIN product_properties pp2
    ON r.p2k IS NOT NULL AND pp2.sku=p.sku AND pp2.key=r.p2k AND lower(pp2.value_text)=lower(r.p2v)
  LEFT JOIN product_properties pp3
    ON r.p3k IS NOT NULL AND pp3.sku=p.sku AND pp3.key=r.p3k AND lower(pp3.value_text)=lower(r.p3v)
  WHERE (r.p2k IS NULL OR pp2.sku IS NOT NULL)
    AND (r.p3k IS NULL OR pp3.sku IS NOT NULL)
), per_item AS (
  SELECT r.item_key,
         m.sku,
         m.product_path,
         COALESCE(i.available_today,0) AS available_today
  FROM requested r
  LEFT JOIN matched m ON m.item_key=r.item_key
  LEFT JOIN target_store ts ON 1=1
  LEFT JOIN inventory i ON i.store_id=ts.id AND i.sku=m.sku
)
SELECT COUNT(*) AS unavailable_count
FROM per_item
WHERE available_today=0;
