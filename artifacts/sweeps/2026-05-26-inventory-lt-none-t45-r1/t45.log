WITH req AS (
  SELECT 1 AS req_no, 'Schneider Electric' AS brand, 'Heavy Duty' AS series, 'Merten 214-ZHY' AS model, 'Extension Cable' AS kind, 'color_family' AS k1, 'White' AS v1, 'length_m' AS k2, '5' AS v2, NULL AS k3, NULL AS v3
  UNION ALL
  SELECT 2,'Gardena','Smart','PowerMax 280-5FI','Manual Garden Tool','tool_type','pruning saw',NULL,NULL,NULL,NULL
  UNION ALL
  SELECT 3,'Gardena','Smart','PowerMax 280-5FI','Manual Garden Tool','tool_type','pressure sprayer',NULL,NULL,NULL,NULL
  UNION ALL
  SELECT 4,'Bondex','Garden','Classic 106-TS1','Wood Stain and Deck Oil','product_type','wood stain',NULL,NULL,NULL,NULL
  UNION ALL
  SELECT 5,'3M','Ventilated','SecureFit 2CE-B35','Safety Eyewear','lens_color','Clear','size','M',NULL,NULL
  UNION ALL
  SELECT 6,'Philips','Professional','Hue 3JS-MSN','LED Bulb','wattage_w','10','luminous_flux_lm','1521',NULL,NULL
), base AS (
  SELECT r.req_no, p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind_name
  FROM req r
  JOIN products p
    ON p.brand = r.brand AND p.series = r.series AND p.model = r.model
