  UNION ALL SELECT 'PNT-2RHJYR74'
  UNION ALL SELECT 'SFE-HICY750I'
  UNION ALL
  SELECT pp.sku
  FROM products p
  JOIN product_kinds pk ON pk.id = p.kind_id
  JOIN product_properties pw ON pw.sku = p.sku AND pw.key = 'wattage_w' AND (pw.value_text = '10' OR pw.value_number = 10)
  JOIN product_properties pp ON pp.sku = p.sku AND pp.key = 'luminous_flux_lm' AND (pp.value_text = '1521' OR pp.value_number = 1521)
  WHERE p.brand = 'Philips' AND p.series = 'Professional' AND p.model = 'Hue 3JS-MSN' AND pk.name = 'LED Bulb'
)
SELECT COUNT(*) AS no_same_day_availability
FROM target_skus t
