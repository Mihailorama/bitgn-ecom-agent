SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       pp.key, pp.value_text, pp.value_number
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand) = 'hazet'
  AND (
    lower(p.series) LIKE '%smartcase 600 2jd-xcz%'
    OR lower(p.model) LIKE '%smartcase 600 2jd-xcz%'
    OR lower(p.name) LIKE '%smartcase 600 2jd-xcz%'
  )
  AND lower(p.name) LIKE '%hammer measuring and cutting tool%'
ORDER BY p.sku, pp.key;
