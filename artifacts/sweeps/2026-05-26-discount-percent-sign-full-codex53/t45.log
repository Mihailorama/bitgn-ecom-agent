WITH wanted AS (
  SELECT 'raaco' AS brand, 'Raaco Professional CarryLite' AS series, '3CS-7A9' AS model, 'Shelving and Cabinet' AS kind
  UNION ALL SELECT 'metabo','Metabo Brushless BS','1OW-IK5','Cordless Drill Driver'
  UNION ALL SELECT 'schneider electric','Schneider Electric Heavy Duty Merten','214-ZHY','Extension Cable'
  UNION ALL SELECT 'engelbert strauss','Engelbert Strauss Classic e.s.','37H-N9K','Work Trousers'
  UNION ALL SELECT 'fischer','Fischer SX','7UY-G03','Anchor and Wall Plug'
  UNION ALL SELECT '3m','3M Ventilated SecureFit','2CE-B35','Safety Eyewear'
)
SELECT p.sku,
       p.path,
       p.brand,
       p.series,
       p.model,
       pk.name AS kind,
       pp.key,
       COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) AS value
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
JOIN wanted w ON lower(p.brand)=w.brand
             AND lower(p.series)=lower(w.series)
             AND lower(p.model)=lower(w.model)
             AND lower(pk.name)=lower(w.kind)
LEFT JOIN product_properties pp ON pp.sku = p.sku
ORDER BY p.brand, p.series, p.model, p.sku, pp.key;
