SELECT p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
WHERE (
  lower(p.brand) LIKE '%raaco%' AND (lower(p.series) LIKE '%carrylite%' OR lower(p.model) LIKE '%3cs-7a9%')
) OR (
  lower(p.brand) LIKE '%metabo%' AND (lower(p.series) LIKE '%brushless bs%' OR lower(p.model) LIKE '%1ow-ik5%')
) OR (
  lower(p.brand) LIKE '%schneider%' AND (lower(p.series) LIKE '%merten%' OR lower(p.model) LIKE '%214-zhy%')
) OR (
  lower(p.brand) LIKE '%engelbert%' AND (lower(p.series) LIKE '%classic e.s.%' OR lower(p.model) LIKE '%37h-n9k%')
) OR (
  lower(p.brand) LIKE '%fischer%' AND (lower(p.series) LIKE '%sx%' OR lower(p.model) LIKE '%7uy-g03%')
) OR (
  lower(p.brand) IN ('3m','3 m') AND (lower(p.series) LIKE '%securefit%' OR lower(p.model) LIKE '%2ce-b35%')
)
ORDER BY p.brand, p.series, p.model, p.sku;
