[32mOUT[0m: /bin/sql <<'SQL'
SELECT s.path AS store_path, s.name, s.city, s.is_open, i.available_today
FROM inventory i
JOIN stores s ON s.id = i.store_id
WHERE i.sku = 'ELC-30NXGINM'
  AND s.is_open = 1
  AND i.available_today > 0
ORDER BY i.available_today DESC, s.name;
