SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind,
       pp.key, pp.value_text
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand='Schneider Electric'
  AND pk.name='Wiring Device'
  AND (
    p.series LIKE '%Acti%'
    OR p.model LIKE '%Acti%'
    OR p.name LIKE '%Acti%'
    OR p.series LIKE '%14B-98F%'
    OR p.model LIKE '%14B-98F%'
    OR p.name LIKE '%14B-98F%'
  )
ORDER BY p.series, p.model, p.sku, pp.key;
