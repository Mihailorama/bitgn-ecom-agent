	PRIMARY KEY (sku, key)
)"
stores,"CREATE TABLE stores (
	id TEXT PRIMARY KEY,
	path TEXT NOT NULL,
	name TEXT NOT NULL,
	city TEXT NOT NULL,
	is_open INTEGER NOT NULL,
	lat REAL NOT NULL,
	lon REAL NOT NULL
)"
inventory,"CREATE TABLE inventory (
	store_id TEXT NOT NULL,
