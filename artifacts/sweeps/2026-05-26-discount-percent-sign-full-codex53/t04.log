[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       pk.name AS kind,
       MAX(CASE WHEN pp.key='device_type' THEN pp.value_text END) AS device_type,
       MAX(CASE WHEN pp.key='color_family' THEN pp.value_text END) AS color_family
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand = 'Schneider Electric'
  AND (p.series = 'Indoor Acti 14B-98F' OR p.model = 'Indoor Acti 14B-98F' OR p.name LIKE '%Indoor Acti 14B-98F%')
  AND pk.name = 'Wiring Device'
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name
HAVING device_type = 'socket outlet' AND color_family = 'Black';
