SELECT pp.sku, p.path, pp.key, pp.value_text, pp.value_number
FROM product_properties pp
JOIN products p ON p.sku = pp.sku
WHERE lower(p.brand) LIKE '%hager%'
  AND (lower(p.series) LIKE '%workshop%' OR lower(p.model) LIKE '%1rh-81u%' OR lower(p.name) LIKE '%extension%')
ORDER BY pp.sku, pp.key;
