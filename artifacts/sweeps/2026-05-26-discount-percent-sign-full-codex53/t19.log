SELECT name, sql FROM sqlite_schema WHERE type='table' AND name IN ('stores','products','product_properties','inventory','product_kinds');

SELECT id, path, name, city FROM stores ORDER BY city, path;

SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pk.name AS kind
FROM products p
LEFT JOIN product_kinds pk ON pk.id = p.kind_id
WHERE lower(p.brand) LIKE '%hager%'
   OR lower(p.series) LIKE '%hager%'
   OR lower(p.model) LIKE '%1rh-81u%'
   OR lower(p.name) LIKE '%extension%'
   OR lower(pk.name) LIKE '%extension%'
