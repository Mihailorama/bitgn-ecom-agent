WITH vienna_stores AS (
  SELECT id, path
  FROM stores
  WHERE lower(city) = 'vienna'
)
SELECT vs.path AS store_path,
       COALESCE(i.available_today, 0) AS available_today_for_sku,
       (SELECT COALESCE(SUM(COALESCE(i2.available_today,0)),0)
        FROM vienna_stores vs2
        LEFT JOIN inventory i2
          ON i2.store_id = vs2.id AND i2.sku = 'AUT-1SJPI2YE') AS total_available_today
FROM vienna_stores vs
LEFT JOIN inventory i
  ON i.store_id = vs.id AND i.sku = 'AUT-1SJPI2YE'
ORDER BY vs.path;
