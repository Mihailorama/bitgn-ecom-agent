SELECT p.sku, p.path, p.brand, p.series, p.model, p.name
FROM products p
JOIN product_properties pp_type ON pp_type.sku = p.sku AND pp_type.key = 'product_type' AND lower(pp_type.value_text) = 'jump starter'
JOIN product_properties pp_voltage ON pp_voltage.sku = p.sku AND pp_voltage.key = 'voltage_v' AND (
  pp_voltage.value_number = 12 OR lower(pp_voltage.value_text) IN ('12','12 v','12v')
)
JOIN product_properties pp_current ON pp_current.sku = p.sku AND pp_current.key = 'current_a' AND (
  pp_current.value_number = 4 OR lower(pp_current.value_text) IN ('4','4 a','4a')
)
WHERE lower(p.brand) = 'bosch'
  AND lower(p.series) = 'bosch premium'
  AND lower(p.model) = 'bbs 3ke-jdb'
  AND lower(p.name) LIKE '%automotive charger and bulb%';
