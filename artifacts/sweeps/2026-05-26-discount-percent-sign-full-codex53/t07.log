    lower(p.name) LIKE '%pliers and wrenches%'
    OR lower(p.series) LIKE '%pliers and wrenches%'
    OR lower(p.model) LIKE '%ets-3cm%'
    OR lower(p.name) LIKE '%ets-3cm%'
  )
ORDER BY p.sku, pp.key;
