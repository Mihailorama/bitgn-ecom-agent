[32mOUT[0m: /bin/sql <<'SQL'
WITH actor AS (
  SELECT e.id AS employee_id, e.store_id, s.path AS store_path
  FROM employees e
  JOIN stores s ON s.id = e.store_id
  WHERE e.id = 'emp_006'
),
req(ord,row_id,qty,brand,series,model,kind_name) AS (
  VALUES
    (1,'e2wxG',4,'Wago','Compact','222 3V7-GBQ','Extension Cable'),
    (2,'JhzA9',9,'Karcher','WD','SC 1PM-1UM','Cleaning Liquid'),
    (3,'hnS23',4,'Stihl','AK System','HSA DUW-0VN','Chainsaw'),
    (4,'XvNLM',3,'Spax','Outdoor','T-Star 1GS-NEI','Wood and Drywall Screw'),
    (5,'cKFaw',2,'Castrol','All Season','GTX 3PP-ZPA','Engine Oil'),
    (6,'B4PgL',3,'Hammerite','Quick Dry','HAM 22B-SYZ','Metal and Concrete Paint')
),
matched AS (
  SELECT 'e2wxG' AS row_id, 'ELC-MC4A3LVJ' AS sku UNION ALL
  SELECT 'JhzA9','CLN-3KKVTTPJ' UNION ALL
  SELECT 'hnS23','GRD-32A30E2Y' UNION ALL
  SELECT 'B4PgL','PNT-12949NIR'
),
relevant_props AS (
  SELECT 'e2wxG' AS row_id, 'color_family' AS k UNION ALL
  SELECT 'e2wxG','length_m' UNION ALL
  SELECT 'JhzA9','cleaner_type' UNION ALL
  SELECT 'JhzA9','volume_ml' UNION ALL
  SELECT 'hnS23','power_source' UNION ALL
  SELECT 'hnS23','bar_length_cm' UNION ALL
  SELECT 'hnS23','battery_platform' UNION ALL
  SELECT 'B4PgL','product_type'
)
SELECT
  r.ord,
  r.row_id,
  p.sku,
  p.path AS product_path,
  p.brand,
  p.series,
  p.model,
  pk.name AS kind,
  pp.key,
  pp.value_text,
  pp.value_number,
  a.store_path,
  i.available_today
FROM req r
LEFT JOIN matched m ON m.row_id = r.row_id
LEFT JOIN products p ON p.sku = m.sku
LEFT JOIN product_kinds pk ON pk.id = p.kind_id
LEFT JOIN relevant_props rp ON rp.row_id = r.row_id
LEFT JOIN product_properties pp ON pp.sku = p.sku AND pp.key = rp.k
CROSS JOIN actor a
LEFT JOIN inventory i ON i.store_id = a.store_id AND i.sku = p.sku
ORDER BY r.ord, p.sku, pp.key;
