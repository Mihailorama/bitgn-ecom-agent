WITH actor_store AS (
  SELECT store_id
  FROM employees
  WHERE id = 'emp_006'
),
req(ord, row_id, qty) AS (
  VALUES
    (1,'e2wxG',4),
    (2,'JhzA9',9),
    (3,'hnS23',4),
    (4,'XvNLM',3),
    (5,'cKFaw',2),
    (6,'B4PgL',3)
),
matched AS (
  SELECT 'e2wxG' AS row_id, 'ELC-MC4A3LVJ' AS sku
  UNION ALL SELECT 'JhzA9', 'CLN-3KKVTTPJ'
  UNION ALL SELECT 'hnS23', 'GRD-32A30E2Y'
  UNION ALL SELECT 'B4PgL', 'PNT-12949NIR'
)
SELECT
  r.ord,
  r.row_id,
  m.sku,
  CASE WHEN m.sku IS NULL THEN NULL ELSE COALESCE(i.available_today,0) END AS in_stock,
  CASE
    WHEN m.sku IS NOT NULL AND COALESCE(i.available_today,0) >= r.qty THEN 'true'
    ELSE 'false'
  END AS match
FROM req r
LEFT JOIN matched m ON m.row_id = r.row_id
LEFT JOIN actor_store s ON 1=1
LEFT JOIN inventory i ON i.store_id = s.store_id AND i.sku = m.sku
ORDER BY r.ord;
