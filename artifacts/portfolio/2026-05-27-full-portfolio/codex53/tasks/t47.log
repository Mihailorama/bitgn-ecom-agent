    ('B4PgL','Hammerite','Hammerite Quick Dry HAM','22B-SYZ','Metal and Concrete Paint')
)
SELECT
  w.row_id,
  p.sku,
  p.path,
  p.brand,
  p.series,
  p.model,
  pk.name AS kind,
  pp.key,
  pp.value_text,
