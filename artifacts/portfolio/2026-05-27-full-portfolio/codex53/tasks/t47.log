WITH rows(row_id, brand, kind_hint) AS (
  VALUES
    ('e2wxG','Wago','Extension Cable'),
    ('JhzA9','Karcher','Cleaning Liquid'),
    ('hnS23','Stihl','Chainsaw'),
    ('XvNLM','Spax','Wood and Drywall Screw'),
    ('cKFaw','Castrol','Engine Oil'),
    ('B4PgL','Hammerite','Metal and Concrete Paint')
)
SELECT
  r.row_id,
  p.sku,
  p.path,
  p.brand,
  p.series,
  p.model,
  p.name,
  pk.name AS kind
FROM rows r
JOIN products p ON p.brand = r.brand
JOIN product_kinds pk ON pk.id = p.kind_id
WHERE pk.name = r.kind_hint
   OR p.name LIKE '%' || r.kind_hint || '%'
ORDER BY r.row_id, p.series, p.model, p.sku;
