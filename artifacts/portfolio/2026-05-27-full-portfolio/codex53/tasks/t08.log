[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       MAX(CASE WHEN pp.key='color_family' THEN pp.value_text END) AS color_family,
       MAX(CASE WHEN pp.key IN ('length_m','length') THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS length_value
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE (p.brand='Kopp' OR p.name LIKE '%Kopp%')
  AND (p.series='Kopp Indoor' OR p.name LIKE '%KOP 1NZ-ACC%')
  AND (p.model='KOP 1NZ-ACC' OR p.name LIKE '%Extension Cable%')
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
ORDER BY p.sku;
