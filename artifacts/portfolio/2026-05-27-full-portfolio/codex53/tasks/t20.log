SELECT p.sku, p.path, p.brand, p.series, p.model, p.name, pp.key, COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) AS value
FROM products p
JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand='Philips'
  AND (p.name LIKE '%LED Bulb%' OR p.model LIKE '%KLU-8H2%' OR p.series LIKE '%SceneSwitch%' OR p.series LIKE '%Ultra%')
ORDER BY p.series, p.model, p.sku, pp.key;
