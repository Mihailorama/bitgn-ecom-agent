Next step_4... Compute SUM(available_today) for SKU ELC-Z394OELV across all Graz stores using LEFT JOIN. (11946 ms)
  [[32msafe[0m] tool='exec' path='/bin/sql' args=[] stdin="SELECT s.path AS store_path,\n       COALESCE(i.available_today, 0) AS available_today,\n       p.path AS product_path,\n       (SELECT SUM(COALESCE(i2.available_today,0))\n        FROM stores s2\n        LEFT JOIN inventory i2 ON i2.store_id=s2.id AND i2.sku='ELC-Z394OELV'\n        WHERE s2.city='Graz') AS total_available\nFROM stores s\nCROSS JOIN products p\nLEFT JOIN inventory i ON i.store_id=s.id AND i.sku='ELC-Z394OELV'\nWHERE s.city='Graz' AND p.sku='ELC-Z394OELV'\nORDER BY s.path;"
[32mOUT[0m: /bin/sql <<'SQL'
SELECT s.path AS store_path,
       COALESCE(i.available_today, 0) AS available_today,
       p.path AS product_path,
       (SELECT SUM(COALESCE(i2.available_today,0))
        FROM stores s2
        LEFT JOIN inventory i2 ON i2.store_id=s2.id AND i2.sku='ELC-Z394OELV'
        WHERE s2.city='Graz') AS total_available
FROM stores s
CROSS JOIN products p
LEFT JOIN inventory i ON i.store_id=s.id AND i.sku='ELC-Z394OELV'
WHERE s.city='Graz' AND p.sku='ELC-Z394OELV'
ORDER BY s.path;
SQL
