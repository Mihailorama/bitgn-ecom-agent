  [[32msafe[0m] tool='exec' path='/bin/sql' args=[] stdin="SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,\n       MAX(CASE WHEN pp.key='wattage_w' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS wattage_w,\n       MAX(CASE WHEN pp.key='luminous_flux_lm' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS luminous_flux_lm,\n       MAX(CASE WHEN pp.key='fitting' THEN pp.value_text END) AS fitting,\n       MAX(CASE WHEN pp.key='color_temperature_k' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS color_temperature_k\nFROM products p\nJOIN product_properties pp ON pp.sku = p.sku\nWHERE p.brand='Philips'\n  AND p.series='Philips SceneSwitch Ultra'\n  AND p.model='KLU-8H2'\n  AND p.name LIKE '%LED Bulb%'\nGROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name\nHAVING SUM(CASE WHEN pp.key='wattage_w' AND (pp.value_number=12 OR pp.value_text='12') THEN 1 ELSE 0 END) > 0\n   AND SUM(CASE WHEN pp.key='luminous_flux_lm' AND (pp.value_number=1521 OR pp.value_text='1521') THEN 1 ELSE 0 END) > 0\n   AND SUM(CASE WHEN pp.key='fitting' AND pp.value_text='E27' THEN 1 ELSE 0 END) > 0\n   AND SUM(CASE WHEN pp.key IN ('color_temperature_k','colour_temperature_k') AND (pp.value_number=2700 OR pp.value_text='2700') THEN 1 ELSE 0 END) > 0;"
[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       MAX(CASE WHEN pp.key='wattage_w' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS wattage_w,
       MAX(CASE WHEN pp.key='luminous_flux_lm' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS luminous_flux_lm,
       MAX(CASE WHEN pp.key='fitting' THEN pp.value_text END) AS fitting,
       MAX(CASE WHEN pp.key='color_temperature_k' THEN COALESCE(CAST(pp.value_number AS TEXT), pp.value_text) END) AS color_temperature_k
FROM products p
JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand='Philips'
  AND p.series='Philips SceneSwitch Ultra'
  AND p.model='KLU-8H2'
  AND p.name LIKE '%LED Bulb%'
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
HAVING SUM(CASE WHEN pp.key='wattage_w' AND (pp.value_number=12 OR pp.value_text='12') THEN 1 ELSE 0 END) > 0
   AND SUM(CASE WHEN pp.key='luminous_flux_lm' AND (pp.value_number=1521 OR pp.value_text='1521') THEN 1 ELSE 0 END) > 0
   AND SUM(CASE WHEN pp.key='fitting' AND pp.value_text='E27' THEN 1 ELSE 0 END) > 0
   AND SUM(CASE WHEN pp.key IN ('color_temperature_k','colour_temperature_k') AND (pp.value_number=2700 OR pp.value_text='2700') THEN 1 ELSE 0 END) > 0;
