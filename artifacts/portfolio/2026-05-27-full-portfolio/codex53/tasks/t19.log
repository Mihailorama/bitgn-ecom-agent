WITH product_candidates AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name
  FROM products p
  WHERE p.brand='Bosch'
    AND (
      p.name LIKE '%Automotive Charger and Bulb%'
      OR p.series LIKE '%Bosch Workshop%'
      OR p.model LIKE '%GWS 17A-FAQ%'
    )
)
SELECT pc.sku, pc.path, pc.brand, pc.series, pc.model, pc.name,
       pp.key, pp.value_text
FROM product_candidates pc
LEFT JOIN product_properties pp ON pp.sku = pc.sku
ORDER BY pc.path, pc.sku, pp.key;
