WITH vienna_stores AS (
  SELECT id, path, name
  FROM stores
  WHERE city='Vienna'
), candidate_products AS (
  SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
         pp.key, pp.value_text
  FROM products p
  LEFT JOIN product_properties pp ON pp.sku = p.sku
  WHERE p.brand='Bosch'
    AND p.series='Bosch Workshop'
    AND p.model='GWS 17A-FAQ'
    AND p.name='Automotive Charger and Bulb'
)
SELECT 'store' AS row_type, vs.id, vs.path, vs.name, NULL AS sku, NULL AS key, NULL AS value_text
FROM vienna_stores vs
UNION ALL
SELECT 'product' AS row_type, NULL, cp.path, cp.name, cp.sku, cp.key, cp.value_text
FROM candidate_products cp
ORDER BY row_type, path, sku, key;
