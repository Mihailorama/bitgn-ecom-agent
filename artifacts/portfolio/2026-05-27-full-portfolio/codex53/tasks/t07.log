[32mOUT[0m: /bin/sql <<'SQL'
SELECT p.sku, p.path, p.brand, p.series, p.model, p.name,
       MAX(CASE WHEN pp.key='product_type' THEN pp.value_text END) AS product_type,
       MAX(CASE WHEN pp.key='color_family' THEN pp.value_text END) AS color_family,
       MAX(CASE WHEN pp.key='finish' THEN pp.value_text END) AS finish
FROM products p
LEFT JOIN product_properties pp ON pp.sku = p.sku
WHERE lower(p.brand) = 'sikkens'
  AND (
    lower(p.series) LIKE '%cetol rubbol 1ke-gbp%'
    OR lower(p.model) LIKE '%cetol rubbol 1ke-gbp%'
    OR lower(p.name)  LIKE '%cetol rubbol 1ke-gbp%'
  )
GROUP BY p.sku, p.path, p.brand, p.series, p.model, p.name
ORDER BY p.sku;
