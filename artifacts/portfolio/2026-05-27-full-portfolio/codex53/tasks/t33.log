SELECT p.sku, p.path, p.brand, p.series, p.model, pk.name AS kind,
       MAX(CASE WHEN pp.key='machine_type' THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS machine_type,
       MAX(CASE WHEN pp.key='voltage_v' THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS voltage_v,
       MAX(CASE WHEN pp.key='power_w' THEN COALESCE(pp.value_text, CAST(pp.value_number AS TEXT)) END) AS power_w
FROM products p
JOIN product_kinds pk ON pk.id = p.kind_id
JOIN product_properties pp ON pp.sku = p.sku
WHERE p.brand = 'Bosch'
  AND p.series = 'Bosch Precision PKS 3Q6-CLK'
  AND pk.name = 'Workshop Saw and Cutter'
GROUP BY p.sku, p.path, p.brand, p.series, p.model, pk.name
HAVING machine_type = 'band saw'
   AND (voltage_v = '400' OR voltage_v = '400 V')
   AND (power_w = '1500' OR power_w = '1500 W');
