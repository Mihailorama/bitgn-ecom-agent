[32mOUT[0m: /bin/sql <<'SQL'
SELECT s.id, s.path, s.name, s.city, s.is_open,
       COALESCE(i.available_today, 0) AS available_today
FROM stores s
LEFT JOIN inventory i ON i.store_id = s.id AND i.sku = 'FST-3ONWRMX0'
WHERE s.city = 'Graz';
